generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model todo {
  id          Int      @id @default(autoincrement())
  titulo      String
  descripcion String?
  etiquetas   String?
  createdAt   DateTime @default(now())
}