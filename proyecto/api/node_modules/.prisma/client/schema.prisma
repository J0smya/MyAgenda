generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model archivo {
  id_archivo   String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  nombre       String    @db.VarChar(150)
  ruta_archivo String    @db.VarChar(255)
  tipo         String?   @db.VarChar(50)
  tamano       Int?
  fecha_subida DateTime? @default(now()) @db.Timestamp(6)
  id_tarea     String    @db.Uuid
  deleted_at   DateTime? @db.Timestamp(6)
  tarea        tarea     @relation(fields: [id_tarea], references: [id_tarea], onDelete: Cascade, onUpdate: NoAction, map: "fk_archivo_tarea")
}

model etiqueta {
  id_etiqueta    String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  nombre         String           @db.VarChar(100)
  color          String?          @db.VarChar(20)
  id_usuario     String           @db.Uuid
  usuario        usuario          @relation(fields: [id_usuario], references: [id_usuario], onDelete: Cascade, onUpdate: NoAction, map: "fk_etiqueta_usuario")
  tarea_etiqueta tarea_etiqueta[]
}

model nota {
  id_nota        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  contenido      String
  fecha_creacion DateTime? @default(now()) @db.Timestamp(6)
  id_tarea       String    @db.Uuid
  deleted_at     DateTime? @db.Timestamp(6)
  tarea          tarea     @relation(fields: [id_tarea], references: [id_tarea], onDelete: Cascade, onUpdate: NoAction, map: "fk_nota_tarea")
}

model proyecto {
  id_proyecto    String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  nombre         String           @db.VarChar(150)
  color          String?          @db.VarChar(20)
  descripcion    String?
  fecha_creacion DateTime?        @default(now()) @db.Timestamp(6)
  estado         estado_proyecto? @default(activo)
  id_usuario     String           @db.Uuid
  deleted_at     DateTime?        @db.Timestamp(6)
  usuario        usuario          @relation(fields: [id_usuario], references: [id_usuario], onDelete: Cascade, onUpdate: NoAction, map: "fk_proyecto_usuario")
  tarea          tarea[]
}

model tarea {
  id_tarea          String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  titulo            String           @db.VarChar(150)
  descripcion       String?
  fecha_inicio      DateTime?        @db.Date
  fecha_vencimiento DateTime?        @db.Date
  hora_inicio       DateTime?        @db.Time(6)
  hora_fin          DateTime?        @db.Time(6)
  fecha_creacion    DateTime?        @default(now()) @db.Timestamp(6)
  estado            estado_tarea?    @default(pendiente)
  prioridad         prioridad_tarea? @default(media)
  id_proyecto       String?          @db.Uuid
  fecha_desactiva   DateTime?        @db.Timestamptz(6)
  razon_desactiva   String?
  deleted_at        DateTime?        @db.Timestamp(6)
  categoria         String?          @default("personal") @db.VarChar(50)
  archivo           archivo[]
  nota              nota[]
  proyecto          proyecto?        @relation(fields: [id_proyecto], references: [id_proyecto], onDelete: Cascade, onUpdate: NoAction, map: "fk_tarea_proyecto")
  tarea_etiqueta    tarea_etiqueta[]
}

model tarea_etiqueta {
  id_tarea    String   @db.Uuid
  id_etiqueta String   @db.Uuid
  etiqueta    etiqueta @relation(fields: [id_etiqueta], references: [id_etiqueta], onDelete: Cascade, onUpdate: NoAction, map: "fk_te_etiqueta")
  tarea       tarea    @relation(fields: [id_tarea], references: [id_tarea], onDelete: Cascade, onUpdate: NoAction, map: "fk_te_tarea")

  @@id([id_tarea, id_etiqueta])
}

model usuario {
  id_usuario     String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  nombre         String     @db.VarChar(100)
  email          String     @unique @db.VarChar(150)
  telefono       String?    @unique @db.VarChar(20)
  contrasena     String     @db.VarChar(255)
  foto_perfil    String?    @db.VarChar(255)
  fecha_creacion DateTime?  @default(now()) @db.Timestamp(6)
  ultimo_acceso  DateTime?  @db.Timestamp(6)
  etiqueta       etiqueta[]
  proyecto       proyecto[]
}

enum estado_proyecto {
  activo
  finalizado
  archivado
}

enum estado_tarea {
  pendiente
  en_progreso
  completada
}

enum prioridad_tarea {
  baja
  media
  alta
}
