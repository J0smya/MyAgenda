  /* ════ TOASTS ════ */
  function mostrarToast(titulo: string, subtitulo: string, tipo: 'ahora' | 'antes') {
    const iconSvg = tipo === 'ahora'
      ? `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>`
      : `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/></svg>`;
    const label = tipo === 'ahora' ? 'Ahora' : 'Recordatorio';
    const toast = document.createElement('div');
    toast.className = `toast-notif toast-${tipo}`;
    toast.innerHTML = `
      <div class="toast-icon-wrap">${iconSvg}</div>
      <div class="toast-body">
        <div class="toast-label">${label}</div>
        <div class="toast-title">${titulo}</div>
        ${subtitulo ? `<div class="toast-sub">${subtitulo}</div>` : ''}
      </div>
      <button class="toast-close" title="Cerrar">✕</button>
    `;
    toast.querySelector('.toast-close')?.addEventListener('click', (e) => { e.stopPropagation(); cerrarToast(toast); });
    toast.addEventListener('click', () => cerrarToast(toast));
    toastContainer.appendChild(toast);
    setTimeout(() => cerrarToast(toast), 6000);
  }
  function cerrarToast(toast: HTMLElement) {
    toast.classList.add('toast-out');
    toast.addEventListener('animationend', () => toast.remove(), { once: true });
  }

  /* ════ RECORDATORIOS ════ */
  function programarRecordatorio(tarea: Tarea, minutosAntes: number) {
    if (!tarea.hora) return;
    const key = String(tarea.id);
    if (recordatoriosActivos.has(key)) recordatoriosActivos.get(key)!.forEach(clearTimeout);
    const timers: ReturnType<typeof setTimeout>[] = [];
    const [anio, mes, dia] = tarea.fecha.split('-').map(Number);
    const [hh, mm]         = tarea.hora.split(':').map(Number);
    const vencimiento      = new Date(anio, mes - 1, dia, hh, mm, 0, 0);
    const ahora            = Date.now();
    const msAntes = vencimiento.getTime() - minutosAntes * 60 * 1000 - ahora;
    if (msAntes > 0) {
      const label = minutosAntes >= 60 ? `En ${minutosAntes/60}h` : `En ${minutosAntes} min`;
      timers.push(setTimeout(() => mostrarToast(tarea.titulo, `${label} · ${tarea.hora}`, 'antes'), msAntes));
    }
    const msExacto = vencimiento.getTime() - ahora;
    if (msExacto > 0) timers.push(setTimeout(() => mostrarToast(tarea.titulo, `Hora exacta · ${tarea.hora}`, 'ahora'), msExacto));
    if (timers.length) recordatoriosActivos.set(key, timers);
  }

