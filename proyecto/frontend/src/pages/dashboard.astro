  function calcularFechasPreview(fechaBase: string): string[] {
    const MAX = recConfig.finTipo==='cantidad' && recConfig.totalOcurr ? Math.min(recConfig.totalOcurr,20) : 8;
    const parse  = (s:string)=>{ const [y,m,d]=s.split('-').map(Number); return new Date(y,m-1,d); };
    const toISO  = (d:Date)=>`${d.getFullYear()}-${String(d.getMonth()+1).padStart(2,'0')}-${String(d.getDate()).padStart(2,'0')}`;
    const isoDay = (d:Date)=>d.getDay()===0?7:d.getDay();
    const fechas:string[]=[];
    let cur = parse(fechaBase);
    const lim = recConfig.finTipo==='fecha'&&recConfig.fechaFin ? parse(recConfig.fechaFin) : null;
    const dias = recConfig.diasSemana.length>0 ? recConfig.diasSemana : null;
    while (fechas.length<MAX) {
      if (lim&&cur>lim) break;
      if (!dias||dias.includes(isoDay(cur))) fechas.push(toISO(cur));
      if (recConfig.frecuencia==='diaria') cur.setDate(cur.getDate()+recConfig.intervalo);
      else if (recConfig.frecuencia==='semanal') {
        if (dias) {
          cur.setDate(cur.getDate()+1);
          if (isoDay(cur)===1&&recConfig.intervalo>1) cur.setDate(cur.getDate()+(recConfig.intervalo-1)*7);
        } else cur.setDate(cur.getDate()+recConfig.intervalo*7);
      } else cur.setMonth(cur.getMonth()+recConfig.intervalo);
    }
    return fechas;
  }
 
  function generarPreviewRec() {
    const fechaBase = (document.getElementById('t-fecha') as HTMLInputElement)?.value;
    if (!fechaBase) { recPreview.innerHTML='<span style="font-size:11px;color:#9ca3af;grid-column:1/-1;text-align:center;">Selecciona fecha primero</span>'; return; }
    const fechas = calcularFechasPreview(fechaBase);
    if (!fechas.length) { recPreview.innerHTML='<span style="font-size:11px;color:#9ca3af;grid-column:1/-1;text-align:center;">Sin fechas</span>'; return; }
    const SHOW=6;
    const chips=fechas.slice(0,SHOW).map(f=>{
      const d=new Date(f+'T00:00:00');
      return `<span class="db-rec-preview-chip">${d.toLocaleDateString('es-ES',{day:'2-digit',month:'short'})}</span>`;
    }).join('');
    const extra=fechas.length>SHOW?`<span class="db-rec-preview-extra">+${fechas.length-SHOW} más</span>`:'';
    recPreview.innerHTML=chips+extra;
  }
 
