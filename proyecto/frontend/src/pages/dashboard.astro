---
import Layout from "../layouts/Layout.astro";
---

<Layout title="MyAgenda Pro 2026">
  <div class="flex h-screen bg-[#f1f5f9] overflow-hidden font-sans text-slate-900 relative">
    
    <aside class="w-72 bg-[#0f172a] text-white p-8 flex flex-col gap-10 shadow-2xl z-20">
      <div class="text-3xl font-black text-blue-400 flex items-center gap-3 italic tracking-tighter">
        <span>📅</span> MY AGENDA
      </div>
      <div class="space-y-8">
        <h3 class="text-[11px] font-black text-slate-500 uppercase tracking-[0.2em]">FILTROS</h3>
        <div class="space-y-5 text-sm font-bold">
            <label class="flex items-center gap-4 cursor-pointer group">
              <input type="checkbox" id="f-trabajo" checked class="w-6 h-6 rounded-lg accent-blue-500"> 
              <span class="group-hover:text-blue-400 transition-colors uppercase italic">Trabajo</span>
            </label>
            <label class="flex items-center gap-4 cursor-pointer group">
              <input type="checkbox" id="f-personal" checked class="w-6 h-6 rounded-lg accent-emerald-500"> 
              <span class="group-hover:text-emerald-400 transition-colors uppercase italic">Personal</span>
            </label>
        </div>
      </div>
    </aside>

    <main class="flex-1 flex flex-col bg-white">
      <header class="p-8 border-b flex justify-between items-center bg-white/90 backdrop-blur-md sticky top-0 z-10">
        <div class="flex items-center gap-8">
            <div class="flex gap-3">
                <button id="prev-date" class="group bg-slate-100 hover:bg-blue-600 w-12 h-12 rounded-2xl flex items-center justify-center transition-all shadow-sm">
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-slate-600 group-hover:text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path d="M15 19l-7-7 7-7" /></svg>
                </button>
                <button id="next-date" class="group bg-slate-100 hover:bg-blue-600 w-12 h-12 rounded-2xl flex items-center justify-center transition-all shadow-sm">
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-slate-600 group-hover:text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path d="M9 5l7 7-7 7" /></svg>
                </button>
            </div>
            <div>
                <h2 id="header-title" class="text-3xl font-black text-slate-800 uppercase italic tracking-tighter leading-none">Cargando...</h2>
            </div>
        </div>
        
        <div class="flex items-center gap-3 bg-slate-100 p-1.5 rounded-[2rem]">
            <button data-v="dia" class="nav-btn px-8 py-2.5 rounded-[1.5rem] font-black text-[11px] transition-all">DIA</button>
            <button data-v="semana" class="nav-btn px-8 py-2.5 rounded-[1.5rem] font-black text-[11px] transition-all">SEMANA</button>
            <button data-v="mes" class="nav-btn px-8 py-2.5 rounded-[1.5rem] font-black text-[11px] transition-all">MES</button>
            <button id="btn-add" class="ml-4 bg-[#1e60ff] text-white px-8 py-2.5 rounded-[1.5rem] font-black text-[11px] shadow-lg hover:bg-blue-700 transition-all uppercase">+ NUEVA TAREA</button>
        </div>
      </header>

      <div class="flex-1 overflow-y-auto p-8 bg-[#f8fafc]" id="view-container"></div>
    </main>

    <button id="btn-ai-toggle" class="fixed bottom-8 right-8 w-16 h-16 bg-[#0f172a] text-blue-400 rounded-full shadow-2xl flex items-center justify-center hover:scale-110 transition-all z-[150] border-4 border-white">
        <span class="text-2xl">🤖</span>
    </button>

    <div id="ai-window" class="fixed bottom-28 right-8 w-80 h-[500px] bg-white rounded-[2.5rem] shadow-2xl border border-slate-100 hidden flex-col overflow-hidden z-[150] animate-in fade-in slide-in-from-bottom-5">
        <div class="p-6 bg-[#0f172a] text-white flex justify-between items-center font-black italic uppercase text-xs">Asistente IA</div>
        <div class="flex-1 p-6 overflow-y-auto text-[10px] font-black uppercase italic text-slate-400">¿En qué puedo ayudarte?</div>
        <div class="p-4 border-t bg-slate-50">
            <input type="text" class="w-full bg-white border-none p-4 rounded-full font-black text-[10px] outline-none shadow-sm uppercase" placeholder="ESCRIBE...">
        </div>
    </div>

    <div id="modal" class="fixed inset-0 bg-slate-900/60 backdrop-blur-md hidden items-center justify-center z-[200] p-4">
      <div class="bg-white w-full max-w-xl rounded-[2.5rem] p-8 shadow-2xl overflow-y-auto max-h-[95vh]">
        <form id="task-form" class="space-y-5">
          <h3 class="font-black italic uppercase text-2xl text-center tracking-tighter mb-2">AGENDAR TAREA</h3>
          <input type="text" id="t-titulo" required placeholder="TÍTULO DE LA TAREA" class="w-full bg-[#f8fafc] border-none p-5 rounded-[1.5rem] font-bold uppercase outline-none focus:ring-4 focus:ring-blue-100">
          <textarea id="t-desc" placeholder="DESCRIPCIÓN O NOTAS" class="w-full bg-[#f8fafc] border-none p-5 rounded-[1.5rem] font-bold uppercase outline-none focus:ring-4 focus:ring-blue-100 resize-none"></textarea>
          
          <div class="grid grid-cols-2 gap-4">
              <select id="t-prioridad" class="bg-[#f8fafc] border-none p-5 rounded-[1.5rem] font-black text-[10px] uppercase outline-none">
                  <option value="alta">🔴 ALTA</option>
                  <option value="media" selected>🟡 MEDIA</option>
                  <option value="baja">🔵 BAJA</option>
              </select>
              <select id="t-cat" class="bg-[#f8fafc] border-none p-5 rounded-[1.5rem] font-black text-[10px] uppercase outline-none">
                  <option value="trabajo">💼 TRABAJO</option>
                  <option value="personal">🏠 PERSONAL</option>
              </select>
          </div>

          <div class="flex flex-col items-center gap-3">
              <label class="flex items-center gap-3 cursor-pointer group bg-slate-50 px-6 py-3 rounded-full border border-slate-100">
                  <input type="checkbox" id="t-usa-hora" class="w-5 h-5 accent-blue-600">
                  <span class="font-black text-[10px] uppercase italic text-slate-500">¿Asignar hora?</span>
              </label>
              <div id="wrapper-hora" class="hidden w-full max-w-[200px]">
                  <input type="time" id="t-hora-inicio" class="w-full bg-blue-50 border-none p-4 rounded-[1.5rem] font-black text-center outline-none text-blue-600">
              </div>
          </div>

          <div class="pt-4 space-y-3">
              <button type="submit" class="w-full bg-[#1e60ff] text-white py-5 rounded-full font-black uppercase text-xs shadow-lg hover:bg-blue-700 transition-all">GUARDAR TAREA</button>
              <button type="button" id="close-modal" class="w-full py-2 font-black text-[10px] text-slate-400 uppercase tracking-widest hover:text-red-500">CANCELAR</button>
          </div>
        </form>
      </div>
    </div>

    <div id="modal-view" class="fixed inset-0 bg-slate-900/60 backdrop-blur-md hidden items-center justify-center z-[210] p-4">
      <div class="bg-white w-full max-w-lg rounded-[3rem] p-10 shadow-2xl relative border-t-8 border-blue-500">
        <div id="view-content" class="space-y-6">
            </div>
        <div class="mt-8 flex flex-col gap-3">
            <button id="close-view" class="w-full bg-slate-900 text-white py-5 rounded-full font-black uppercase text-[11px] italic shadow-lg">ENTENDIDO</button>
            <button id="btn-delete-task" class="w-full py-2 font-black text-[10px] text-red-400 uppercase tracking-widest hover:text-red-600 transition-colors">ELIMINAR TAREA</button>
        </div>
      </div>
    </div>

  </div>
</Layout>

<script>
  interface Tarea { id: any; titulo: string; descripcion: string; fecha: string; hora: string | null; prioridad: string; categoria: string; }
  
  let allTasks: Tarea[] = [];
  let currentView: 'dia' | 'semana' | 'mes' = 'dia';
  let viewDate = new Date(); 
  let selectedTaskId: any = null;

  const container = document.getElementById('view-container') as HTMLDivElement;
  const hTitle = document.getElementById('header-title') as HTMLElement;
  const modalCreate = document.getElementById('modal');
  const modalView = document.getElementById('modal-view');
  const viewContent = document.getElementById('view-content');
  const taskForm = document.getElementById('task-form') as HTMLFormElement;

  // --- NAVEGACIÓN IA ---
  document.getElementById('btn-ai-toggle')?.addEventListener('click', () => {
    document.getElementById('ai-window')?.classList.toggle('hidden');
  });

  // --- CARGA DE DATOS ---
  async function load() {
    try {
        const response = await fetch('/api/dashboard');
        const data = await response.json();
        if (data.success) {
            allTasks = data.tareas.map((t: any) => ({
                id: t.id_tarea,
                titulo: t.titulo,
                descripcion: t.descripcion,
                fecha: t.fecha_inicio ? new Date(t.fecha_inicio).toISOString().split('T')[0] : '',
                hora: t.hora_inicio,
                prioridad: t.prioridad,
                categoria: t.categoria || 'personal'
            }));
            render();
        }
    } catch (err) { console.error("Error al cargar:", err); }
  }

  // --- RENDERIZADO ---
  function render() {
    if (!container) return;
    const sT = (document.getElementById('f-trabajo') as HTMLInputElement).checked;
    const sP = (document.getElementById('f-personal') as HTMLInputElement).checked;
    const filtered = allTasks.filter(t => (t.categoria === 'trabajo' && sT) || (t.categoria === 'personal' && sP));

    document.querySelectorAll('.nav-btn').forEach(b => {
        const btn = b as HTMLElement;
        btn.className = `nav-btn px-8 py-2.5 rounded-[1.5rem] font-black text-[11px] transition-all ${btn.dataset.v === currentView ? 'bg-[#0f172a] text-white shadow-xl scale-105' : 'text-slate-400 hover:text-slate-600'}`;
    });

    if (currentView === 'dia') renderDia(filtered);
    else if (currentView === 'semana') renderSemana(filtered);
    else renderMes(filtered);
  }

  function renderDia(filtered: Tarea[]) {
    const dStr = viewDate.toISOString().split('T')[0];
    hTitle.innerText = viewDate.toLocaleDateString('es-ES', { weekday: 'long', day: 'numeric', month: 'long' }).toUpperCase();
    let html = `<div class="grid grid-cols-[100px_1fr] bg-white rounded-[2.5rem] border border-slate-100 overflow-hidden shadow-2xl">`;
    for (let i = 0; i < 24; i++) {
        const h = i.toString().padStart(2, '0');
        const tasksH = filtered.filter(t => t.fecha === dStr && t.hora?.startsWith(h + ':'));
        html += `<div class="min-h-[100px] border-b border-r flex items-center justify-center text-[11px] font-black text-slate-300 bg-slate-50/30">${h}:00</div>`;
        html += `<div class="border-b p-5 space-y-2">${tasksH.map(t => crearCard(t)).join('')}</div>`;
    }
    container.innerHTML = html + `</div>`;
  }

  function renderSemana(filtered: Tarea[]) {
    hTitle.innerText = "VISTA SEMANAL";
    let html = `<div class="grid grid-cols-7 gap-4">`;
    const start = new Date(viewDate);
    start.setDate(start.getDate() - (start.getDay() === 0 ? 6 : start.getDay() - 1));
    for (let i = 0; i < 7; i++) {
        const d = new Date(start); d.setDate(start.getDate() + i);
        const ds = d.toISOString().split('T')[0];
        html += `<div class="bg-white p-4 rounded-[2rem] border border-slate-100 min-h-[400px]">
            <div class="text-center mb-4">
                <div class="text-[9px] font-black text-slate-300 uppercase">${d.toLocaleDateString('es-ES',{weekday:'short'})}</div>
                <div class="text-xl font-black">${d.getDate()}</div>
            </div>
            <div class="space-y-2">${filtered.filter(t => t.fecha === ds).map(t => crearCard(t)).join('')}</div>
        </div>`;
    }
    container.innerHTML = html + `</div>`;
  }

  function renderMes(filtered: Tarea[]) {
    hTitle.innerText = viewDate.toLocaleDateString('es-ES', { month: 'long', year: 'numeric' }).toUpperCase();
    const year = viewDate.getFullYear();
    const month = viewDate.getMonth();
    const firstDay = new Date(year, month, 1).getDay();
    const daysInMonth = new Date(year, month + 1, 0).getDate();
    const offset = firstDay === 0 ? 6 : firstDay - 1;

    let html = `<div class="grid grid-cols-7 gap-2 bg-slate-100 p-2 rounded-[2rem] shadow-inner">`;
    ['Lun','Mar','Mie','Jue','Vie','Sab','Dom'].forEach(d => {
        html += `<div class="text-center p-2 text-[9px] font-black text-slate-400 uppercase tracking-widest">${d}</div>`;
    });
    for (let i = 0; i < offset; i++) html += `<div></div>`;
    for (let d = 1; d <= daysInMonth; d++) {
        const ds = `${year}-${String(month+1).padStart(2,'0')}-${String(d).padStart(2,'0')}`;
        const dayTasks = filtered.filter(t => t.fecha === ds);
        html += `<div class="bg-white min-h-[120px] rounded-[1.5rem] p-3 border border-slate-50 shadow-sm">
            <span class="text-[10px] font-black text-slate-800">${d}</span>
            <div class="mt-2 space-y-1">${dayTasks.map(t => `<div onclick="window.verDetalle('${t.id}')" class="h-2 rounded-full cursor-pointer ${t.prioridad === 'alta' ? 'bg-red-500' : 'bg-blue-500'}"></div>`).join('')}</div>
        </div>`;
    }
    container.innerHTML = html + `</div>`;
  }

  function crearCard(t: Tarea) {
    const colors: any = { 'alta': 'bg-red-600', 'media': 'bg-yellow-500', 'baja': 'bg-blue-500' };
    return `<div onclick="window.verDetalle('${t.id}')" class="${colors[t.prioridad]} p-4 rounded-[1.5rem] mb-2 cursor-pointer transition-all hover:brightness-110 text-white shadow-sm active:scale-95">
        <span class="text-[7px] font-black block opacity-80 uppercase">${t.hora || 'TODO EL DÍA'}</span>
        <h4 class="font-black text-[11px] uppercase truncate">${t.titulo}</h4>
    </div>`;
  }

  // --- LÓGICA DE DETALLES (RESTAURADA) ---
  (window as any).verDetalle = (id: string) => {
      selectedTaskId = id;
      const t = allTasks.find(task => String(task.id) === String(id));
      if (!t || !viewContent) return;
      
      viewContent.innerHTML = `
          <div class="flex justify-between items-start">
            <span class="bg-blue-100 text-blue-600 px-4 py-1 rounded-full text-[8px] font-black uppercase tracking-widest">${t.categoria}</span>
            <span class="text-slate-300 font-black text-[10px] uppercase">${t.fecha} | ${t.hora || 'S.H'}</span>
          </div>
          <h3 class="text-3xl font-black italic uppercase tracking-tighter text-slate-800 leading-none">${t.titulo}</h3>
          <p class="font-bold text-slate-500 uppercase text-[11px] leading-relaxed border-l-4 border-slate-100 pl-4">${t.descripcion || 'Sin descripción adicional.'}</p>
          <div class="pt-4 flex items-center gap-2">
            <div class="w-3 h-3 rounded-full ${t.prioridad === 'alta' ? 'bg-red-500' : (t.prioridad === 'media' ? 'bg-yellow-500' : 'bg-blue-500')}"></div>
            <span class="font-black text-[9px] uppercase text-slate-400">Prioridad ${t.prioridad}</span>
          </div>
      `;
      modalView?.classList.remove('hidden');
  };

  // --- BOTONES Y FORMULARIOS ---
  document.getElementById('btn-add')?.addEventListener('click', () => {
    modalCreate?.classList.remove('hidden');
  });

  document.getElementById('close-modal')?.addEventListener('click', () => modalCreate?.classList.add('hidden'));
  document.getElementById('close-view')?.addEventListener('click', () => modalView?.classList.add('hidden'));

  taskForm?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const payload = { 
        titulo: (document.getElementById('t-titulo') as HTMLInputElement).value, 
        descripcion: (document.getElementById('t-desc') as HTMLTextAreaElement).value,
        fecha: viewDate.toISOString().split('T')[0], 
        hora: (document.getElementById('t-usa-hora') as HTMLInputElement).checked ? (document.getElementById('t-hora-inicio') as HTMLInputElement).value : null, 
        prioridad: (document.getElementById('t-prioridad') as HTMLSelectElement).value,
        categoria: (document.getElementById('t-cat') as HTMLSelectElement).value 
    };

    const res = await fetch('/api/dashboard', { method: 'POST', body: JSON.stringify(payload) });
    if ((await res.json()).success) {
        modalCreate?.classList.add('hidden');
        taskForm.reset();
        await load();
    }
  });

  document.getElementById('f-trabajo')?.addEventListener('change', render);
  document.getElementById('f-personal')?.addEventListener('change', render);
  document.getElementById('t-usa-hora')?.addEventListener('change', (e) => {
    document.getElementById('wrapper-hora')?.classList.toggle('hidden', !(e.target as HTMLInputElement).checked);
  });

  document.querySelectorAll('.nav-btn').forEach(b => b.addEventListener('click', (e) => { 
    currentView = (e.target as HTMLElement).dataset.v as any; render(); 
  }));

  document.getElementById('prev-date')?.addEventListener('click', () => { 
    if(currentView === 'mes') viewDate.setMonth(viewDate.getMonth() - 1);
    else viewDate.setDate(viewDate.getDate() - (currentView === 'semana' ? 7 : 1));
    render(); 
  });
  document.getElementById('next-date')?.addEventListener('click', () => { 
    if(currentView === 'mes') viewDate.setMonth(viewDate.getMonth() + 1);
    else viewDate.setDate(viewDate.getDate() + (currentView === 'semana' ? 7 : 1));
    render(); 
  });

  load();
</script>