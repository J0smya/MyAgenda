  function agregarToastAccion(texto:string) {
    const div=document.createElement('div'); div.className='db-ai-accion-toast'; div.innerHTML=texto;
    aiMensajes.appendChild(div); aiMensajes.scrollTop=aiMensajes.scrollHeight;
  }
  async function enviarMensajeAI(textoForzado?:string) {
    const texto=textoForzado??aiInput.value.trim();
    if (!texto||aiEnviando) return;
    aiEnviando=true; if (!textoForzado) aiInput.value=''; btnAiSend.disabled=true;
    if (estadoChat.menu==='crear_tarea_titulo') datosAcumulados={titulo:texto};
    else if (estadoChat.menu==='crear_tarea_prioridad') {
      let p='media';
      if (texto.toLowerCase().includes('alta')) p='alta';
      else if (texto.toLowerCase().includes('baja')) p='baja';
      datosAcumulados={...datosAcumulados,prioridad:p};
    } else if (estadoChat.menu==='crear_nota_titulo') datosAcumulados={titulo:texto};
    agregarMensajeChat('user',texto);
    aiTyping.classList.remove('hidden'); aiMensajes.scrollTop=aiMensajes.scrollHeight;
    try {
      const r=await fetch('/api/chatbot',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({mensaje:texto,estado:estadoChat,datos:datosAcumulados})});
      const d=await r.json();
      aiTyping.classList.add('hidden');
      if (d.success) {
        estadoChat={menu:d.estado,datos:datosAcumulados};
        if (d.estado==='inicio') datosAcumulados={};
        agregarMensajeChat('bot',d.texto); renderOpciones(d.opciones??[]);
        if (d.accion==='tarea_creada') { datosAcumulados={}; agregarToastAccion('Tarea creada'); await load(); actualizarBadgeNotas(); }
        if (d.accion==='nota_creada')  { datosAcumulados={}; agregarToastAccion('Nota creada');  actualizarBadgeNotas(); }
      } else agregarMensajeChat('bot',d.texto||'Error al procesar.');
    } catch { aiTyping.classList.add('hidden'); agregarMensajeChat('bot','Error de conexión.'); }
    finally { aiEnviando=false; btnAiSend.disabled=false; aiInput.focus(); }
  }
  async function iniciarChat() {
    if (aiMensajes.children.length>1) return;
    try {
      const r=await fetch('/api/chatbot',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({mensaje:'inicio',estado:{menu:'inicio'},datos:{}})});
      const d=await r.json();
      if (d.success) { estadoChat={menu:d.estado}; agregarMensajeChat('bot',d.texto); renderOpciones(d.opciones??[]); }
    } catch {}
  }
