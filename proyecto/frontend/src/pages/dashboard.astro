  function confirmar(msg: string, peligro = false): Promise<boolean> {
    return new Promise(resolve => {
      const modal     = document.getElementById('modal-confirmar')!;
      const msgEl     = document.getElementById('confirm-msg')!;
      const iconEl    = document.getElementById('confirm-icon')!;
      const okBtn     = document.getElementById('confirm-ok') as HTMLButtonElement;
      const cancelBtn = document.getElementById('confirm-cancel') as HTMLButtonElement;

      msgEl.textContent  = msg;
      iconEl.innerHTML = peligro
        ? `<svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/><path d="M10 11v6"/><path d="M14 11v6"/><path d="M9 6V4h6v2"/></svg>`
        : `<svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="#f59e0b" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>`;
      okBtn.className    = peligro ? 'db-btn-delete' : 'db-btn-submit';
      okBtn.style.cssText = 'max-width:160px;';
      modal.classList.add('open');

      const cleanup = () => {
        modal.classList.remove('open');
        okBtn.removeEventListener('click', onOk);
        cancelBtn.removeEventListener('click', onNo);
        modal.removeEventListener('click', onBackdrop);
      };
      const onOk       = () => { cleanup(); resolve(true); };
      const onNo       = () => { cleanup(); resolve(false); };
      const onBackdrop = (e: Event) => { if (e.target === modal) { cleanup(); resolve(false); } };

      okBtn.addEventListener('click',    onOk,       { once: true });
      cancelBtn.addEventListener('click', onNo,       { once: true });
      modal.addEventListener('click',    onBackdrop, { once: true });
    });
  }

  function mostrarInfo(msg: string, tipo: 'error'|'ok'|'info' = 'info') {
    const modal  = document.getElementById('modal-alerta')!;
    const msgEl  = document.getElementById('alerta-msg')!;
    const iconEl = document.getElementById('alerta-icon')!;
    const okBtn  = document.getElementById('alerta-ok') as HTMLButtonElement;

    msgEl.textContent  = msg;
    iconEl.innerHTML = tipo === 'error'
      ? `<svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg>`
      : tipo === 'ok'
      ? `<svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="#16a34a" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>`
      : `<svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="#3b82f6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>`;
    modal.classList.add('open');

    const cleanup = () => {
      modal.classList.remove('open');
      okBtn.removeEventListener('click', onOk);
      modal.removeEventListener('click', onBackdrop);
    };
    const onOk       = () => cleanup();
    const onBackdrop = (e: Event) => { if (e.target === modal) cleanup(); };

    okBtn.addEventListener('click',  onOk,       { once: true });
    modal.addEventListener('click',  onBackdrop, { once: true });
  }

  /* ─────────────────── TOASTS ─────────────────── */
  function reproducirSonido(tipo:'ahora'|'antes') {
    if (localStorage.getItem('conf_sonido')==='false') return;
    try {
      const ctx  = new (window.AudioContext||(window as any).webkitAudioContext)();
      const osc  = ctx.createOscillator();
      const gain = ctx.createGain();
      osc.connect(gain); gain.connect(ctx.destination);
      osc.type='sine'; osc.frequency.value=tipo==='ahora'?880:660;
      gain.gain.setValueAtTime(.25,ctx.currentTime);
      gain.gain.exponentialRampToValueAtTime(.001,ctx.currentTime+.6);
      osc.start(ctx.currentTime); osc.stop(ctx.currentTime+.6);
    } catch {}
  }
  function mostrarToast(titulo:string, subtitulo:string, tipo:'ahora'|'antes') {
    reproducirSonido(tipo);
    const label = tipo==='ahora'?'Ahora':'Recordatorio';
    const toast = document.createElement('div');
    toast.className=`toast-notif toast-${tipo}`;
    toast.innerHTML=`
      <div class="toast-icon-wrap">${tipo==='ahora'
        ? `<svg width="16" height="16" viewBox="0 0 24 24" fill="#ef4444" stroke="#ef4444" stroke-width="0"><circle cx="12" cy="12" r="10"/></svg>`
        : `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/></svg>`
      }</div>
      <div class="toast-body">
        <div class="toast-label">${label}</div>
        <div class="toast-title">${titulo}</div>
        ${subtitulo?`<div class="toast-sub">${subtitulo}</div>`:''}
      </div>
      <button class="toast-close">✕</button>`;
    toast.querySelector('.toast-close')?.addEventListener('click',e=>{e.stopPropagation();cerrarToast(toast);});
    toast.addEventListener('click',()=>cerrarToast(toast));
    toastContainer.appendChild(toast);
    setTimeout(()=>cerrarToast(toast),6000);
  }
  function cerrarToast(t:HTMLElement) {
    t.classList.add('toast-out');
    t.addEventListener('animationend',()=>t.remove(),{once:true});
  }
 
  /* ─────────────────── RECORDATORIOS ─────────────────── */
  function programarRecordatorio(tarea:Tarea, minutosAntes:number) {
    if (!tarea.hora) return;
    const key=String(tarea.id);
    if (recordatoriosActivos.has(key)) recordatoriosActivos.get(key)!.forEach(clearTimeout);
    const timers:ReturnType<typeof setTimeout>[]=[];
    const [ay,am,ad]=tarea.fecha.split('-').map(Number);
    const [hh,mm]=tarea.hora.split(':').map(Number);
    const venc=new Date(ay,am-1,ad,hh,mm,0,0);
    const ahora=Date.now();
    const msAntes=venc.getTime()-minutosAntes*60*1000-ahora;
    if (msAntes>0) {
      const label=minutosAntes>=60?`En ${minutosAntes/60}h`:`En ${minutosAntes}min`;
      timers.push(setTimeout(()=>mostrarToast(tarea.titulo,`${label} · ${tarea.hora}`,'antes'),msAntes));
    }
    const msExacto=venc.getTime()-ahora;
    if (msExacto>0) timers.push(setTimeout(()=>mostrarToast(tarea.titulo,`Hora exacta · ${tarea.hora}`,'ahora'),msExacto));
    if (timers.length) recordatoriosActivos.set(key,timers);
  }
 
