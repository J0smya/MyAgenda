  /* ════ SUBMIT TAREA ════ */
  taskForm.addEventListener('submit', async (e) => {
    e.preventDefault();
    const submitBtn = taskForm.querySelector('button[type="submit"]') as HTMLButtonElement;
    submitBtn.disabled = true; submitBtn.textContent = 'Guardando...';
    const usaRecordatorio = (document.getElementById('t-usa-recordatorio') as HTMLInputElement).checked;
    const minutosAntes    = parseInt((document.getElementById('t-minutos-antes') as HTMLSelectElement).value);
    const fechaInput      = (document.getElementById('t-fecha') as HTMLInputElement).value;
    const horaInput       = (document.getElementById('t-hora-inicio') as HTMLInputElement).value || null;
    if (!fechaInput) { alert('Por favor selecciona una fecha.'); submitBtn.disabled=false; submitBtn.textContent='Guardar tarea'; return; }
    if (usaRecordatorio && !horaInput) { alert('Para activar el recordatorio debes asignar una hora.'); submitBtn.disabled=false; submitBtn.textContent='Guardar tarea'; return; }
    const payload: Record<string,any> = {
      titulo:      (document.getElementById('t-titulo')    as HTMLInputElement).value,
      descripcion: (document.getElementById('t-desc')      as HTMLTextAreaElement).value,
      fecha: fechaInput, hora: horaInput,
      prioridad:   (document.getElementById('t-prioridad') as HTMLSelectElement).value,
      categoria:   (document.getElementById('t-cat')       as HTMLSelectElement).value,
    };
    if (notaHtml) { payload.nota_contenido = notaHtml; payload.nota_titulo = notaTitulo; }
    try {
      const res  = await fetch('/api/dashboard', { method:'POST', headers:{'Content-Type':'application/json'}, body: JSON.stringify(payload) });
      const data = await res.json();
      if (data.success) {
        closeModalTarea(); taskForm.reset(); resetNota();
        await load(); actualizarBadgeNotas();
        if (usaRecordatorio && horaInput) {
          const nuevaTarea: Tarea = { id: data.tarea.id_tarea, titulo: payload.titulo, descripcion: payload.descripcion, fecha: payload.fecha, hora: horaInput, prioridad: payload.prioridad, categoria: payload.categoria };
          programarRecordatorio(nuevaTarea, minutosAntes);
          const labelMin = minutosAntes >= 60 ? `${minutosAntes/60}h` : `${minutosAntes}min`;
          mostrarToast('Recordatorio activado', `"${payload.titulo}" · ${labelMin} antes`, 'antes');
        }
      } else { throw new Error(data.message || data.error); }
    } catch (err: any) { alert(`Error: ${err.message}`); }
    finally { submitBtn.disabled=false; submitBtn.textContent='Guardar tarea'; }
