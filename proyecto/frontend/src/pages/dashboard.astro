  /* ─────────────────── SUBMIT TAREA ─────────────────── */
  taskForm.addEventListener('submit', async e=>{
    e.preventDefault();
    const submitBtn=document.getElementById('btn-submit-tarea') as HTMLButtonElement;
    submitBtn.disabled=true; submitBtn.textContent='Guardando...';
 
    const usaRecordatorio=(document.getElementById('t-usa-recordatorio') as HTMLInputElement).checked;
    const minutosAntes=parseInt((document.getElementById('t-minutos-antes') as HTMLSelectElement).value);
    const fechaInput=(document.getElementById('t-fecha') as HTMLInputElement).value;
    const horaInput=(document.getElementById('t-hora-inicio') as HTMLInputElement).value||null;
 
    if (!fechaInput){mostrarInfo('Selecciona una fecha.','info');submitBtn.disabled=false;submitBtn.textContent=modoEdicion?'Guardar cambios':'Guardar tarea';return;}
    if (usaRecordatorio&&!horaInput){mostrarInfo('Para activar el recordatorio debes asignar una hora.','info');submitBtn.disabled=false;submitBtn.textContent=modoEdicion?'Guardar cambios':'Guardar tarea';return;}
 
    const payload: Record<string,any> = {
      titulo:      (document.getElementById('t-titulo')    as HTMLInputElement).value,
      descripcion: (document.getElementById('t-desc')      as HTMLTextAreaElement).value,
      fecha:fechaInput, hora:horaInput,
      prioridad:   (document.getElementById('t-prioridad') as HTMLSelectElement).value,
      categoria:   (document.getElementById('t-cat')       as HTMLSelectElement).value,
    };
 
    try {
      // ── MODO EDICIÓN ──
      if (modoEdicion && tareaEditandoId) {
        const t = allTasks.find(x=>String(x.id)===String(tareaEditandoId));
        // Si es recurrente preguntar alcance
        if (t?.es_recurrente && t?.id_serie) {
          closeModalTarea();
          abrirSerieAccion('editar', t.id_serie, tareaEditandoId, payload);
        } else {
          const res=await fetch('/api/dashboard',{method:'PUT',headers:{'Content-Type':'application/json'},body:JSON.stringify({id_tarea:tareaEditandoId,...payload})});
          const data=await res.json();
          if(data.success){closeModalTarea();await load();}
          else throw new Error(data.message||data.error);
        }
        return;
      }
 
      // ── MODO CREAR ──
      if (notaHtml){payload.nota_contenido=notaHtml;payload.nota_titulo=notaTitulo;}
      // Con recurrencia
      if (recConfig.activo) {
        const recPayload={
          ...payload,
          frecuencia:recConfig.frecuencia,
          intervalo:recConfig.intervalo,
          dias_semana:recConfig.diasSemana.length>0?recConfig.diasSemana.join(','):null,
          fecha_fin:recConfig.finTipo==='fecha'?recConfig.fechaFin:null,
          total_ocurr:recConfig.finTipo==='cantidad'?recConfig.totalOcurr:null,
        };
        const res=await fetch('/api/dashboard',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(recPayload)});
        const data=await res.json();
        if(data.success){
          closeModalTarea(); resetRecurrencia();
          mostrarToast(`Serie creada (${data.tareas?.length||''} instancias)`,'','antes');
          activarPendientes(); await load(); actualizarBadgeNotas();
        } else throw new Error(data.message||data.error);
        return;
      }
      // Sin recurrencia
      const res=await fetch('/api/dashboard',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(payload)});
      const data=await res.json();
      if(data.success){
        closeModalTarea(); resetNota(); activarPendientes(); await load(); actualizarBadgeNotas();
        if(usaRecordatorio&&horaInput){
          const nt:Tarea={id:data.tarea.id_tarea,titulo:payload.titulo,descripcion:payload.descripcion,fecha:payload.fecha,hora:horaInput,prioridad:payload.prioridad,categoria:payload.categoria};
          programarRecordatorio(nt,minutosAntes);
          mostrarToast('Recordatorio activado',`"${payload.titulo}" · ${minutosAntes>=60?minutosAntes/60+'h':minutosAntes+'min'} antes`,'antes');
        }
      } else throw new Error(data.message||data.error);
    } catch(err:any){mostrarInfo(`Error: ${(err as any).message}`,'error');}
    finally{submitBtn.disabled=false;submitBtn.textContent=modoEdicion?'Guardar cambios':'Guardar tarea';}
  });
 
