---
// src/pages/dashboard.astro
import Layout from "../layouts/Layout.astro";
import NoteEditor from "../components/noteEditor.astro";
import Perfil from "../pages/perfil.astro";
import '../styles/tablero.css';
import '../styles/noteEditor.css';
---

<Layout title="MyAgenda Pro 2026">
<div class="db-layout">

  <aside class="db-sidebar">
    <div class="db-logo">
      <div class="db-logo-icon">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/>
          <line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/>
        </svg>
      </div>
      My Agenda
    </div>

    <!-- FILTROS -->
    <div class="db-sidebar-section">
      <div class="db-filters-header">
        <h3>Filtros</h3>
        <button id="btn-add-filtro" class="db-btn-add-filtro" title="Agregar filtro">+</button>
      </div>
      <div id="filtros-lista"></div>
    </div>

    <!-- BOTÓN NOTAS EN SIDEBAR -->
    <div style="margin-top: auto; display: flex; flex-direction: column; gap: 12px; width: 100%;">

      <div class="db-sidebar-notes-btn-wrap" style="padding: 0;">
        <button id="btn-ver-notas" class="db-sidebar-notes-btn">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
            <polyline points="14 2 14 8 20 8"/>
            <line x1="16" y1="13" x2="8" y2="13"/>
            <line x1="16" y1="17" x2="8" y2="17"/>
          </svg>
          <span>Notas</span>
          <span id="notas-count-badge" class="db-notes-count-badge" style="display:none"></span>
        </button>
      </div>

      <div class="db-sidebar-perfil-wrap" style="width: 100%;">
        <Perfil />
      </div>

    </div>

    <!-- BOTÓN ARCHIVOS EN SIDEBAR -->
    <div class="db-sidebar-notes-btn-wrap">
      <button id="btn-ver-archivos" class="db-sidebar-archivos-btn">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"/>
        </svg>
        <span>Archivos</span>
        <span id="archivos-count-badge" class="db-archivos-count-badge" style="display:none"></span>
      </button>
    </div>
  </aside>

  <main class="db-main">
    <header class="db-header">
      <div class="db-header-left">
        <button id="prev-date" class="db-nav-arrow" title="Anterior">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M15 19l-7-7 7-7"/></svg>
        </button>
        <button id="next-date" class="db-nav-arrow" title="Siguiente">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M9 5l7 7-7 7"/></svg>
        </button>
        <h2 id="header-title" class="db-date-title">Cargando...</h2>
      </div>
      <div class="db-header-right">
        <div class="db-view-tabs">
          <button data-v="dia"    class="db-view-btn nav-btn">Día</button>
          <button data-v="semana" class="db-view-btn nav-btn">Semana</button>
          <button data-v="mes"    class="db-view-btn nav-btn">Mes</button>
        </div>
        <button id="btn-add" class="db-btn-add">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
          Nueva tarea
        </button>
      </div>
    </header>
    <div class="db-view-container" id="view-container"></div>
  </main>
  
  <!-- BOTÓN AI -->
  <button id="btn-ai-toggle" class="db-fab db-fab--ai" title="Asistente IA">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M12 2a2 2 0 0 1 2 2c0 .74-.4 1.39-1 1.73V7h1a7 7 0 0 1 7 7h1a1 1 0 0 1 1 1v3a1 1 0 0 1-1 1h-1v1a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-1H2a1 1 0 0 1-1-1v-3a1 1 0 0 1 1-1h1a7 7 0 0 1 7-7h1V5.73c-.6-.34-1-.99-1-1.73a2 2 0 0 1 2-2z"/>
      <circle cx="9" cy="13" r="1" fill="currentColor" stroke="none"/>
      <circle cx="15" cy="13" r="1" fill="currentColor" stroke="none"/>
    </svg>
  </button>

  <!-- VENTANA CHAT AI -->
  <div id="ai-window" class="db-ai-window hidden">
    <div class="db-ai-header">
      <div class="db-ai-header-info">
        <div class="db-ai-avatar">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 2a2 2 0 0 1 2 2c0 .74-.4 1.39-1 1.73V7h1a7 7 0 0 1 7 7h1a1 1 0 0 1 1 1v3a1 1 0 0 1-1 1h-1v1a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-1H2a1 1 0 0 1-1-1v-3a1 1 0 0 1 1-1h1a7 7 0 0 1 7-7h1V5.73c-.6-.34-1-.99-1-1.73a2 2 0 0 1 2-2z"/>
          </svg>
        </div>
        <div>
          <div class="db-ai-name">Aria</div>
          <div class="db-ai-status">
            <span class="db-ai-dot"></span>
            Asistente IA
          </div>
        </div>
      </div>
      <button id="btn-ai-close" class="db-ai-close" title="Cerrar">✕</button>
    </div>
    <div class="db-ai-body" id="ai-mensajes">
      <div class="db-ai-msg db-ai-msg--bot">
        <div class="db-ai-msg-bubble">
          Hola, soy <strong>Aria</strong>, tu asistente inteligente. Puedo consultar tus tareas, notas y archivos, y también <strong>crear tareas o notas</strong> por ti. ¿En qué te ayudo?
        </div>
      </div>
    </div>
    <div id="ai-typing" class="db-ai-typing hidden">
      <span></span><span></span><span></span>
    </div>
    <div class="db-ai-footer">
      <input type="text" id="ai-input" class="db-ai-input" placeholder="Escribe aquí… (Enter para enviar)" maxlength="500">
      <button id="btn-ai-send" class="db-ai-send-btn" title="Enviar">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <line x1="22" y1="2" x2="11" y2="13"/>
          <polygon points="22 2 15 22 11 13 2 9 22 2"/>
        </svg>
      </button>
    </div>
  </div>

  <!-- MODAL CREAR TAREA -->
  <div id="modal" class="db-modal-backdrop">
    <div class="db-modal-box">
      <form id="task-form">
        <h3 class="db-modal-title">Nueva tarea</h3>
        <div class="space-y-4">
          <input type="text" id="t-titulo" required placeholder="Título de la tarea" class="db-input">
          <textarea id="t-desc" placeholder="Descripción o notas" rows="2" class="db-input" style="resize:none"></textarea>
          <div class="grid-2">
            <select id="t-prioridad" class="db-select">
              <option value="alta">Alta prioridad</option>
              <option value="media" selected>Media prioridad</option>
              <option value="baja">Baja prioridad</option>
            </select>
            <select id="t-cat" class="db-select">
              <option value="trabajo">Trabajo</option>
              <option value="personal">Personal</option>
            </select>
          </div>

          <div class="grid-2" style="align-items:end;">
            <div style="display:flex;flex-direction:column;gap:6px;">
              <label style="font-size:11px;font-weight:700;color:#6b7280;text-transform:uppercase;letter-spacing:0.04em;">Fecha</label>
              <input type="date" id="t-fecha" class="db-input">
            </div>
            <div style="display:flex;flex-direction:column;gap:6px;">
              <label style="font-size:11px;font-weight:700;color:#6b7280;text-transform:uppercase;letter-spacing:0.04em;">Hora</label>
              <input type="time" id="t-hora-inicio" class="db-input" style="text-align:center;">
            </div>
          </div>

          <div style="display:flex;flex-direction:column;gap:8px;padding:12px;background:#f8fafc;border-radius:10px;border:1px solid #e2e8f0;">
            <label style="display:flex;align-items:center;gap:8px;font-size:13px;font-weight:600;color:#374151;cursor:pointer;">
              <input type="checkbox" id="t-usa-recordatorio" style="width:16px;height:16px;">
              Activar recordatorio
            </label>
            <div id="wrapper-recordatorio" class="hidden" style="flex-direction:column;gap:8px;">
              <select id="t-minutos-antes" class="db-select" style="font-size:13px;">
                <option value="5">5 minutos antes</option>
                <option value="15">15 minutos antes</option>
                <option value="30">30 minutos antes</option>
                <option value="60" selected>1 hora antes</option>
                <option value="120">2 horas antes</option>
                <option value="1440">1 día antes</option>
              </select>
              <p style="font-size:11px;color:#6b7280;margin:0;">Aparecerá una notificación en pantalla.</p>
            </div>
          </div>

          <div class="db-form-sep">
            <div class="db-form-sep-line"></div>
            <span class="db-form-sep-text">Extras</span>
            <div class="db-form-sep-line"></div>
          </div>

          <div id="nota-badge" class="db-nota-badge">
            <span class="db-nota-badge-check">✓</span>
            <div class="db-nota-badge-info">
              <p class="db-nota-badge-label">Nota adjunta</p>
              <p id="nota-badge-title" class="db-nota-badge-title"></p>
            </div>
            <button type="button" id="btn-editar-nota" class="db-nota-badge-edit">Editar</button>
          </div>

          <button type="button" id="btn-agregar-nota" class="db-btn-nota">
            <div class="db-btn-nota-icon">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/>
                <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/>
              </svg>
            </div>
            <div class="db-btn-nota-text">
              <p class="db-btn-nota-label">Agregar nota</p>
              <p class="db-btn-nota-sub">Negrita · Cursiva · Listas · Colores</p>
            </div>
            <svg class="db-btn-nota-arrow" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M9 5l7 7-7 7"/></svg>
          </button>

          <div class="space-y-3" style="margin-top:8px;">
            <button type="submit" class="db-btn-submit">Guardar tarea</button>
            <button type="button" id="close-modal" class="db-btn-cancel">Cancelar</button>
          </div>
        </div>
      </form>
    </div>
  </div>

  <!-- MODAL VER TAREA -->
  <div id="modal-view" class="db-modal-backdrop" style="z-index:210;">
    <div class="db-view-modal-box">
      <div id="view-content" class="space-y-4"></div>
      <div class="space-y-3" style="margin-top:24px;">
        <button id="close-view" class="db-btn-understood">Entendido</button>
        <button id="btn-delete-task" class="db-btn-delete">Eliminar tarea</button>
      </div>
    </div>
  </div>

  <!-- MODAL ETIQUETAS -->
  <div id="modal-etiquetas" class="db-modal-backdrop" style="z-index:220;">
    <div class="db-etiquetas-box">
      <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:20px;">
        <h3 class="db-etiquetas-title">Etiquetas</h3>
        <button id="close-etiquetas" class="db-btn-tag-del" style="padding:6px 14px;">✕</button>
      </div>
      <div id="etiquetas-list" class="space-y-3"></div>
      <div id="etiquetas-form" class="hidden space-y-3" style="margin-top:20px;padding-top:20px;border-top:1px solid #f3f4f6;">
        <p style="font-size:12px;font-weight:700;color:#6b7280;text-transform:uppercase;letter-spacing:0.06em;">Editar etiqueta</p>
        <input type="hidden" id="e-id"/>
        <input type="text" id="e-nombre" placeholder="Nombre" maxlength="100" class="db-input"/>
        <div style="display:flex;align-items:center;gap:12px;">
          <input type="color" id="e-color" value="#0ea5e9" style="width:48px;height:48px;border-radius:50%;border:none;cursor:pointer;"/>
          <span style="font-size:13px;font-weight:600;color:#6b7280;">Color</span>
        </div>
        <div style="display:flex;gap:8px;">
          <button id="e-guardar" class="db-btn-submit" style="padding:10px;">Guardar</button>
          <button id="e-cancelar" class="db-btn-cancel" style="width:auto;padding:10px 16px;background:#f3f4f6;color:#6b7280;border-radius:10px;">Cancelar</button>
        </div>
      </div>
      <div id="etiquetas-toast" class="hidden" style="text-align:center;margin-top:12px;font-size:11px;font-weight:700;"></div>
    </div>
  </div>

  <!-- MODAL FILTRO -->
  <div id="modal-filtro" class="db-modal-backdrop" style="z-index:230;">
    <div class="db-filtro-modal-box">
      <h3 class="db-modal-title" id="filtro-modal-titulo">Nuevo filtro</h3>
      <div class="space-y-4">
        <div style="display:flex;flex-direction:column;gap:6px;">
          <label class="db-filtro-label-text">Nombre</label>
          <input type="text" id="fi-nombre" class="db-input" placeholder="Ej: Urgente, Casa, Gym…" maxlength="30">
        </div>
        <div style="display:flex;flex-direction:column;gap:10px;">
          <label class="db-filtro-label-text">Color</label>
          <div id="fi-colores" class="db-filtro-colores"></div>
          <div style="display:flex;align-items:center;gap:10px;margin-top:4px;">
            <input type="color" id="fi-color-custom" value="#0ea5e9" style="width:36px;height:36px;border-radius:50%;border:2px solid #e5e7eb;cursor:pointer;padding:2px;">
            <span style="font-size:12px;color:#6b7280;font-weight:600;">Color personalizado</span>
          </div>
        </div>
        <div style="display:flex;gap:8px;margin-top:8px;">
          <button id="fi-guardar" class="db-btn-submit">Guardar</button>
          <button id="fi-cancelar" class="db-btn-cancel" style="width:auto;padding:10px 20px;background:#f3f4f6;color:#6b7280;border-radius:12px;text-transform:none;font-size:13px;">Cancelar</button>
        </div>
      </div>
    </div>
  </div>

  <!-- MODAL ARCHIVOS -->
  <div id="modal-archivos-lista" class="db-modal-backdrop" style="z-index:245;">
    <div class="archivos-lista-box">
      <div class="archivos-lista-header">
        <div class="archivos-lista-header-left">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"/>
          </svg>
          <h2>Archivos</h2>
        </div>
        <button id="archivos-lista-close" class="archivos-lista-close" title="Cerrar">✕</button>
      </div>
      <div class="archivos-upload-zone" id="archivos-upload-zone">
        <div class="archivos-upload-inner">
          <div class="archivos-upload-icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="16 16 12 12 8 16"/>
              <line x1="12" y1="12" x2="12" y2="21"/>
              <path d="M20.39 18.39A5 5 0 0 0 18 9h-1.26A8 8 0 1 0 3 16.3"/>
            </svg>
          </div>
          <p class="archivos-upload-title">Subir archivo</p>
          <p class="archivos-upload-sub">Selecciona o arrastra un archivo aquí</p>
          <label class="archivos-upload-btn">
            <input type="file" id="archivo-input" style="display:none" multiple>
            Seleccionar archivo
          </label>
        </div>
        <div class="archivos-tarea-sel-wrap">
          <label class="archivos-tarea-sel-label">Asociar a tarea (opcional)</label>
          <select id="archivo-tarea-select" class="db-select" style="font-size:12px;">
            <option value="">— Sin tarea —</option>
          </select>
        </div>
        <div id="archivos-upload-progress" class="archivos-upload-progress hidden">
          <div class="archivos-progress-bar"><div id="archivos-progress-fill" class="archivos-progress-fill"></div></div>
          <span id="archivos-progress-text" class="archivos-progress-text">Subiendo…</span>
        </div>
      </div>
      <div id="archivos-lista-body" class="archivos-lista-body">
        <p class="archivos-loading">Cargando archivos…</p>
      </div>
    </div>
  </div>

  <!-- Contenedor toasts -->
  <div id="toast-container"></div>

  <NoteEditor />
</div>
</Layout>

<script>
  interface Tarea {
    id: any; titulo: string; descripcion: string;
    fecha: string; hora: string | null; prioridad: string; categoria: string;
  }
  interface Filtro {
    id: string; nombre: string; color: string; activo: boolean;
  }

  let allTasks:    Tarea[]              = [];
  let currentView: 'dia'|'semana'|'mes' = 'dia';
  let viewDate     = new Date();
  let selectedTaskId: any               = null;
  let notaHtml     = '';
  let notaTitulo   = '';
  let editorMode: 'task' | 'sidebar-edit' | 'sidebar-new' = 'task';
  let notaSidebarEditandoId: string | null = null;
  const recordatoriosActivos = new Map<string, ReturnType<typeof setTimeout>[]>();

  const FILTROS_KEY = 'myagenda_filtros';
  let filtros: Filtro[] = [];
  let filtroEditandoId: string | null = null;
  let colorSeleccionado = '#0ea5e9';

  const COLORES_PRESET = ['#0ea5e9','#6366f1','#f59e0b','#ef4444','#10b981','#8b5cf6','#f97316','#ec4899','#14b8a6','#64748b'];

  let estadoChat: { menu: string; datos?: Record<string, any> } = { menu: 'inicio' };
  let datosAcumulados: Record<string, any> = {};
  let aiEnviando = false;

  function cargarFiltros(): Filtro[] {
    try {
      const raw = localStorage.getItem(FILTROS_KEY);
      if (raw) {
        const parsed = JSON.parse(raw);
        // Compatibilidad: eliminar campo emoji si existe
        return parsed.map((f: any) => ({ id: f.id, nombre: f.nombre, color: f.color, activo: f.activo }));
      }
    } catch {}
    return [
      { id: 'trabajo',  nombre: 'Trabajo',  color: '#0ea5e9', activo: true },
      { id: 'personal', nombre: 'Personal', color: '#10b981', activo: true },
    ];
  }
  function guardarFiltros() { localStorage.setItem(FILTROS_KEY, JSON.stringify(filtros)); }

  function renderFiltros() {
    const lista = document.getElementById('filtros-lista')!;
    if (!filtros.length) {
      lista.innerHTML = '<p style="font-size:12px;color:#d1d5db;text-align:center;padding:8px 0;">Sin filtros</p>';
      return;
    }
    lista.innerHTML = filtros.map(f => `
      <div class="db-filtro-item" data-id="${f.id}">
        <input type="checkbox" class="db-filtro-check" ${f.activo ? 'checked' : ''}
          style="border-color:${f.color};${f.activo ? `background:${f.color};` : ''}"
          data-id="${f.id}">
        <span class="db-filtro-color-indicator" style="width:8px;height:8px;border-radius:50%;background:${f.color};display:inline-block;flex-shrink:0;"></span>
        <span class="db-filtro-nombre">${f.nombre}</span>
        <div class="db-filtro-acciones">
          <button class="db-filtro-btn edit" data-id="${f.id}" title="Editar">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
          </button>
          <button class="db-filtro-btn del" data-id="${f.id}" title="Eliminar">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/><path d="M10 11v6"/><path d="M14 11v6"/><path d="M9 6V4h6v2"/></svg>
          </button>
        </div>
      </div>
    `).join('');
    lista.querySelectorAll<HTMLInputElement>('.db-filtro-check').forEach(chk => {
      chk.addEventListener('change', () => {
        const f = filtros.find(x => x.id === chk.dataset.id);
        if (!f) return;
        f.activo = chk.checked;
        chk.style.background = f.activo ? f.color : '';
        guardarFiltros(); render();
      });
    });
    lista.querySelectorAll<HTMLButtonElement>('.db-filtro-btn.edit').forEach(btn => {
      btn.addEventListener('click', (e) => { e.stopPropagation(); abrirModalFiltro(btn.dataset.id); });
    });
    lista.querySelectorAll<HTMLButtonElement>('.db-filtro-btn.del').forEach(btn => {
      btn.addEventListener('click', (e) => {
        e.stopPropagation();
        if (confirm('¿Eliminar este filtro?')) {
          filtros = filtros.filter(x => x.id !== btn.dataset.id);
          guardarFiltros(); renderFiltros(); render();
        }
      });
    });
