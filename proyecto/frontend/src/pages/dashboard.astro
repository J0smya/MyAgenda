  /* ─────────────────── MODAL SERIE ACCIÓN (GT-87/GT-88) ─────────────────── */
  function abrirSerieAccion(accion:'editar'|'eliminar', idSerie:number, idTarea:any, payload:Record<string,any>|null) {
    const titulo  = document.getElementById('serie-accion-titulo')!;
    const desc    = document.getElementById('serie-accion-desc')!;
    const btnsDiv = document.getElementById('serie-accion-btns')!;
 
    titulo.textContent = accion==='eliminar' ? '¿Qué deseas eliminar?' : '¿Cómo quieres editar?';
    desc.textContent   = accion==='eliminar'
      ? 'Esta tarea es parte de una serie recurrente.'
      : 'Esta tarea pertenece a una serie. Elige el alcance de los cambios.';
 
    btnsDiv.innerHTML=`
      <button class="db-serie-btn" id="sb-este">
        <strong>Solo este evento</strong><br>
        <span style="font-size:11px;color:#9ca3af;">${accion==='eliminar'?'Elimina solo esta fecha':'Edita únicamente esta instancia'}</span>
      </button>
      <button class="db-serie-btn peligro" id="sb-serie">
        <strong>Toda la serie</strong><br>
        <span style="font-size:11px;">${accion==='eliminar'?'Elimina todas las repeticiones':'Aplica cambios a todos los eventos futuros'}</span>
      </button>`;
 
    document.getElementById('sb-este')?.addEventListener('click', async ()=>{
      modalSerieAcc.classList.remove('open');
      if (accion==='eliminar') {
        await fetch(`/api/dashboard?id=${idTarea}&modo=este`,{method:'DELETE'});
        await load(); actualizarBadgeNotas();
      } else if (payload) {
        const res=await fetch('/api/dashboard',{method:'PUT',headers:{'Content-Type':'application/json'},body:JSON.stringify({id_tarea:idTarea,modo:'este',...payload})});
        const data=await res.json();
        if(data.success) await load(); else mostrarInfo(data.message||'Error al editar','error');
      }
    });
 
    document.getElementById('sb-serie')?.addEventListener('click', async ()=>{
      const conf = accion==='eliminar' ? await confirmar('¿Eliminar TODA la serie? Esta acción no se puede deshacer.', true) : true;
      if (!conf) return;
      modalSerieAcc.classList.remove('open');
      if (accion==='eliminar') {
        await fetch(`/api/dashboard?id=${idTarea}&modo=serie`,{method:'DELETE'});
        await load(); actualizarBadgeNotas();
      } else if (payload) {
        const res=await fetch('/api/dashboard',{method:'PUT',headers:{'Content-Type':'application/json'},body:JSON.stringify({id_tarea:idTarea,modo:'serie',...payload})});
        const data=await res.json();
        if(data.success) await load(); else mostrarInfo(data.message||'Error al editar','error');
      }
    });
 
    modalSerieAcc.classList.add('open');
  }
 
  document.getElementById('close-serie-accion')?.addEventListener('click',()=>{
    modalSerieAcc.classList.remove('open');
    modalView.classList.add('open');
  });
 
  /* ─────────────────── MODAL NOTAS ─────────────────── */
  async function cargarTodasLasNotas() {
    notasListaBody.innerHTML='<p class="notas-loading">Cargando notas…</p>';
    try {
      const r=await fetch('/api/noteEditor'); const d=await r.json();
      const badge=document.getElementById('notas-count-badge')!;
      const count=d.success?d.notas.length:0;
      badge.textContent=String(count); badge.style.display=count>0?'inline-block':'none';
      if(!d.success||!d.notas.length){notasListaBody.innerHTML='<p class="notas-empty">No hay notas guardadas aún.</p>';return;}
      notasListaBody.innerHTML=d.notas.map((n:any)=>{
        const fecha=n.fecha_creacion?new Date(n.fecha_creacion).toLocaleDateString('es-ES',{day:'2-digit',month:'short',year:'numeric'}):'';
        const sc=encodeURIComponent(n.contenido??''); const st=encodeURIComponent(n.nota_titulo??'');
        return `<div class="nota-card">
          <div class="nota-card-header">
            <span class="nota-card-title">${n.nota_titulo??'Sin título'}</span>
            <span class="nota-card-date">${fecha}</span>
          </div>
          ${n.tarea_titulo?`<span class="nota-card-tarea">${n.tarea_titulo}</span>`:''}
          <div class="nota-card-preview">${n.contenido??''}</div>
          <div class="nota-card-actions">
            <button class="nota-card-btn nota-card-btn--edit" data-id="${n.id_nota}" data-content="${sc}" data-title="${st}">Editar</button>
            <button class="nota-card-btn nota-card-btn--del" data-id="${n.id_nota}">Eliminar</button>
          </div>
        </div>`;
      }).join('');
      notasListaBody.querySelectorAll<HTMLButtonElement>('.nota-card-btn--edit').forEach(btn=>{
        btn.addEventListener('click',()=>{
          const id=btn.dataset.id!; const contenido=decodeURIComponent(btn.dataset.content!); const titulo=decodeURIComponent(btn.dataset.title!);
          modalNotasLista.classList.remove('open'); editorMode='sidebar-edit'; notaSidebarEditandoId=id;
          neEditor.innerHTML=contenido; neTitleInput.value=titulo; neWords.textContent='0 palabras';
          modalNota.classList.add('ne-open'); setTimeout(()=>neEditor.focus(),150);
        });
      });
      notasListaBody.querySelectorAll<HTMLButtonElement>('.nota-card-btn--del').forEach(btn=>{
        btn.addEventListener('click',async()=>{
          if(!(await confirmar('¿Eliminar esta nota?', true)))return;
          const r=await fetch('/api/noteEditor',{method:'DELETE',headers:{'Content-Type':'application/json'},body:JSON.stringify({id_nota:btn.dataset.id})});
          if((await r.json()).success) await cargarTodasLasNotas();
        });
      });
    } catch{notasListaBody.innerHTML='<p class="notas-empty">Error al cargar notas.</p>';}
  }
  document.getElementById('btn-nueva-nota-modal')?.addEventListener('click',()=>{
    modalNotasLista.classList.remove('open'); editorMode='sidebar-new'; notaSidebarEditandoId=null;
    neEditor.innerHTML=''; neTitleInput.value=''; neWords.textContent='0 palabras';
    modalNota.classList.add('ne-open'); setTimeout(()=>neEditor.focus(),150);
  });
  document.getElementById('btn-pendientes')?.addEventListener('click',()=>abrirPanelTareas('pendiente'));
  document.getElementById('btn-completadas')?.addEventListener('click',()=>abrirPanelTareas('completada'));
  document.getElementById('pendientes-panel-close')?.addEventListener('click',()=>cerrarPanelTareas('pendiente'));
  document.getElementById('completadas-panel-close')?.addEventListener('click',()=>cerrarPanelTareas('completada'));
  document.getElementById('modal-pendientes-lista')?.addEventListener('click',e=>{ if(e.target===e.currentTarget) cerrarPanelTareas('pendiente'); });
  document.getElementById('modal-completadas-lista')?.addEventListener('click',e=>{ if(e.target===e.currentTarget) cerrarPanelTareas('completada'); });
  document.getElementById('btn-ver-notas')?.addEventListener('click',async()=>{modalNotasLista.classList.add('open');await cargarTodasLasNotas();});
  document.getElementById('notas-lista-close')?.addEventListener('click',()=>modalNotasLista.classList.remove('open'));
  modalNotasLista?.addEventListener('click',e=>{if(e.target===modalNotasLista) modalNotasLista.classList.remove('open');});
 
  /* ─────────────────── MODAL ARCHIVOS ─────────────────── */
  function iconoArchivo(tipo:string):string {
    if(tipo.startsWith('image/')) return `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>`;
    if(tipo.startsWith('video/')) return `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="23 7 16 12 23 17 23 7"/><rect x="1" y="5" width="15" height="14" rx="2"/></svg>`;
    if(tipo.startsWith('audio/')) return `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18V5l12-2v13"/><circle cx="6" cy="18" r="3"/><circle cx="18" cy="16" r="3"/></svg>`;
    if(tipo.includes('pdf'))      return `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>`;
    if(tipo.includes('zip')||tipo.includes('rar')) return `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/></svg>`;
    return `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>`;
  }
  function formatSize(b:number):string {
    if(b<1024) return `${b} B`;
    if(b<1024*1024) return `${(b/1024).toFixed(1)} KB`;
    return `${(b/1024/1024).toFixed(1)} MB`;
  }
  function poblarSelectorTareas() {
    const sel=document.getElementById('archivo-tarea-select') as HTMLSelectElement;
    sel.innerHTML='<option value="">— Sin tarea —</option>'+allTasks.map(t=>`<option value="${t.id}">${t.titulo}</option>`).join('');
  }
  async function cargarTodosLosArchivos() {
    archivosBody.innerHTML='<p class="archivos-loading">Cargando archivos…</p>';
    try {
      const r=await fetch('/api/archivo?todos=1'); const d=await r.json();
      const badge=document.getElementById('archivos-count-badge')!;
      const count=d.success?(d.archivos?.length??0):0;
      badge.textContent=String(count); badge.style.display=count>0?'inline-block':'none';
      if(!d.success||!d.archivos?.length){archivosBody.innerHTML='<p class="archivos-empty">No hay archivos subidos aún.</p>';return;}
      archivosBody.innerHTML=d.archivos.map((a:any)=>{
        const fecha=a.fecha_subida?new Date(a.fecha_subida).toLocaleDateString('es-ES',{day:'2-digit',month:'short',year:'numeric'}):'';
        const tarea=allTasks.find(t=>String(t.id)===String(a.id_tarea));
        return `<div class="archivo-card">
          <div class="archivo-icon">${iconoArchivo(a.tipo??'')}</div>
          <div class="archivo-info">
            <div class="archivo-nombre">${a.nombre}</div>
            <div class="archivo-meta">
              <span class="archivo-size">${formatSize(a.tamano??0)}</span>
              ${tarea?`<span class="archivo-tarea-tag">${tarea.titulo}</span>`:''}
              <span class="archivo-fecha">${fecha}</span>
            </div>
          </div>
          <div class="archivo-actions">
            <a href="${a.ruta_archivo}" target="_blank" download="${a.nombre}" class="archivo-btn archivo-btn--dl">Descargar</a>
            <button class="archivo-btn archivo-btn--del" data-id="${a.id_archivo}">Eliminar</button>
          </div>
        </div>`;
      }).join('');
      archivosBody.querySelectorAll<HTMLButtonElement>('.archivo-btn--del').forEach(btn=>{
        btn.addEventListener('click',async()=>{
          if(!(await confirmar('¿Eliminar este archivo?', true)))return;
          try{
            const r=await fetch('/api/archivo',{method:'DELETE',headers:{'Content-Type':'application/json'},body:JSON.stringify({id_archivo:btn.dataset.id})});
            if((await r.json()).success) await cargarTodosLosArchivos();
          }catch{mostrarInfo('Error al eliminar archivo','error');}
        });
      });
    } catch{archivosBody.innerHTML='<p class="archivos-empty">Error al cargar archivos.</p>';}
  }
 
  const archivoInput    = document.getElementById('archivo-input')           as HTMLInputElement;
  const uploadZoneInner = document.querySelector('.archivos-upload-inner')    as HTMLElement;
  const progressWrap    = document.getElementById('archivos-upload-progress') as HTMLElement;
  const progressFill    = document.getElementById('archivos-progress-fill')   as HTMLElement;
  const progressText    = document.getElementById('archivos-progress-text')   as HTMLElement;
 
  async function subirArchivo(file:File) {
    const idTarea=(document.getElementById('archivo-tarea-select') as HTMLSelectElement).value;
    if(!idTarea){mostrarInfo('Selecciona una tarea para asociar el archivo.','info');return;}
    progressWrap.classList.remove('hidden'); progressFill.style.width='10%'; progressText.textContent='Subiendo…';
    const fd=new FormData(); fd.append('archivo',file); fd.append('id_tarea',idTarea);
    try{
      progressFill.style.width='40%';
      const r=await fetch('/api/archivo',{method:'POST',body:fd}); progressFill.style.width='80%';
      const d=await r.json();
      if(d.success){
        progressFill.style.width='100%'; progressText.textContent='Subido correctamente';
        setTimeout(()=>{progressWrap.classList.add('hidden');progressFill.style.width='0%';},1200);
        await cargarTodosLosArchivos(); actualizarBadgeArchivos();
      } else{
        progressText.textContent='Error: '+(d.error||'desconocido');
        progressFill.style.background='#ef4444';
        setTimeout(()=>{progressWrap.classList.add('hidden');progressFill.style.width='0%';progressFill.style.background='#8b5cf6';},2500);
      }
    }catch{progressText.textContent='Error de conexión';setTimeout(()=>{progressWrap.classList.add('hidden');progressFill.style.width='0%';},2000);}
  }
 
  archivoInput?.addEventListener('change',async()=>{
    for(const f of Array.from(archivoInput.files??[])) await subirArchivo(f);
    archivoInput.value='';
  });
  uploadZoneInner?.addEventListener('dragover',e=>{e.preventDefault();uploadZoneInner.classList.add('drag-over');});
  uploadZoneInner?.addEventListener('dragleave',()=>uploadZoneInner.classList.remove('drag-over'));
  uploadZoneInner?.addEventListener('drop',async e=>{
    e.preventDefault(); uploadZoneInner.classList.remove('drag-over');
    for(const f of Array.from(e.dataTransfer?.files??[])) await subirArchivo(f);
  });
  document.getElementById('btn-ver-archivos')?.addEventListener('click',async()=>{poblarSelectorTareas();modalArchivos.classList.add('open');await cargarTodosLosArchivos();});
  document.getElementById('archivos-lista-close')?.addEventListener('click',()=>modalArchivos.classList.remove('open'));
  modalArchivos?.addEventListener('click',e=>{if(e.target===modalArchivos) modalArchivos.classList.remove('open');});
 
  /* ─────────────────── LOAD & RENDER ─────────────────── */
  async function load() {
    try{
      const r=await fetch('/api/dashboard'); const d=await r.json();
      if(d.success){
        const mapped=d.tareas.map((t:any)=>({
          id:t.id_tarea, titulo:t.titulo, descripcion:t.descripcion,
          fecha:t.fecha_inicio?new Date(t.fecha_inicio).toISOString().split('T')[0]:'',
          hora:t.hora_inicio, prioridad:t.prioridad, categoria:t.categoria||'personal',
          estado:t.estado||'pendiente',
          es_recurrente:t.es_recurrente||false, id_serie:t.id_serie||null,
        }));
        const seen=new Set<string>();
        allTasks=mapped.filter((t:Tarea)=>{ const k=String(t.id); if(seen.has(k)) return false; seen.add(k); return true; });
        render();
      }
    }catch(e){console.error(e);}
  }
 
  function activarPendientes() {
    abrirPanelTareas('pendiente');
  }

  /* ─────────────────── PANELES PENDIENTES / COMPLETADAS ─────────────────── */
  function abrirPanelTareas(estado: 'pendiente'|'completada') {
    const modalId = estado==='pendiente' ? 'modal-pendientes-lista' : 'modal-completadas-lista';
    document.getElementById(modalId)?.classList.add('open');
    renderPanelTareas(estado);
  }

  function cerrarPanelTareas(estado: 'pendiente'|'completada') {
    const modalId = estado==='pendiente' ? 'modal-pendientes-lista' : 'modal-completadas-lista';
    document.getElementById(modalId)?.classList.remove('open');
  }

  function renderPanelTareas(estado: 'pendiente'|'completada') {
    const bodyId   = estado==='pendiente' ? 'pendientes-panel-body'  : 'completadas-panel-body';
    const countId  = estado==='pendiente' ? 'pendientes-panel-count' : 'completadas-panel-count';
    const body  = document.getElementById(bodyId);
    const count = document.getElementById(countId);
    if (!body) return;

    const lista = allTasks.filter(t=>t.estado===estado)
      .sort((a,b)=>{ if(!a.fecha) return 1; if(!b.fecha) return -1; return a.fecha.localeCompare(b.fecha); });

    if (count) count.textContent = `${lista.length} tarea${lista.length!==1?'s':''}`;

    if (!lista.length) {
      const svgIcon = estado==='pendiente'
        ? `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#9ca3af" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>`
        : `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#9ca3af" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>`;
      const txt = estado==='pendiente' ? 'No hay tareas pendientes' : 'No hay tareas completadas';
      body.innerHTML=`<div class="db-tasks-panel-empty"><div class="db-tasks-panel-empty-icon">${svgIcon}</div><span>${txt}</span></div>`;
      return;
    }

    const prioConfig: Record<string,{bg:string;color:string;border:string}> = {
      alta:  { bg:'#fef2f2', color:'#dc2626', border:'#fecaca' },
      media: { bg:'#fffbeb', color:'#d97706', border:'#fde68a' },
      baja:  { bg:'#f0fdf4', color:'#16a34a', border:'#bbf7d0' },
    };

    body.innerHTML = lista.map((t,i)=>{
      const filtro = filtros.find(f=>f.id===t.categoria);
      const accentColor = filtro ? filtro.color : (t.prioridad==='alta'?'#ef4444':t.prioridad==='media'?'#f59e0b':'#22c55e');
      const catNombre = filtro ? filtro.nombre : t.categoria;
      const pc = prioConfig[t.prioridad] ?? prioConfig.media;
      const fecha = t.fecha ? new Date(t.fecha+'T00:00:00').toLocaleDateString('es-ES',{day:'2-digit',month:'short',year:'numeric'}) : 'Sin fecha';
      const recBadge = t.es_recurrente
        ? `<span class="db-tasks-panel-item-rec"><svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="17 1 21 5 17 9"/><path d="M3 11V9a4 4 0 0 1 4-4h14"/><polyline points="7 23 3 19 7 15"/><path d="M21 13v2a4 4 0 0 1-4 4H3"/></svg>repetir</span>`
        : '';
      return `<div class="db-tasks-panel-item" style="animation-delay:${i*45}ms" onclick="window.verDetalle('${t.id}');window.cerrarPanelExt('${estado}')">
        <span class="db-tasks-panel-accent" style="background:${accentColor}"></span>
        <div class="db-tasks-panel-info">
          <div class="db-tasks-panel-item-title">${t.titulo}</div>
          <div class="db-tasks-panel-item-cat">
            <span class="db-tasks-panel-item-cat-dot" style="background:${accentColor}"></span>
            ${catNombre}
          </div>
          <div class="db-tasks-panel-item-divider"></div>
          <div class="db-tasks-panel-item-meta">
            <span class="db-tasks-panel-item-fecha">
              <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="3" y1="10" x2="21" y2="10"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="16" y1="2" x2="16" y2="6"/></svg>
              ${fecha}
            </span>
            <span class="db-tasks-panel-item-prio" style="background:${pc.bg};color:${pc.color};border-color:${pc.border}">${t.prioridad}</span>
            ${recBadge}
          </div>
        </div>
      </div>`;
    }).join('');
  }

  (window as any).cerrarPanelExt = (estado: string) => cerrarPanelTareas(estado as 'pendiente'|'completada');

  function render() {
    const activos=filtros.filter(f=>f.activo).map(f=>f.id);
    const filtered=allTasks.filter(t=>activos.includes(t.categoria));
    // Badges
    const totalPendientes  = allTasks.filter(t => t.estado === 'pendiente').length;
    const totalCompletadas = allTasks.filter(t => t.estado === 'completada').length;
    const badge = document.getElementById('pendientes-count-badge');
    if (badge) { badge.textContent=String(totalPendientes); badge.style.display=totalPendientes>0?'inline-flex':'none'; }
    const badgeC = document.getElementById('completadas-count-badge');
    if (badgeC) { badgeC.textContent=String(totalCompletadas); badgeC.style.display=totalCompletadas>0?'inline-flex':'none'; }
    document.querySelectorAll<HTMLElement>('.db-view-btn').forEach(btn=>btn.classList.toggle('active',btn.dataset.v===currentView));
    if(currentView==='dia') renderDia(filtered);
    else if(currentView==='semana') renderSemana(filtered);
    else renderMes(filtered);
    if(document.getElementById('modal-pendientes-lista')?.classList.contains('open')) renderPanelTareas('pendiente');
    if(document.getElementById('modal-completadas-lista')?.classList.contains('open')) renderPanelTareas('completada');
  }
 
  function getColorTarea(t:Tarea):string {
    if (t.estado === 'completada') return '#9ca3af';
    const f=filtros.find(x=>x.id===t.categoria); if(f) return f.color;
    return t.prioridad==='alta'?'#ef4444':t.prioridad==='media'?'#f59e0b':'#0ea5e9';
  }
 
  function formatearHora(i:number):string {
    const fmt=localStorage.getItem('conf_hora')??"24";
    if(fmt==='12'){const p=i<12?'AM':'PM';const h=i===0?12:i>12?i-12:i;return `${h}:00 ${p}`;}
    return `${i.toString().padStart(2,'0')}:00`;
  }
 
  function renderDia(filtered:Tarea[]) {
    const dStr=[viewDate.getFullYear(),String(viewDate.getMonth()+1).padStart(2,'0'),String(viewDate.getDate()).padStart(2,'0')].join('-');
    hTitle.textContent=viewDate.toLocaleDateString('es-ES',{weekday:'long',day:'numeric',month:'long'}).replace(/^\w/,c=>c.toUpperCase());
    let html='<div class="db-day-grid">';
    for(let i=0;i<24;i++){
      const h=i.toString().padStart(2,'0');
      const tasks=filtered.filter(t=>t.fecha===dStr&&t.hora?.startsWith(h+':'));
      html+=`<div class="db-day-row"><div class="db-hour-label">${formatearHora(i)}</div><div class="db-hour-tasks">${tasks.map(crearCard).join('')}</div></div>`;
    }
    container.innerHTML=html+'</div>';
  }
 
  function renderSemana(filtered:Tarea[]) {
    hTitle.textContent='Vista semanal';
    const start=new Date(viewDate); start.setDate(start.getDate()-(start.getDay()===0?6:start.getDay()-1));
    let html='<div class="db-week-grid">';
    for(let i=0;i<7;i++){
      const d=new Date(start); d.setDate(start.getDate()+i);
      const ds=[d.getFullYear(),String(d.getMonth()+1).padStart(2,'0'),String(d.getDate()).padStart(2,'0')].join('-');
      html+=`<div class="db-week-col"><div class="db-week-col-header"><div class="db-week-col-day">${d.toLocaleDateString('es-ES',{weekday:'short'})}</div><div class="db-week-col-num">${d.getDate()}</div></div>${filtered.filter(t=>t.fecha===ds).map(crearCard).join('')}</div>`;
    }
    container.innerHTML=html+'</div>';
  }
 
  function renderMes(filtered:Tarea[]) {
    const y=viewDate.getFullYear(),m=viewDate.getMonth();
    hTitle.textContent=viewDate.toLocaleDateString('es-ES',{month:'long',year:'numeric'}).replace(/^\w/,c=>c.toUpperCase());
    const first=new Date(y,m,1).getDay(),days=new Date(y,m+1,0).getDate(),off=first===0?6:first-1;
    let html='<div class="db-month-grid">';
    ['Lun','Mar','Mié','Jue','Vie','Sáb','Dom'].forEach(d=>html+=`<div class="db-month-header-cell">${d}</div>`);
    for(let i=0;i<off;i++) html+='<div></div>';
    for(let d=1;d<=days;d++){
      const ds=`${y}-${String(m+1).padStart(2,'0')}-${String(d).padStart(2,'0')}`;
      const dt=filtered.filter(t=>t.fecha===ds);
      html+=`<div class="db-month-day"><div class="db-month-day-num">${d}</div>${dt.map(t=>`<div onclick="window.verDetalle('${t.id}')" class="db-month-dot" style="background:${getColorTarea(t)}" title="${t.titulo}"></div>`).join('')}</div>`;
    }
    container.innerHTML=html+'</div>';
  }
 
  // GT-86: badge recurrente en tarjeta
  function crearCard(t:Tarea):string {
    const color=getColorTarea(t);
    const recBadge=t.es_recurrente?`<div class="db-task-card-rec"><svg width="9" height="9" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="display:inline;vertical-align:middle;margin-right:3px"><polyline points="17 1 21 5 17 9"/><path d="M3 11V9a4 4 0 0 1 4-4h14"/><polyline points="7 23 3 19 7 15"/><path d="M21 13v2a4 4 0 0 1-4 4H3"/></svg>recurrente</div>`:'';
    return `<div onclick="window.verDetalle('${t.id}')" class="db-task-card" style="background:${color}">
      <div class="db-task-card-time">${t.hora||'Todo el día'}</div>
      <div class="db-task-card-title">${t.titulo}</div>
      ${recBadge}
    </div>`;
  }
 
  document.querySelectorAll<HTMLElement>('.db-view-btn').forEach(btn=>{
    btn.addEventListener('click',()=>{ currentView=btn.dataset.v as any; render(); });
  });
  document.getElementById('prev-date')?.addEventListener('click',()=>{
    if(currentView==='mes') viewDate.setMonth(viewDate.getMonth()-1);
    else viewDate.setDate(viewDate.getDate()-(currentView==='semana'?7:1));
    render();
  });
  document.getElementById('next-date')?.addEventListener('click',()=>{
    if(currentView==='mes') viewDate.setMonth(viewDate.getMonth()+1);
    else viewDate.setDate(viewDate.getDate()+(currentView==='semana'?7:1));
    render();
  });
 
  /* ─────────────────── ETIQUETAS ─────────────────── */
  const modalEtiquetas=document.getElementById('modal-etiquetas')!;
  const etiquetasList =document.getElementById('etiquetas-list')!;
  const etiquetasForm =document.getElementById('etiquetas-form')!;
  const etiquetasToast=document.getElementById('etiquetas-toast')!;
  const eId     =document.getElementById('e-id')     as HTMLInputElement;
  const eNombre =document.getElementById('e-nombre') as HTMLInputElement;
  const eColor  =document.getElementById('e-color')  as HTMLInputElement;
 
  function toastEtiqueta(msg:string,ok:boolean){
    etiquetasToast.textContent=msg;
    etiquetasToast.className=ok?'db-toast show db-toast--ok':'db-toast show db-toast--err';
    setTimeout(()=>{etiquetasToast.className='hidden';},3000);
  }
  async function cargarEtiquetas(){
    etiquetasList.innerHTML='<p style="text-align:center;color:#9ca3af;font-size:12px;padding:16px;">Cargando...</p>';
    try{
      const r=await fetch('/api/etiquetas'); const d=await r.json();
      if(!d.success||!d.etiquetas.length){etiquetasList.innerHTML='<p style="text-align:center;color:#9ca3af;font-size:12px;padding:16px;">No hay etiquetas.</p>';return;}
      etiquetasList.innerHTML=d.etiquetas.map((e:any)=>`
        <div class="db-etiqueta-row">
          <div style="display:flex;align-items:center;gap:10px;"><div class="db-etiqueta-dot" style="background:${e.color}"></div><span class="db-etiqueta-name">${e.nombre}</span></div>
          <div style="display:flex;gap:6px;">
            <button class="db-btn-tag-edit btn-editar-etiqueta" data-id="${e.id_etiqueta}" data-nombre="${e.nombre}" data-color="${e.color}">Editar</button>
            <button class="db-btn-tag-del btn-eliminar-etiqueta" data-id="${e.id_etiqueta}" data-nombre="${e.nombre}">Eliminar</button>
          </div>
        </div>`).join('');
      etiquetasList.querySelectorAll('.btn-editar-etiqueta').forEach(btn=>{
        btn.addEventListener('click',()=>{
          const d=(btn as HTMLElement).dataset;
          eId.value=d.id!;eNombre.value=d.nombre!;eColor.value=d.color!;
          etiquetasForm.classList.remove('hidden');
          etiquetasForm.scrollIntoView({behavior:'smooth',block:'nearest'});
        });
      });
      etiquetasList.querySelectorAll('.btn-eliminar-etiqueta').forEach(btn=>{
        btn.addEventListener('click',async()=>{
          const d=(btn as HTMLElement).dataset;
          if(!(await confirmar(`¿Eliminar ${d.nombre}?`, true)))return;
          const r=await fetch('/api/etiquetas',{method:'DELETE',headers:{'Content-Type':'application/json'},body:JSON.stringify({id_etiqueta:d.id})});
          const rd=await r.json();
          if(rd.success){toastEtiqueta(`"${d.nombre}" eliminada`,true);await cargarEtiquetas();}
          else toastEtiqueta('Error al eliminar',false);
        });
      });
    }catch{etiquetasList.innerHTML='<p style="color:#ef4444;text-align:center;font-size:12px;padding:16px;">Error al cargar.</p>';}
  }
  document.getElementById('e-guardar')?.addEventListener('click',async()=>{
    const p={id_etiqueta:eId.value,nombre:eNombre.value.trim(),color:eColor.value};
    if(!p.nombre)return;
    const r=await fetch('/api/etiquetas',{method:'PUT',headers:{'Content-Type':'application/json'},body:JSON.stringify(p)});
    const rd=await r.json();
    if(rd.success){toastEtiqueta(`"${p.nombre}" actualizada`,true);etiquetasForm.classList.add('hidden');await cargarEtiquetas();}
    else toastEtiqueta('Error al guardar',false);
  });
  document.getElementById('e-cancelar')?.addEventListener('click',()=>etiquetasForm.classList.add('hidden'));
  document.getElementById('btn-etiquetas')?.addEventListener('click',async()=>{modalEtiquetas.classList.add('open');etiquetasForm.classList.add('hidden');await cargarEtiquetas();});
  document.getElementById('close-etiquetas')?.addEventListener('click',()=>modalEtiquetas.classList.remove('open'));
 
  /* ─────────────────── SIDEBAR RESPONSIVE ─────────────────── */
  const dbLayout       = document.querySelector('.db-layout') as HTMLElement;
  const sidebarOverlay = document.getElementById('sidebar-overlay');
  const sidebarToggle  = document.getElementById('btn-sidebar-toggle');
  const dbMainEl       = document.querySelector('.db-main') as HTMLElement;

  function cerrarSidebarMobile() { dbLayout?.classList.remove('sidebar-open'); }

  sidebarToggle?.addEventListener('click', (e) => {
    e.stopPropagation();
    dbLayout?.classList.toggle('sidebar-open');
  });
  sidebarOverlay?.addEventListener('click', cerrarSidebarMobile);
  dbMainEl?.addEventListener('click', () => {
    if (window.innerWidth <= 768) cerrarSidebarMobile();
  });

  /* ─────────────────── INIT ─────────────────── */
  filtros=cargarFiltros();
  renderFiltros();
  actualizarBadgeNotas();
  actualizarBadgeArchivos();
 
  window.addEventListener('configuracionActualizada',()=>{
    const v=localStorage.getItem('conf_vista') as 'dia'|'semana'|'mes';
    if(v&&currentView!==v){currentView=v;render();}
  });
 
  load();
</script>
