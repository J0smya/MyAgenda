  function renderOpciones(opciones: string[]) {
    const prev = aiMensajes.querySelector('.db-ai-opciones');
    if (prev) prev.remove();
    if (!opciones.length) return;
    const wrap = document.createElement('div');
    wrap.className = 'db-ai-opciones';
    opciones.forEach(op => {
      const btn = document.createElement('button');
      btn.className = 'db-ai-opcion-btn';
      btn.textContent = op;
      btn.addEventListener('click', () => { wrap.remove(); enviarMensajeAI(op); });
      wrap.appendChild(btn);
    });
    aiMensajes.appendChild(wrap);
    aiMensajes.scrollTop = aiMensajes.scrollHeight;
  }

  function agregarMensajeChat(rol: 'user' | 'bot', texto: string) {
    aiMensajes.querySelector('.db-ai-opciones')?.remove();
    const div = document.createElement('div');
    div.className = `db-ai-msg db-ai-msg--${rol}`;
    const html = texto
      .replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>')
      .replace(/\n/g, '<br>');
    div.innerHTML = `<div class="db-ai-msg-bubble">${html}</div>`;
    aiMensajes.appendChild(div);
    aiMensajes.scrollTop = aiMensajes.scrollHeight;
  }

  function agregarToastAccion(texto: string) {
    const div = document.createElement('div');
    div.className = 'db-ai-accion-toast';
    div.innerHTML = texto;
    aiMensajes.appendChild(div);
    aiMensajes.scrollTop = aiMensajes.scrollHeight;
  }

  async function enviarMensajeAI(textoForzado?: string) {
    const texto = textoForzado ?? aiInput.value.trim();
    if (!texto || aiEnviando) return;
    aiEnviando = true;
    if (!textoForzado) aiInput.value = '';
    btnAiSend.disabled = true;
    if (estadoChat.menu === 'crear_tarea_titulo') {
      datosAcumulados = { titulo: texto };
    } else if (estadoChat.menu === 'crear_tarea_prioridad') {
      let prioridad = 'media';
      if (texto.toLowerCase().includes('alta')) prioridad = 'alta';
      else if (texto.toLowerCase().includes('baja')) prioridad = 'baja';
      datosAcumulados = { ...datosAcumulados, prioridad };
    } else if (estadoChat.menu === 'crear_nota_titulo') {
      datosAcumulados = { titulo: texto };
    }
    agregarMensajeChat('user', texto);
    aiTyping.classList.remove('hidden');
    aiMensajes.scrollTop = aiMensajes.scrollHeight;
    try {
      const res = await fetch('/api/chatbot', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ mensaje: texto, estado: estadoChat, datos: datosAcumulados })
      });
      const data = await res.json();
      aiTyping.classList.add('hidden');
      if (data.success) {
        estadoChat = { menu: data.estado, datos: datosAcumulados };
        if (data.estado === 'inicio') datosAcumulados = {};
        agregarMensajeChat('bot', data.texto);
        renderOpciones(data.opciones ?? []);
        if (data.accion === 'tarea_creada') {
          datosAcumulados = {};
          agregarToastAccion('Tarea creada correctamente');
          await load(); actualizarBadgeNotas();
        }
        if (data.accion === 'nota_creada') {
          datosAcumulados = {};
          agregarToastAccion('Nota creada correctamente');
          actualizarBadgeNotas();
        }
      } else {
        agregarMensajeChat('bot', data.texto || 'Error al procesar. Intenta de nuevo.');
      }
    } catch {
      aiTyping.classList.add('hidden');
      agregarMensajeChat('bot', 'Error de conexión. Verifica tu red e intenta de nuevo.');
    } finally {
      aiEnviando = false;
      btnAiSend.disabled = false;
      aiInput.focus();
    }
  }

  async function iniciarChat() {
    if (aiMensajes.children.length > 1) return;
    try {
