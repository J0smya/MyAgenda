  /* ─────────────────── MODAL TAREA ─────────────────── */
  function openModalTarea(modo:'nueva'|'editar'='nueva', tarea?:Tarea) {
    const tituloLabel = document.getElementById('modal-titulo-label')!;
    const submitBtn   = document.getElementById('btn-submit-tarea') as HTMLButtonElement;
 
    if (modo==='editar' && tarea) {
      modoEdicion    = true;
      tareaEditandoId = tarea.id;
      tituloLabel.textContent  = 'Editar tarea';
      submitBtn.textContent    = 'Guardar cambios';
      // Rellenar campos con datos existentes
      (document.getElementById('t-titulo')      as HTMLInputElement).value   = tarea.titulo;
      (document.getElementById('t-desc')        as HTMLTextAreaElement).value = tarea.descripcion||'';
      (document.getElementById('t-fecha')       as HTMLInputElement).value   = tarea.fecha;
      (document.getElementById('t-hora-inicio') as HTMLInputElement).value   = tarea.hora||'';
      (document.getElementById('t-prioridad')   as HTMLSelectElement).value  = tarea.prioridad;
      actualizarSelectCategoria();
      (document.getElementById('t-cat') as HTMLSelectElement).value = tarea.categoria;
      actualizarDots();
      // Ocultar recurrencia en modo edición (se maneja por separado)
      document.getElementById('recurrencia-wrap')!.style.display = 'none';
    } else {
      modoEdicion    = false;
      tareaEditandoId = null;
      tituloLabel.textContent = 'Nueva tarea';
      submitBtn.textContent   = 'Guardar tarea';
      taskForm.reset();
      const hoy=[viewDate.getFullYear(),String(viewDate.getMonth()+1).padStart(2,'0'),String(viewDate.getDate()).padStart(2,'0')].join('-');
      (document.getElementById('t-fecha') as HTMLInputElement).value = hoy;
      const avisoGuardado=localStorage.getItem('conf_aviso');
      if (avisoGuardado) (document.getElementById('t-minutos-antes') as HTMLSelectElement).value=avisoGuardado;
      actualizarSelectCategoria();
      actualizarDots();
      document.getElementById('recurrencia-wrap')!.style.display='';
      resetRecurrencia();
      resetNota();
    }
    modalCreate.classList.add('open');
  }
 
