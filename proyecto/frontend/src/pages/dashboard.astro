<script>
  interface Tarea {
    id: any; titulo: string; descripcion: string;
    fecha: string; hora: string | null; prioridad: string; categoria: string;
    estado?: string;
    es_recurrente?: boolean; id_serie?: number | null;
  }
  interface Filtro {
    id: string; nombre: string; color: string; activo: boolean;
  }
 
  let allTasks:    Tarea[]               = [];
  let currentView: 'dia'|'semana'|'mes'  = (localStorage.getItem('conf_vista') as any) || 'dia';
  let viewDate      = new Date();
  let selectedTaskId: any                = null;
  let notaHtml      = '';
  let notaTitulo    = '';
  let editorMode: 'task'|'sidebar-edit'|'sidebar-new' = 'task';
  let notaSidebarEditandoId: string | null = null;
  let modoEdicion   = false;          // true cuando editamos tarea existente
  let tareaEditandoId: any = null;    // id de la tarea que se está editando
  const recordatoriosActivos = new Map<string, ReturnType<typeof setTimeout>[]>();
 
  const FILTROS_KEY = 'myagenda_filtros';
  let filtros: Filtro[] = [];
  let filtroEditandoId: string | null = null;
  let colorSeleccionado = '#0ea5e9';
  const COLORES_PRESET = ['#0ea5e9','#6366f1','#f59e0b','#ef4444','#10b981','#8b5cf6','#f97316','#ec4899','#14b8a6','#64748b'];
 
  // ── Estado recurrencia ──
  let recConfig = {
    activo: false,
    frecuencia: 'diaria' as 'diaria'|'semanal'|'mensual',
    intervalo: 1,
    diasSemana: [] as number[],
    finTipo: 'nunca' as 'nunca'|'fecha'|'cantidad',
    fechaFin: null as string|null,
    totalOcurr: null as number|null,
  };
 
  const INTERVALO_LABELS: Record<string,string> = { diaria:'día(s)', semanal:'semana(s)', mensual:'mes(es)' };

  const PRIORIDAD_COLORS: Record<string,string> = {
    alta: '#ef4444', media: '#f59e0b', baja: '#22c55e',
  };

  function actualizarDots() {
    const prioEl = document.getElementById('t-prioridad') as HTMLSelectElement;
    const catEl  = document.getElementById('t-cat')       as HTMLSelectElement;
    const dotPrio = document.getElementById('dot-prioridad') as HTMLElement;
    const dotCat  = document.getElementById('dot-categoria') as HTMLElement;
    if (dotPrio && prioEl) {
      dotPrio.style.background = PRIORIDAD_COLORS[prioEl.value] || '#94a3b8';
    }
