---
// src/pages/dashboard.astro
import Layout from "../layouts/Layout.astro";
import NoteEditor from "../components/noteEditor.astro";
import Perfil from "../pages/perfil.astro";
import '../styles/tablero.css';
import '../styles/noteEditor.css';
---
 
<Layout title="MyAgenda Pro 2026">
<div class="db-layout">
 
  <aside class="db-sidebar">
    <div class="db-logo">
      <img src="/logo.svg" alt="My Agenda" class="db-logo-icon" width="36" height="36" />
      <span class="db-logo-text">My Agenda</span>
    </div>
 
    <div class="db-sidebar-section">
      <div class="db-filters-header">
        <h3>Filtros</h3>
        <button id="btn-add-filtro" class="db-btn-add-filtro" title="Agregar filtro">+</button>
      </div>
      <div id="filtros-lista"></div>
    </div>
 
    <div class="db-sidebar-bottom-btns">
      <button id="btn-pendientes" class="db-sidebar-pendientes-btn">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="10"/>
          <polyline points="12 6 12 12 16 14"/>
        </svg>
        <span>Pendientes</span>
        <span id="pendientes-count-badge" class="db-pendientes-count-badge" style="display:none"></span>
      </button>
      <button id="btn-completadas" class="db-sidebar-completadas-btn">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="20 6 9 17 4 12"/>
        </svg>
        <span>Completadas</span>
        <span id="completadas-count-badge" class="db-completadas-count-badge" style="display:none"></span>
      </button>
      <button id="btn-ver-notas" class="db-sidebar-notes-btn">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
          <polyline points="14 2 14 8 20 8"/>
          <line x1="16" y1="13" x2="8" y2="13"/>
          <line x1="16" y1="17" x2="8" y2="17"/>
        </svg>
        <span>Notas</span>
        <span id="notas-count-badge" class="db-notes-count-badge" style="display:none"></span>
      </button>
      <button id="btn-ver-archivos" class="db-sidebar-archivos-btn">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"/>
        </svg>
        <span>Archivos</span>
        <span id="archivos-count-badge" class="db-archivos-count-badge" style="display:none"></span>
      </button>
      <div class="db-sidebar-perfil-wrap">
        <Perfil />
      </div>
    </div>
  </aside>

  <div id="sidebar-overlay" class="db-sidebar-overlay"></div>

  <main class="db-main">
    <header class="db-header">
      <div class="db-header-left">
        <button id="btn-sidebar-toggle" class="db-sidebar-toggle" aria-label="Abrir menú">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <line x1="3" y1="6" x2="21" y2="6"/>
            <line x1="3" y1="12" x2="21" y2="12"/>
            <line x1="3" y1="18" x2="21" y2="18"/>
          </svg>
        </button>
        <button id="prev-date" class="db-nav-arrow" title="Anterior">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M15 19l-7-7 7-7"/></svg>
        </button>
        <button id="next-date" class="db-nav-arrow" title="Siguiente">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M9 5l7 7-7 7"/></svg>
        </button>
        <h2 id="header-title" class="db-date-title"></h2>
      </div>
      <div class="db-header-right">
        <div class="db-view-tabs">
          <button data-v="dia"    class="db-view-btn nav-btn">Día</button>
          <button data-v="semana" class="db-view-btn nav-btn">Semana</button>
          <button data-v="mes"    class="db-view-btn nav-btn">Mes</button>
        </div>
        <button id="btn-add" class="db-btn-add">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
          <span class="db-btn-add-text">Nueva tarea</span>
        </button>
      </div>
    </header>
    <div class="db-view-container" id="view-container"></div>
  </main>
 
  <!-- FAB IA -->
  <button id="btn-ai-toggle" class="db-fab db-fab--ai" title="Asistente IA">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M12 2a2 2 0 0 1 2 2c0 .74-.4 1.39-1 1.73V7h1a7 7 0 0 1 7 7h1a1 1 0 0 1 1 1v3a1 1 0 0 1-1 1h-1v1a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-1H2a1 1 0 0 1-1-1v-3a1 1 0 0 1 1-1h1a7 7 0 0 1 7-7h1V5.73c-.6-.34-1-.99-1-1.73a2 2 0 0 1 2-2z"/>
      <circle cx="9" cy="13" r="1" fill="currentColor" stroke="none"/>
      <circle cx="15" cy="13" r="1" fill="currentColor" stroke="none"/>
    </svg>
  </button>
 
  <!-- VENTANA CHAT AI -->
  <div id="ai-window" class="db-ai-window hidden">
    <div class="db-ai-header">
      <div class="db-ai-header-info">
        <div class="db-ai-avatar">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 2a2 2 0 0 1 2 2c0 .74-.4 1.39-1 1.73V7h1a7 7 0 0 1 7 7h1a1 1 0 0 1 1 1v3a1 1 0 0 1-1 1h-1v1a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-1H2a1 1 0 0 1-1-1v-3a1 1 0 0 1 1-1h1a7 7 0 0 1 7-7h1V5.73c-.6-.34-1-.99-1-1.73a2 2 0 0 1 2-2z"/>
          </svg>
        </div>
        <div>
          <div class="db-ai-name">Aria</div>
          <div class="db-ai-status"><span class="db-ai-dot"></span>Asistente IA</div>
        </div>
      </div>
      <button id="btn-ai-close" class="db-ai-close" title="Cerrar">✕</button>
    </div>
    <div class="db-ai-body" id="ai-mensajes">
      <div class="db-ai-msg db-ai-msg--bot">
        <div class="db-ai-msg-bubble">
          Hola, soy <strong>Aria</strong>, tu asistente inteligente. Puedo consultar tus tareas, notas y archivos, y también <strong>crear tareas o notas</strong> por ti. ¿En qué te ayudo?
        </div>
      </div>
    </div>
    <div id="ai-typing" class="db-ai-typing hidden"><span></span><span></span><span></span></div>
    <div class="db-ai-footer">
      <input type="text" id="ai-input" class="db-ai-input" placeholder="Escribe aquí… (Enter para enviar)" maxlength="500">
      <button id="btn-ai-send" class="db-ai-send-btn" title="Enviar">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/>
        </svg>
      </button>
    </div>
  </div>
 
  <!-- MODAL CREAR / EDITAR TAREA -->
  <div id="modal" class="db-modal-backdrop">
    <div class="db-modal-box">
      <form id="task-form">
        <div class="db-modal-form-head">
          <div class="db-modal-form-icon">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <rect x="3" y="4" width="18" height="18" rx="2"/>
              <line x1="16" y1="2" x2="16" y2="6"/>
              <line x1="8" y1="2" x2="8" y2="6"/>
              <line x1="3" y1="10" x2="21" y2="10"/>
            </svg>
          </div>
          <h3 class="db-modal-title" id="modal-titulo-label">Nueva tarea</h3>
        </div>
        <div class="space-y-4">
          <div class="db-field-group">
            <label class="db-field-label" for="t-titulo">Título</label>
            <input type="text" id="t-titulo" required placeholder="Ej: Reunión de equipo..." class="db-input">
          </div>

          <div class="db-field-group">
            <label class="db-field-label" for="t-desc">Descripción</label>
            <textarea id="t-desc" placeholder="Agrega notas o detalles opcionales..." rows="2" class="db-input" style="resize:none"></textarea>
          </div>

          <div class="grid-2">
            <div class="db-field-group">
              <label class="db-field-label" for="t-prioridad">Prioridad</label>
              <div class="db-select-pill-wrap">
                <span class="db-select-pill-dot" id="dot-prioridad"></span>
                <select id="t-prioridad" class="db-select db-select-has-dot">
                  <option value="alta">Alta prioridad</option>
                  <option value="media" selected>Media prioridad</option>
                  <option value="baja">Baja prioridad</option>
                </select>
              </div>
            </div>
            <div class="db-field-group">
              <label class="db-field-label" for="t-cat">Categoría</label>
              <div class="db-select-pill-wrap">
                <span class="db-select-pill-dot" id="dot-categoria"></span>
                <select id="t-cat" class="db-select db-select-has-dot"></select>
              </div>
            </div>
          </div>

          <div class="grid-2">
            <div class="db-field-group">
              <label class="db-field-label" for="t-fecha">Fecha</label>
              <input type="date" id="t-fecha" class="db-input">
            </div>
            <div class="db-field-group">
              <label class="db-field-label" for="t-hora-inicio">Hora</label>
              <input type="time" id="t-hora-inicio" class="db-input" style="text-align:center;">
            </div>
          </div>
 
          <!-- RECORDATORIO -->
          <div class="db-form-section">
            <label class="db-form-section-toggle">
              <input type="checkbox" id="t-usa-recordatorio" class="db-form-checkbox">
              <span class="db-form-section-icon db-form-section-icon--blue">
                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/>
                  <path d="M13.73 21a2 2 0 0 1-3.46 0"/>
                </svg>
              </span>
              <span class="db-form-section-label">Activar recordatorio</span>
            </label>
            <div id="wrapper-recordatorio" class="hidden db-form-section-body">
              <select id="t-minutos-antes" class="db-select">
                <option value="5">5 minutos antes</option>
                <option value="15">15 minutos antes</option>
                <option value="30">30 minutos antes</option>
                <option value="60" selected>1 hora antes</option>
                <option value="120">2 horas antes</option>
                <option value="1440">1 día antes</option>
              </select>
              <p class="db-form-section-hint">Recibirás una notificación en pantalla.</p>
            </div>
          </div>
 
          <!-- RECURRENCIA -->
          <div id="recurrencia-wrap" class="db-form-section db-form-section--green">
            <label class="db-form-section-toggle">
              <input type="checkbox" id="t-usa-recurrencia" class="db-form-checkbox">
              <span class="db-form-section-icon db-form-section-icon--green">
                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                  <polyline points="17 1 21 5 17 9"/>
                  <path d="M3 11V9a4 4 0 0 1 4-4h14"/>
                  <polyline points="7 23 3 19 7 15"/>
                  <path d="M21 13v2a4 4 0 0 1-4 4H3"/>
                </svg>
              </span>
              <span class="db-form-section-label">Repetir tarea</span>
            </label>
            <div id="wrapper-recurrencia" style="display:none;" class="db-form-section-body db-recur-body">

              <!-- Frecuencia -->
              <div class="db-recur-group">
                <p class="db-recur-group-label">Frecuencia</p>
                <div class="db-recur-tabs" id="rec-freq-tabs">
                  <button type="button" class="db-rec-freq-btn active" data-freq="diaria">
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="3" y1="10" x2="21" y2="10"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="16" y1="2" x2="16" y2="6"/></svg>
                    Diaria
                  </button>
                  <button type="button" class="db-rec-freq-btn" data-freq="semanal">
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="3" y1="10" x2="21" y2="10"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="16" y1="2" x2="16" y2="6"/></svg>
                    Semanal
                  </button>
                  <button type="button" class="db-rec-freq-btn" data-freq="mensual">
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="3" y1="10" x2="21" y2="10"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="16" y1="2" x2="16" y2="6"/></svg>
                    Mensual
                  </button>
                </div>
              </div>

              <!-- Intervalo -->
              <div class="db-recur-interval">
                <span class="db-recur-lbl">Cada</span>
                <input type="number" id="rec-intervalo" min="1" max="30" value="1" class="db-input db-recur-num">
                <span id="rec-intervalo-label" class="db-recur-lbl">día(s)</span>
              </div>

              <!-- Días semana (solo semanal) -->
              <div id="rec-dias-wrap" style="display:none;" class="db-recur-group">
                <p class="db-recur-group-label">Días</p>
                <div class="db-dia-btns-row" id="rec-dias">
                  <button type="button" class="db-dia-btn" data-day="1">L</button>
                  <button type="button" class="db-dia-btn" data-day="2">M</button>
                  <button type="button" class="db-dia-btn" data-day="3">X</button>
                  <button type="button" class="db-dia-btn" data-day="4">J</button>
                  <button type="button" class="db-dia-btn" data-day="5">V</button>
                  <button type="button" class="db-dia-btn" data-day="6">S</button>
                  <button type="button" class="db-dia-btn" data-day="7">D</button>
                </div>
              </div>

              <!-- Fin de serie -->
              <div class="db-recur-group">
                <p class="db-recur-group-label">Terminar</p>
                <div class="db-recur-fin-row" id="rec-fin-tabs">
                  <button type="button" class="db-rec-fin-btn active" data-fin="nunca">Nunca</button>
                  <button type="button" class="db-rec-fin-btn" data-fin="fecha">Por fecha</button>
                  <button type="button" class="db-rec-fin-btn" data-fin="cantidad">Por cantidad</button>
                </div>
                <div id="rec-fin-fecha-wrap" style="display:none;margin-top:8px;">
                  <input type="date" id="rec-fecha-fin" class="db-input">
                </div>
                <div id="rec-fin-cantidad-wrap" style="display:none;margin-top:8px;align-items:center;gap:10px;">
                  <input type="number" id="rec-total-ocurr" min="2" max="365" value="10" class="db-input db-recur-num">
                  <span class="db-recur-lbl">repeticiones</span>
                </div>
              </div>

              <!-- Preview fechas -->
              <div class="db-recur-group">
                <p class="db-recur-group-label">Próximas fechas</p>
                <div id="rec-preview" class="db-rec-preview-wrap"></div>
              </div>
            </div>
          </div>
 
          <div class="db-form-sep">
            <div class="db-form-sep-line"></div>
            <span class="db-form-sep-text">Extras</span>
            <div class="db-form-sep-line"></div>
          </div>
 
          <div id="nota-badge" class="db-nota-badge">
            <span class="db-nota-badge-check">✓</span>
            <div class="db-nota-badge-info">
              <p class="db-nota-badge-label">Nota adjunta</p>
              <p id="nota-badge-title" class="db-nota-badge-title"></p>
            </div>
            <button type="button" id="btn-editar-nota" class="db-nota-badge-edit">Editar</button>
          </div>
 
          <button type="button" id="btn-agregar-nota" class="db-btn-nota">
            <div class="db-btn-nota-icon">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/>
                <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/>
              </svg>
            </div>
            <div class="db-btn-nota-text">
              <p class="db-btn-nota-label">Agregar nota</p>
              <p class="db-btn-nota-sub">Negrita · Cursiva · Listas · Colores</p>
            </div>
            <svg class="db-btn-nota-arrow" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M9 5l7 7-7 7"/></svg>
          </button>
 
          <div class="space-y-3" style="margin-top:8px;">
            <button type="submit" id="btn-submit-tarea" class="db-btn-submit">Guardar tarea</button>
            <button type="button" id="close-modal" class="db-btn-cancel">Cancelar</button>
          </div>
        </div>
      </form>
    </div>
  </div>
 
  <!-- MODAL VER TAREA -->
  <div id="modal-view" class="db-modal-backdrop" style="z-index:210;">
    <div class="db-view-modal-box">
      <div id="view-content" class="space-y-4"></div>
      <div class="space-y-3" style="margin-top:24px;">
        <div class="db-view-action-row">
          <button id="btn-complete-task" class="db-btn-complete">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="margin-right:5px;flex-shrink:0;"><polyline points="20 6 9 17 4 12"/></svg>
            <span id="complete-task-label">Completar</span>
          </button>
          <button id="btn-view-pendientes" class="db-btn-pendientes-view">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            Pendientes
          </button>
        </div>
        <button id="btn-edit-task" class="db-btn-submit" style="background:linear-gradient(135deg,#6366f1,#8b5cf6);box-shadow:0 4px 14px rgba(99,102,241,0.35);">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="margin-right:6px;"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
          Editar tarea
        </button>
        <button id="close-view" class="db-btn-understood">Entendido</button>
        <button id="btn-delete-task" class="db-btn-delete">Eliminar tarea</button>
      </div>
    </div>
  </div>
 
  <!-- MODAL CONFIRMAR ACCIÓN EN SERIE (GT-87 / GT-88) -->
  <div id="modal-serie-accion" class="db-modal-backdrop" style="z-index:215;">
    <div class="db-view-modal-box" style="max-width:380px;">
      <div style="text-align:center;margin-bottom:16px;">
        <div style="width:44px;height:44px;border-radius:12px;background:#f0fdf4;display:flex;align-items:center;justify-content:center;margin:0 auto 10px;"><svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#059669" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><polyline points="17 1 21 5 17 9"/><path d="M3 11V9a4 4 0 0 1 4-4h14"/><polyline points="7 23 3 19 7 15"/><path d="M21 13v2a4 4 0 0 1-4 4H3"/></svg></div>
        <h3 id="serie-accion-titulo" style="font-size:16px;font-weight:700;color:#111827;margin:0 0 6px;"></h3>
        <p id="serie-accion-desc" style="font-size:13px;color:#6b7280;margin:0;"></p>
      </div>
      <div class="space-y-3" id="serie-accion-btns"></div>
      <button id="close-serie-accion" class="db-btn-cancel" style="margin-top:10px;">Cancelar</button>
    </div>
  </div>
 
  <!-- MODAL ETIQUETAS -->
  <div id="modal-etiquetas" class="db-modal-backdrop" style="z-index:220;">
    <div class="db-etiquetas-box">
      <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:20px;">
        <h3 class="db-etiquetas-title">Etiquetas</h3>
        <button id="close-etiquetas" class="db-btn-tag-del" style="padding:6px 14px;">✕</button>
      </div>
      <div id="etiquetas-list" class="space-y-3"></div>
      <div id="etiquetas-form" class="hidden space-y-3" style="margin-top:20px;padding-top:20px;border-top:1px solid #f3f4f6;">
