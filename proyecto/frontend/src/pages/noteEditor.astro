---

---


<div
  id="modal-nota"
  class="fixed inset-0 bg-slate-900/70 backdrop-blur-md hidden items-center justify-center z-[300] p-4"
  aria-modal="true"
  role="dialog"
  aria-labelledby="ne-modal-title"
>
  <div class="ne-modal-box">

    <!-- ── Topbar ── -->
    <header class="ne-topbar">
      <div class="flex items-center gap-3">
        <!-- dots macOS -->
        <div class="flex gap-1.5">
          <button id="ne-dot-close" class="ne-dot bg-[#ff5f57]" title="Cerrar sin guardar"></button>
          <span class="ne-dot bg-[#febc2e] cursor-default"></span>
          <span class="ne-dot bg-[#28c840] cursor-default"></span>
        </div>
        <div class="w-px h-4 bg-white/20"></div>
        <div class="flex items-center gap-2 text-blue-400">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/>
            <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/>
          </svg>
          <span id="ne-modal-title" class="font-black italic uppercase text-xs tracking-tight text-white">
            Editor de Nota
          </span>
        </div>
      </div>

      <div class="flex items-center gap-3">
        <span id="ne-words" class="text-[9px] font-black uppercase text-slate-500 tracking-widest">0 palabras</span>
        <button
          id="ne-save-btn"
          class="flex items-center gap-1.5 bg-blue-600 hover:bg-blue-700 active:scale-95 text-white px-5 py-2 rounded-full font-black uppercase text-[10px] tracking-widest shadow-lg transition-all"
        >
          <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/>
            <polyline points="17 21 17 13 7 13 7 21"/>
            <polyline points="7 3 7 8 15 8"/>
          </svg>
          Guardar nota
        </button>
      </div>
    </header>

    <!-- ── Cuerpo: sidebar + editor ── -->
    <div class="ne-body">

      <!-- Sidebar vertical de herramientas -->
      <aside class="ne-sidebar">

        <div class="ne-tool-group">
          <button class="ne-tool" data-cmd="bold"          title="Negrita (Ctrl+B)"><strong class="ne-tool-label">B</strong></button>
          <button class="ne-tool" data-cmd="italic"        title="Cursiva (Ctrl+I)"><em    class="ne-tool-label">I</em></button>
          <button class="ne-tool" data-cmd="underline"     title="Subrayado (Ctrl+U)">
            <span class="ne-tool-label" style="text-decoration:underline">U</span>
          </button>
          <button class="ne-tool" data-cmd="strikeThrough" title="Tachado">
            <span class="ne-tool-label" style="text-decoration:line-through">S</span>
          </button>
        </div>

        <div class="ne-sep"></div>

        <div class="ne-tool-group">
          <button class="ne-tool ne-tool--sm" data-cmd="formatBlock" data-val="h1" title="Título 1">H1</button>
          <button class="ne-tool ne-tool--sm" data-cmd="formatBlock" data-val="h2" title="Título 2">H2</button>
          <button class="ne-tool ne-tool--sm" data-cmd="formatBlock" data-val="p"  title="Párrafo">¶</button>
        </div>

        <div class="ne-sep"></div>

        <div class="ne-tool-group">
          <button class="ne-tool" data-cmd="insertUnorderedList" title="Lista con viñetas">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
              <line x1="9" y1="6"  x2="20" y2="6"/><line x1="9" y1="12" x2="20" y2="12"/><line x1="9" y1="18" x2="20" y2="18"/>
              <circle cx="4" cy="6"  r="1.5" fill="currentColor" stroke="none"/>
              <circle cx="4" cy="12" r="1.5" fill="currentColor" stroke="none"/>
              <circle cx="4" cy="18" r="1.5" fill="currentColor" stroke="none"/>
            </svg>
          </button>
          <button class="ne-tool" data-cmd="insertOrderedList" title="Lista numerada">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
              <line x1="10" y1="6"  x2="21" y2="6"/><line x1="10" y1="12" x2="21" y2="12"/><line x1="10" y1="18" x2="21" y2="18"/>
              <text x="1" y="8"  font-size="7" fill="currentColor" stroke="none" font-family="sans-serif">1</text>
              <text x="1" y="14" font-size="7" fill="currentColor" stroke="none" font-family="sans-serif">2</text>
              <text x="1" y="20" font-size="7" fill="currentColor" stroke="none" font-family="sans-serif">3</text>
            </svg>
          </button>
          <button class="ne-tool" data-cmd="indent" title="Sangría">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
              <line x1="3" y1="6" x2="21" y2="6"/><line x1="9" y1="12" x2="21" y2="12"/><line x1="9" y1="18" x2="21" y2="18"/>
              <polyline points="3 10 7 14 3 18"/>
            </svg>
          </button>
        </div>

        <div class="ne-sep"></div>

        <div class="ne-tool-group">
          <button class="ne-tool" data-cmd="justifyLeft"   title="Alinear izquierda">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="15" y2="12"/><line x1="3" y1="18" x2="18" y2="18"/></svg>
          </button>
          <button class="ne-tool" data-cmd="justifyCenter" title="Centrar">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><line x1="3" y1="6" x2="21" y2="6"/><line x1="6" y1="12" x2="18" y2="12"/><line x1="4" y1="18" x2="20" y2="18"/></svg>
          </button>
          <button class="ne-tool" data-cmd="justifyRight"  title="Alinear derecha">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><line x1="3" y1="6" x2="21" y2="6"/><line x1="9" y1="12" x2="21" y2="12"/><line x1="6" y1="18" x2="21" y2="18"/></svg>
          </button>
        </div>

        <div class="ne-sep"></div>

        <!-- Colores -->
        <div class="ne-tool-group">
          <span class="ne-color-label">Color</span>
          <button class="ne-color" data-color="#1f2937" style="background:#1f2937" title="Negro"></button>
          <button class="ne-color" data-color="#3b9edd" style="background:#3b9edd" title="Azul"></button>
          <button class="ne-color" data-color="#16a34a" style="background:#16a34a" title="Verde"></button>
          <button class="ne-color" data-color="#dc2626" style="background:#dc2626" title="Rojo"></button>
          <button class="ne-color" data-color="#d97706" style="background:#d97706" title="Naranja"></button>
          <button class="ne-color" data-color="#7c3aed" style="background:#7c3aed" title="Morado"></button>
          <button class="ne-color" data-color="#db2777" style="background:#db2777" title="Rosa"></button>
        </div>

        <div class="ne-sep"></div>

        <div class="ne-tool-group">
          <button class="ne-tool" data-cmd="undo" title="Deshacer">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="1 4 1 10 7 10"/><path d="M3.51 15a9 9 0 1 0 .49-3.5"/></svg>
          </button>
          <button class="ne-tool" data-cmd="redo" title="Rehacer">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 4 23 10 17 10"/><path d="M20.49 15a9 9 0 1 1-.49-3.5"/></svg>
          </button>
        </div>
      </aside>

      <!-- Área editable -->
      <div class="ne-edit-area">
        <!-- Título de la nota -->
        <div class="ne-title-wrap">
          <input
            id="ne-title"
            type="text"
            placeholder="Título de la nota…"
            maxlength="120"
            class="ne-title-input"
          />
        </div>
        <!-- Editor contenteditable -->
        <div
          id="ne-editor"
          contenteditable="true"
          spellcheck="true"
          data-placeholder="Empieza a escribir tu nota enriquecida…"
          class="ne-editor"
        ></div>
      </div>
    </div>

    <!-- Toast interno -->
    <div id="ne-toast" class="ne-toast hidden"></div>
  </div>
</div>

<style>
   /* ══ Caja del modal ══ */
  .ne-modal-box {
    background: #ffffff;
    width: 100%;
    max-width: 860px;
    height: 88vh;
    border-radius: 2rem;
    box-shadow: 0 32px 80px rgba(0,0,0,0.25), 0 0 0 1px rgba(0,0,0,0.06);
    display: flex;
    flex-direction: column;
    overflow: hidden;
    animation: ne-pop-in 0.22s cubic-bezier(0.34,1.56,0.64,1) both;
  }

  @keyframes ne-pop-in {
    from { opacity: 0; transform: scale(0.94) translateY(12px); }
    to   { opacity: 1; transform: scale(1)    translateY(0); }
  }

  /* ══ Topbar ══ */
  .ne-topbar {
    background: #0f172a;
    padding: 12px 20px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-shrink: 0;
  }

  .ne-dot {
    width: 12px; height: 12px;
    border-radius: 50%;
    border: none; padding: 0;
    cursor: pointer;
    transition: filter 0.15s;
  }
  .ne-dot:hover { filter: brightness(0.85); }

  /* ══ Cuerpo ══ */
  .ne-body {
    display: flex;
    flex: 1;
    overflow: hidden;
  }

  /* ══ Sidebar de herramientas ══ */
  .ne-sidebar {
    width: 3.5rem;
    background: #ffffff;
    border-right: 1px solid #f1f5f9;
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 12px 0;
    gap: 2px;
    overflow-y: auto;
    flex-shrink: 0;
  }

  .ne-tool-group {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2px;
    width: 100%;
  }

  .ne-sep {
    width: 28px; height: 1px;
    background: #f1f5f9;
    margin: 4px 0;
    flex-shrink: 0;
  }

  .ne-tool {
    width: 2rem; height: 2rem;
    display: flex; align-items: center; justify-content: center;
    border-radius: 8px;
    color: #64748b;
    transition: background 0.12s, color 0.12s;
    cursor: pointer;
    border: none;
    background: transparent;
    padding: 0;
  }
  .ne-tool:hover    { background: #eff6ff; color: #2563eb; }
  .ne-tool--active  { background: #dbeafe !important; color: #2563eb !important; }
  .ne-tool--sm      { font-weight: 900; font-size: 0.68rem; color: #475569; }
  .ne-tool-label    { font-size: 0.85rem; line-height: 1; pointer-events: none; }

  .ne-color-label {
    font-size: 7px;
    font-weight: 900;
    text-transform: uppercase;
    color: #cbd5e1;
    letter-spacing: 0.05em;
    margin-bottom: 2px;
  }

  .ne-color {
    width: 1rem; height: 1rem;
    border-radius: 50%;
    border: 2px solid transparent;
    cursor: pointer; padding: 0;
    transition: transform 0.12s;
    flex-shrink: 0;
  }
  .ne-color:hover { transform: scale(1.3); }

  /* ══ Área de edición ══ */
  .ne-edit-area {
    flex: 1;
    display: flex;
    flex-direction: column;
    overflow: hidden;
    background: #fff;
  }

  .ne-title-wrap {
    padding: 20px 40px 12px;
    border-bottom: 1px solid #f8fafc;
    flex-shrink: 0;
  }

  .ne-title-input {
    width: 100%;
    font-size: 1.4rem;
    font-weight: 900;
    color: #1e293b;
    background: transparent;
    border: none;
    outline: none;
    letter-spacing: -0.02em;
  }
  .ne-title-input::placeholder { color: #e2e8f0; }

  .ne-editor {
    flex: 1;
    overflow-y: auto;
    padding: 20px 40px 32px;
    outline: none;
    color: #374151;
    font-size: 0.9rem;
    line-height: 1.8;
    caret-color: #3b9edd;
    transition: box-shadow 0.2s;
  }
  .ne-editor:empty::before {
    content: attr(data-placeholder);
    color: #cbd5e1;
    pointer-events: none;
  }
  .ne-editor h1 { font-size: 1.5rem; font-weight: 900; margin: 0.6rem 0 0.3rem; line-height: 1.2; }
  .ne-editor h2 { font-size: 1.1rem; font-weight: 700; margin: 0.5rem 0 0.2rem; }
  .ne-editor p  { margin-bottom: 0.4rem; }
  .ne-editor ul, .ne-editor ol { padding-left: 1.4rem; margin-bottom: 0.4rem; }
  .ne-editor li { margin-bottom: 0.2rem; }
  .ne-editor strong { font-weight: 700; }
  .ne-editor em     { font-style: italic; }

  /* shake cuando se intenta guardar vacío */
  .ne-editor--shake {
    animation: ne-shake 0.35s ease;
    box-shadow: 0 0 0 2px #fca5a5;
    border-radius: 8px;
  }
  @keyframes ne-shake {
    0%,100% { transform: translateX(0); }
    20%  { transform: translateX(-6px); }
    40%  { transform: translateX( 6px); }
    60%  { transform: translateX(-4px); }
    80%  { transform: translateX( 4px); }
  }

  /* ══ Toast ══ */
  .ne-toast {
    position: absolute;
    bottom: 16px;
    left: 50%;
    transform: translateX(-50%);
    padding: 8px 20px;
    border-radius: 999px;
    font-size: 0.72rem;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    white-space: nowrap;
    z-index: 10;
    animation: ne-toast-in 0.2s ease;
  }
  .ne-toast--ok  { background:#f0fdf4; color:#15803d; border:1px solid #bbf7d0; }
  .ne-toast--err { background:#fef2f2; color:#dc2626; border:1px solid #fecaca; }
  @keyframes ne-toast-in {
    from { opacity:0; transform:translateX(-50%) translateY(8px); }
    to   { opacity:1; transform:translateX(-50%) translateY(0); }
  }

</style>