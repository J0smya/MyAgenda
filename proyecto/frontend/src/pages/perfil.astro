---
import '../styles/global.css'
import Layout from "../layouts/Layout.astro";
import '../styles/perfil.css';
import { obtenerTokenDeCookie, obtenerSesion } from '../lib/sesion';
import { pool } from '../lib/db';

const token = obtenerTokenDeCookie(Astro.request.headers.get('cookie'));
let userName  = '';
let userPhoto = '';
if (token) {
  const sesion = await obtenerSesion(token);
  if (sesion) {
    const r = await pool.query(
      'SELECT nombre, foto_perfil FROM public.usuario WHERE id_usuario = $1',
      [sesion.id_usuario]
    );
    if (r.rows.length > 0) {
      userName  = r.rows[0].nombre      ?? '';
      userPhoto = r.rows[0].foto_perfil ?? '';
    }
  }
}
---

<div class="perfil-wrapper" data-nombre={userName} data-foto={userPhoto}>
  <button id="perfil-btn" class="btn-estilo-notas">
    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg>
    Perfil
  </button>

  <div id="perfil-menu" class="perfil-menu oculto">
    <div class="menu-header">
      <div class="avatar-circulo" id="avatar-visual">A</div>
      <div class="info-usuario">
        <span class="nombre-usuario" id="nombre-visual">Alex Sebastian Saldaña Palomino</span>
      </div>
    </div>

    <hr class="separador" />

    <div class="seccion-menu">
      <button id="btn-cambiar-cuenta" class="item-menu">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
        <span>Cambiar de cuenta</span>
      </button>
      <button id="btn-cerrar-sesion" class="item-menu">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
        <span>Cerrar sesión</span>
      </button>
    </div>

    <hr class="separador" />

    <div class="seccion-menu">
      <button id="btn-configuracion" class="item-menu" onclick="window.location.href='/configuracion'">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1Z"/></svg>
        <span>Configuración</span>
      </button>
    </div>
  </div>
</div>

<div id="modal-cambiar-cuenta" class="modal-overlay hidden">
  <div class="perfil-modal-box">
    <h3 class="perfil-modal-title">Cambiar de cuenta</h3>
    <p style="font-size: 14px; text-align: center; color: #64748b; margin-bottom: 20px;">¿Deseas cerrar la sesión actual y cambiar de cuenta?</p>
    <div class="perfil-modal-actions">
      <button type="button" class="btn-cancelar" onclick="document.getElementById('modal-cambiar-cuenta').classList.add('hidden')">Cancelar</button>
      <button type="button" class="btn-guardar" id="btn-confirmar-cambio">Cambiar</button>
    </div>
  </div>
</div>

<div id="modal-cerrar-sesion" class="modal-overlay hidden">
  <div class="perfil-modal-box">
    <h3 class="perfil-modal-title">Cerrar sesión</h3>
    <p style="font-size: 14px; text-align: center; color: #64748b; margin-bottom: 20px;">¿Estás seguro de que deseas salir de My Agenda?</p>
    <div class="perfil-modal-actions">
      <button type="button" class="btn-cancelar" onclick="document.getElementById('modal-cerrar-sesion').classList.add('hidden')">Cancelar</button>
      <button type="button" class="btn-guardar" style="background: #ef4444;" id="btn-confirmar-cerrar">Cerrar sesión</button>
    </div>
  </div>
</div>

<script src="../pages/api/perfil.ts"></script>