---
import '../styles/global.css'
import Layout from "../layouts/Layout.astro";
import '../styles/perfil.css';
---

<div class="perfil-wrapper">
  <!-- Botón disparador -->
  <button id="perfil-btn" class="btn-estilo-notas">
    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"></path>
      <circle cx="12" cy="7" r="4"></circle>
    </svg>
    Perfil
  </button>

  <!-- Menú emergente -->
  <div id="perfil-menu" class="perfil-menu oculto">
    
    <div class="menu-header">
      <div class="avatar-circulo" id="avatar-visual">A</div>
      <div class="info-usuario">
        <span class="nombre-usuario" id="nombre-visual">Alex Sebastian Saldaña Palomino</span>
        <span class="handle-usuario">@Sebastian-dev</span>
        <!-- ID agregado aquí 👇 -->
        <a href="#" id="btn-editar-perfil" class="link-editar">Editar perfil</a>
      </div>
    </div>

    <hr class="separador" />

    <div class="seccion-menu">
      <button class="item-menu">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
        <span>Cambiar de cuenta</span>
        <svg class="icono-flecha" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-6-6"/></svg>
      </button>
      <!-- ID agregado aquí 👇 -->
      <button id="btn-cerrar-sesion" class="item-menu">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
        <span>Cerrar sesión</span>
      </button>
    </div>

    <hr class="separador" />

    <div class="seccion-menu">
      <!-- ID agregado aquí 👇 -->
      <button id="btn-tema" class="item-menu">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"/></svg>
        <span id="texto-tema">Aspecto: Claro</span>
        <svg class="icono-flecha" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-6-6"/></svg>
      </button>
      <button class="item-menu">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m5 8 6 6"/><path d="m4 14 6-6 2-3"/><path d="M2 5h12"/><path d="M7 2h1"/><path d="m22 22-5-10-5 10"/><path d="M14 18h6"/></svg>
        <span>Idioma: Español</span>
        <svg class="icono-flecha" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-6-6"/></svg>
      </button>
      <button class="item-menu">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 2a14.5 14.5 0 0 0 0 20 14.5 14.5 0 0 0 0-20"/><path d="M2 12h20"/></svg>
        <span>Ubicación: Colombia</span>
        <svg class="icono-flecha" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-6-6"/></svg>
      </button>
      <button class="item-menu">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1Z"/></svg>
        <span>Configuración</span>
      </button>
    </div>
  </div>
</div>

<!-- ✨ NUEVO: MODAL PARA EDITAR PERFIL -->
<div id="modal-edicion-perfil" class="modal-overlay hidden">
  <div class="perfil-modal-box">
    <h3 class="perfil-modal-title">Editar Perfil</h3>
    
    <form id="form-editar-perfil">
      <div class="perfil-form-group">
        <label>Foto de perfil</label>
        <div class="avatar-upload-container">
          <div class="avatar-preview" id="avatar-preview-circulo">A</div>
          <button type="button" class="btn-upload">Cambiar foto</button>
          <input type="file" id="input-foto" accept="image/*" class="hidden">
        </div>
      </div>

      <div class="perfil-form-group">
        <label>Nombre completo</label>
        <input type="text" id="input-nombre" class="perfil-input" value="Alex Sebastian Saldaña Palomino" required>
      </div>

      <div class="perfil-form-group">
        <label>Nombre de usuario</label>
        <input type="text" id="input-handle" class="perfil-input" value="@Sebastian-dev" required>
      </div>

      <div class="perfil-modal-actions">
        <button type="button" id="btn-cancelar-perfil" class="btn-cancelar">Cancelar</button>
        <button type="submit" class="btn-guardar">Guardar cambios</button>
      </div>
    </form>
  </div>
</div>

<!-- ESTE BLOQUE DEBE ESTAR AL FINAL DE TU PERFIL.ASTRO -->
<div id="modal-edicion-perfil" class="modal-overlay hidden">
  <div class="perfil-modal-box">
    <h3 class="perfil-modal-title">Editar Perfil</h3>
    <!-- ... resto del formulario que te pasé en el mensaje anterior ... -->
  </div>
</div>

<script src="../pages/api/perfil.ts"></script>