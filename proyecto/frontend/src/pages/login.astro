---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Iniciar sesión">

  <div class="relative min-h-screen flex items-center justify-center">

    <!-- Fondo -->
    <div class="absolute inset-0">
      <img 
        src=""
        class="w-full h-full object-cover"
        alt="background"
      />
      <div class="absolute inset-0 bg-white/70"></div>
    </div>

    <!-- Card -->
    <div class="relative w-[330px] bg-gray-200 rounded-2xl shadow-xl p-8">

      <!-- Header -->
      <div class="flex justify-center mb-6">
        <div class="bg-gray-400 text-white px-6 py-2 rounded-full font-bold shadow-md tracking-wide flex items-center gap-2">
          📅 INICIAR SESIÓN
        </div>
      </div>

      <!-- Contenedor del mensaje de error -->
      <div id="error-message" 
           class="mb-4 text-center text-sm text-red-600 font-medium hidden bg-red-50 p-3 rounded-xl border border-red-200">
        <!-- Aquí aparecerán los mensajes -->
      </div>

      <form id="login-form" class="space-y-4">

        <!-- Email -->
        <div class="bg-gray-300 rounded-full px-4 py-2 flex items-center gap-3 shadow-inner">
          <span class="text-gray-600">✉</span>
          <input 
            type="email" 
            name="email"
            placeholder="Correo"
            required
            class="bg-transparent w-full outline-none text-sm"
          />
        </div>

        <!-- Password -->
        <div class="bg-gray-300 rounded-full px-4 py-2 flex items-center gap-3 shadow-inner">
          <span class="text-gray-600">🔒</span>
          <input 
            type="password" 
            name="password"
            placeholder="Contraseña"
            required
            minlength="8"
            class="bg-transparent w-full outline-none text-sm"
          />
        </div>

        <!-- Olvidé contraseña -->
        <div class="text-xs text-center text-gray-600">
          <a href="/forgot-password" class="hover:underline">
            ¿Olvidó su contraseña?
          </a>
        </div>

        <!-- Botón -->
        <button 
          type="submit"
          class="w-full mt-3 bg-black text-white py-2 rounded-full font-semibold hover:scale-105 transition duration-200"
        >
          INICIAR SESIÓN
        </button>

      </form>

      <p class="text-center text-xs text-gray-600 mt-5">
        ¿No tienes cuenta?
        <a href="/registro" class="font-semibold hover:underline">
          Crear cuenta
        </a>
      </p>

    </div>
  </div>

  <script>
  document.addEventListener('DOMContentLoaded', () => {
    
    const formElement = document.getElementById('login-form');
    const errorDiv = document.getElementById('error-message');

    if (!formElement || !errorDiv) {
      console.warn('No se encontró el formulario o el div de error');
      return;
    }

    const form = formElement as HTMLFormElement;

    form.addEventListener('submit', async (e) => {
      e.preventDefault();

      errorDiv.classList.add('hidden');
      errorDiv.textContent = '';

      
      const formData = new FormData(form);

      try {
        const response = await fetch('/api/login', {
          method: 'POST',
          body: formData,
        });

        const data = await response.json();

        if (data.success) {
          window.location.href = '/dashboard'; // ruta al calendario
        } else {
          errorDiv.textContent = data.message || 'Error al iniciar sesión';
          errorDiv.classList.remove('hidden');
        }
      } catch (err) {
        errorDiv.textContent = 'Error de conexión. Intenta más tarde.';
        errorDiv.classList.remove('hidden');
        console.error(err);
      }
    });
  });
</script>

</Layout>