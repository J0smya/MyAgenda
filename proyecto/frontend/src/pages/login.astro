---
import '../styles/global.css'
import '../styles/login.css'
import Layout from "../layouts/Layout.astro";
---

<Layout title="Iniciar sesión">

  <div class="login-page">

    <!-- Fondo calendario SVG -->
    <div class="calendar-bg" aria-hidden="true">
      <svg class="cal-svg" viewBox="0 0 800 500" xmlns="http://www.w3.org/2000/svg">
        <!-- Líneas de cuadrícula diagonal -->
        <g stroke="#c8cdd4" stroke-width="1" opacity="0.6">
          <!-- Verticales -->
          <line x1="0"   y1="0" x2="0"   y2="500"/>
          <line x1="130" y1="0" x2="130" y2="500"/>
          <line x1="260" y1="0" x2="260" y2="500"/>
          <line x1="390" y1="0" x2="390" y2="500"/>
          <line x1="520" y1="0" x2="520" y2="500"/>
          <line x1="650" y1="0" x2="650" y2="500"/>
          <line x1="780" y1="0" x2="780" y2="500"/>
          <!-- Horizontales -->
          <line x1="0" y1="0"   x2="800" y2="0"/>
          <line x1="0" y1="125" x2="800" y2="125"/>
          <line x1="0" y1="250" x2="800" y2="250"/>
          <line x1="0" y1="375" x2="800" y2="375"/>
          <line x1="0" y1="500" x2="800" y2="500"/>
        </g>

        <!-- Texto de días/horas del calendario (rotado) -->
        <g font-family="'DM Sans', sans-serif" fill="#aab0b8" font-size="22" font-weight="600">
          <!-- Encabezados de columna (días) rotados -->
          <text x="50"  y="60" transform="rotate(-30,50,60)">May 20</text>
          <text x="180" y="40" transform="rotate(-30,180,40)">6 A</text>
          <text x="310" y="30" transform="rotate(-30,310,30)">JL</text>
          <text x="440" y="20" transform="rotate(-30,440,20)">tri</text>
          <text x="60"  y="100" transform="rotate(-30,60,100)">Ma</text>
          <text x="600" y="80" transform="rotate(-30,600,80)">Diseño de</text>
          <text x="610" y="115" transform="rotate(-30,610,115)">la página</text>
          <text x="625" y="148" transform="rotate(-30,625,148)">15:00</text>
          <text x="490" y="340" transform="rotate(-30,490,340)">Llamar</text>
          <text x="498" y="372" transform="rotate(-30,498,372)">al cliente</text>
          <text x="510" y="404" transform="rotate(-30,510,404)">9:30</text>
          <text x="240" y="310" transform="rotate(-30,240,310)">Revisión</text>
          <text x="250" y="342" transform="rotate(-30,250,342)">del</text>
          <text x="242" y="374" transform="rotate(-30,242,374)">proyecto</text>
          <text x="248" y="406" transform="rotate(-30,248,406)">10:00</text>
        </g>

        <!-- Horas laterales -->
        <g font-family="'DM Sans', sans-serif" fill="#aab0b8" font-size="18">
          <text x="130" y="370">9:00</text>
          <text x="130" y="460">10:00</text>
          <text x="260" y="460">10</text>
          <text x="0"   y="460">10:00</text>
        </g>

        <!-- Corchete esquina inferior izquierda -->
        <g stroke="#aab0b8" stroke-width="2.5" fill="none">
          <polyline points="80,290 65,290 65,310"/>
          <polyline points="110,290 110,290"/>
        </g>
      </svg>
      <!-- Overlay blanco semitransparente -->
      <div class="cal-overlay"></div>
    </div>

    <!-- Card de login -->
    <div class="login-card">

      <!-- Header -->
      <div class="login-header">
        <span class="header-icon">
          <!-- Icono calendario con color teal -->
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
            <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
            <line x1="16" y1="2" x2="16" y2="6"></line>
            <line x1="8"  y1="2" x2="8"  y2="6"></line>
            <line x1="3"  y1="10" x2="21" y2="10"></line>
          </svg>
        </span>
        INICIAR SESION
      </div>

      <!-- Error -->
      <div id="error-message" class="error-msg hidden">
        <!-- mensaje -->
      </div>

      <form id="login-form" class="login-form">

        <!-- Email -->
        <div class="input-group">
          <label class="input-label">Correo</label>
          <div class="input-wrap">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#6b7280" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="4"></circle>
              <path d="M16 8v5a3 3 0 0 0 6 0v-1a10 10 0 1 0-3.92 7.94"></path>
            </svg>
            <input
              type="email"
              name="email"
              placeholder=""
              required
              class="input-field"
            />
          </div>
        </div>

        <!-- Password -->
        <div class="input-group">
          <label class="input-label">Contraseña</label>
          <div class="input-wrap">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#6b7280" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect>
              <path d="M7 11V7a5 5 0 0 1 10 0v4"></path>
            </svg>
            <input
              type="password"
              name="password"
              placeholder=""
              required
              minlength="8"
              class="input-field"
            />
          </div>
        </div>

        <!-- Olvidé contraseña -->
        <div class="forgot-wrap">
          <a href="/recuperarcontrasena" class="forgot-link">
            ¿Olvidó su contraseña?
          </a>
        </div>

        

        <!-- Botón submit -->
        <button type="submit" class="btn-submit">
          INICIAR SESIÓN
        </button>

      </form>

      <p class="register-link">
        ¿No tienes cuenta?
        <a href="/registro">Crear cuenta</a>
      </p>

    </div>
  </div>

</Layout>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const formElement = document.getElementById('login-form');
    const errorDiv    = document.getElementById('error-message');

    if (!formElement || !errorDiv) return;

    const form = formElement as HTMLFormElement;

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      errorDiv.classList.add('hidden');
      errorDiv.textContent = '';

      const formData = new FormData(form);

      try {
        const response = await fetch('/api/login', {
          method: 'POST',
          body: formData,
        });

        const data = await response.json();

        if (data.success) {
          window.location.href = '/dashboard';
        } else {
          errorDiv.textContent = data.message || 'Error al iniciar sesión';
          errorDiv.classList.remove('hidden');
        }
      } catch (err) {
        errorDiv.textContent = 'Error de conexión. Intenta más tarde.';
        errorDiv.classList.remove('hidden');
        console.error(err);
      }
    });
  });
</script>