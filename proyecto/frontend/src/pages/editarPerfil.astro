---
// Importamos los estilos desde la misma carpeta
import '../styles/editarPerfil.css';
import '../styles/global.css';
import Layout from "../layouts/Layout.astro";
---


<div class="profile-menu-container real-dashboard-position">
  <button id="profile-trigger" class="profile-btn" aria-label="Abrir menú de perfil">
    <img id="profile-photo" src="/tu-foto.jpg" alt="Perfil" />
  </button>

  <div id="profile-popover" class="popover hidden">
    <div class="popover-header">
      <img id="popover-photo" src="/tu-foto.jpg" alt="Perfil" class="popover-avatar" />
      <div class="user-info">
        <span id="display-user-name" class="user-name">Alex Sebastian Saldaña Palomino</span>
        <span class="user-handle">@alexsaldana</span>
        <a href="/perfil" class="view-profile-link">Ver tu perfil</a>
      </div>
    </div>
    
    <hr class="divider" />
    
    <div class="popover-body">
      <button id="btn-edit-profile" class="menu-item">
        <svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"></path></svg>
        Editar perfil
      </button>
      
      <button id="btn-pending-tasks" class="menu-item pending-tasks">
        <svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg>
        Tareas Pendientes
        <span class="badge">3</span>
      </button>
      
      <hr class="divider" />
      
      <button id="btn-switch-account" class="menu-item">
        <svg class="icon" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12.07 7a4 4 0 1 1 0 8 4 4 0 0 1 0-8zm0 10c2.67 0 8 1.33 8 4v2H4v-2c0-2.67 5.33-4 8-4zm7-9a2.5 2.5 0 1 1 0 5a2.5 2.5 0 0 1 0-5zm0 7c.83 0 2.5.42 2.5 1.25v2.25H16.5v-2.25c0-.83 1.67-1.25 2.5-1.25z"></path>
        </svg>
        Cambiar de cuenta
        <span class="arrow-right">›</span>
      </button>
      
      <button id="btn-logout" class="menu-item logout">
        <svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"></path><polyline points="16 17 21 12 16 7"></polyline><line x1="21" y1="12" x2="9" y2="12"></line></svg>
        Cerrar sesión
      </button>
    </div>
  </div>
</div>

<div id="modal-editar-perfil" class="ep-modal-backdrop hidden">
  <div class="ep-modal-box">
    <h3 class="ep-modal-title">Editar Perfil</h3>
    <form id="form-editar-perfil">
      <div class="ep-form-group">
        <label for="ep-input-nombre" class="ep-label">Nombre completo</label>
        <input type="text" id="ep-input-nombre" value="Alex Sebastian Saldaña Palomino" class="ep-input" />
      </div>
      <div class="ep-form-group">
        <label for="ep-input-foto" class="ep-label">Nueva foto de perfil</label>
        <input type="file" id="ep-input-foto" accept="image/*" class="ep-input ep-file-input" />
      </div>
      <div class="ep-modal-actions">
        <button type="submit" id="ep-btn-guardar" class="ep-btn-submit">Guardar cambios</button>
        <button type="button" id="ep-btn-cancelar" class="ep-btn-cancel">Cancelar</button>
      </div>
    </form>
  </div>
</div>

<div id="modal-tareas-pendientes" class="ep-modal-backdrop hidden">
  <div class="ep-modal-box">
    <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom: 20px;">
      <h3 class="ep-modal-title" style="margin:0;">Tareas Pendientes</h3>
      <span class="badge" style="margin:0; font-size: 0.85rem; padding: 4px 10px;">3</span>
    </div>
    
    <div class="tp-list">
      <div class="tp-item">
        <div class="tp-dot" style="background-color: #ef4444;"></div>
        <div class="tp-text">Terminar componente Astro</div>
      </div>
      <div class="tp-item">
        <div class="tp-dot" style="background-color: #f59e0b;"></div>
        <div class="tp-text">Revisar correos pendientes</div>
      </div>
      <div class="tp-item">
        <div class="tp-dot" style="background-color: #0ea5e9;"></div>
        <div class="tp-text">Actualizar base de datos local</div>
      </div>
    </div>

    <div class="ep-modal-actions" style="margin-top: 24px;">
      <button type="button" id="tp-btn-cerrar" class="ep-btn-cancel">Cerrar</button>
    </div>
  </div>
</div>

<script src="../pages/api/editarPerfil.ts"></script>