---
export const prerender = false;
import '../styles/recuperarcontrasena.css';
---

<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Recuperar contraseña — My Agenda</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
</head>
<body>

  <nav class="navbar">
    <a href="/" class="navbar-logo">
      <img src="/logo.svg" alt="My Agenda" width="28" height="28" style="border-radius:7px;display:block;flex-shrink:0;" />
      <span class="navbar-logo-text">My Agenda</span>
    </a>
  </nav>

  <main class="pagina">
    <div class="tarjeta">

      <div class="encabezado">
        <div class="burbuja">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
            <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
          </svg>
        </div>
        <h1>Recuperar contraseña</h1>
        <p>Verifica tu identidad para volver a<br/>acceder a tu cuenta.</p>
      </div>

      <!-- Indicador de pasos -->
      <div class="pasos">
        <div class="paso activo" id="paso-1">
          <div class="paso-circulo">1</div>
          <span class="paso-label">Método</span>
        </div>
        <div class="paso-linea"></div>
        <div class="paso" id="paso-2">
          <div class="paso-circulo">2</div>
          <span class="paso-label">Código</span>
        </div>
        <div class="paso-linea"></div>
        <div class="paso" id="paso-3">
          <div class="paso-circulo">3</div>
          <span class="paso-label">Nueva</span>
        </div>
      </div>

      <!-- PANEL 1: Elegir método -->
      <div class="panel activo" id="panel-1">
        <div class="campo" id="campo-correo">
          <label for="input-correo">Correo electrónico</label>
          <div class="wrap-input">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#9ca3af" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
            <input type="email" id="input-correo" placeholder="tu@correo.com" autocomplete="email" />
          </div>
        </div>

        <button class="btn-ok" id="btn-enviar" type="button">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
          Enviar código de verificación
        </button>

        <div class="ir-login">¿Recordaste tu contraseña? <a href="/login">Iniciar sesión</a></div>
      </div>

      <!-- PANEL 2: Verificar OTP -->
      <div class="panel" id="panel-2">
        <button class="btn-volver" id="btn-volver-paso1" type="button">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M19 12H5"/><path d="M12 19l-7-7 7-7"/></svg>
          Volver
        </button>

        <div class="mascara">
          <div class="punto"></div>
          <span id="texto-mascara">Código enviado…</span>
        </div>

        <div class="campo">
          <label>Código de 6 dígitos</label>
          <div class="otp-fila" id="otp-fila">
            <input class="otp-caja" type="text" inputmode="numeric" maxlength="1" autocomplete="off" />
            <input class="otp-caja" type="text" inputmode="numeric" maxlength="1" autocomplete="off" />
            <input class="otp-caja" type="text" inputmode="numeric" maxlength="1" autocomplete="off" />
            <input class="otp-caja" type="text" inputmode="numeric" maxlength="1" autocomplete="off" />
            <input class="otp-caja" type="text" inputmode="numeric" maxlength="1" autocomplete="off" />
            <input class="otp-caja" type="text" inputmode="numeric" maxlength="1" autocomplete="off" />
          </div>

          <div class="timer-row">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="#6b7280" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            Expira en <strong id="timer">3:00</strong>
          </div>
        </div>

        <button class="btn-ok" id="btn-verificar" type="button" disabled>
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
          Verificar código
        </button>

        <button class="btn-reenviar" id="btn-reenviar" type="button" disabled>
          Reenviar código <span id="reenviar-timer"></span>
        </button>
      </div>

      <!-- PANEL 3: Nueva contraseña -->
      <div class="panel" id="panel-3">
        <div class="campo">
          <label for="input-nueva">Nueva contraseña</label>
          <div class="wrap-input wrap-input--pass">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#9ca3af" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
            <input type="password" id="input-nueva" placeholder="Mínimo 8 caracteres" autocomplete="new-password" />
            <button type="button" class="btn-ojo" id="ojo-nueva" aria-label="Mostrar contraseña">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
            </button>
          </div>
          <div class="pass-strength" id="pass-strength"></div>
        </div>
        <div class="campo">
          <label for="input-confirmar">Confirmar contraseña</label>
          <div class="wrap-input wrap-input--pass">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#9ca3af" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
            <input type="password" id="input-confirmar" placeholder="Repite la contraseña" autocomplete="new-password" />
            <button type="button" class="btn-ojo" id="ojo-confirmar" aria-label="Mostrar contraseña">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
            </button>
          </div>
          <p class="msg" id="msg-confirmar"></p>
        </div>
        <button class="btn-ok" id="btn-guardar" type="button" disabled>
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/><polyline points="17 21 17 13 7 13 7 21"/><polyline points="7 3 7 8 15 8"/></svg>
          Guardar nueva contraseña
        </button>
      </div>

      <!-- PANEL 4: Éxito -->
      <div class="panel" id="panel-4">
        <div class="panel-exito">
          <div class="exito-icono">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
          </div>
          <h2>¡Contraseña actualizada!</h2>
          <p>Ya puedes iniciar sesión con tu nueva contraseña.</p>
          <a href="/login"><button class="btn-ok" type="button">Ir a iniciar sesión</button></a>
        </div>
      </div>

    </div>
  </main>

  <!-- Contenedor de toasts -->
  <div id="rc-toast-container" class="rc-toast-container"></div>

  <script is:inline>
    // ── Estado ────────────────────────────────────────────────────
    let metodoActual     = 'email';
    let contactoActual   = '';
    let otpToken         = '';   // token firmado que contiene el OTP (viene del servidor)
    let resetToken       = '';   // token para cambiar la clave (viene tras verificar OTP)
    let timerInterval    = null;
    let reenviarInterval = null;

    // ── Toast ─────────────────────────────────────────────────────
    function mostrarToast(titulo, subtitulo, tipo = 'success') {
      const container = document.getElementById('rc-toast-container');
      const claseExtra =
        tipo === 'error'   ? ' rc-toast--error'   :
        tipo === 'warning' ? ' rc-toast--warning'  :
        tipo === 'info'    ? ' rc-toast--info'     : '';

      const iconSvg =
        tipo === 'error' || tipo === 'warning'
          ? `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>`
          : tipo === 'info'
          ? `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg>`
          : `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>`;

      const toast = document.createElement('div');
      toast.className = `rc-toast${claseExtra}`;
      toast.innerHTML = `
        <div class="rc-toast-icon">${iconSvg}</div>
        <div class="rc-toast-body">
          <div class="rc-toast-title">${titulo}</div>
          <div class="rc-toast-sub">${subtitulo}</div>
        </div>
        <button class="rc-toast-close" title="Cerrar">✕</button>
      `;
      toast.querySelector('.rc-toast-close').addEventListener('click', () => cerrarToast(toast));
      container.appendChild(toast);
      setTimeout(() => cerrarToast(toast), 4500);
    }

    function cerrarToast(toast) {
      toast.classList.add('rc-toast--out');
      toast.addEventListener('animationend', () => toast.remove(), { once: true });
    }

    // ── Cambiar paso ──────────────────────────────────────────────
    function irAPaso(num) {
      document.querySelectorAll('.panel').forEach(p => p.classList.remove('activo'));
      document.getElementById('panel-' + num).classList.add('activo');
      for (let i = 1; i <= 3; i++) {
        const el = document.getElementById('paso-' + i);
        if (!el) continue;
        el.classList.remove('activo', 'completado');
        if (i < num)      el.classList.add('completado');
        else if (i === num) el.classList.add('activo');
      }
    }

    // ── PASO 1: Enviar código ─────────────────────────────────────
    document.getElementById('btn-enviar').addEventListener('click', enviarCodigo);
    document.getElementById('input-correo').addEventListener('keydown', e => { if (e.key === 'Enter') enviarCodigo(); });

    async function enviarCodigo() {
      const emailVal = document.getElementById('input-correo').value.trim();

      if (!emailVal) {
        mostrarToast('Campo requerido', 'Ingresa tu correo electrónico.', 'error');
        document.getElementById('input-correo').focus();
        return;
      }

      contactoActual = emailVal;

      const btn = document.getElementById('btn-enviar');
      btn.innerHTML = '<span class="btn-spinner"></span> Enviando…';
      btn.disabled = true;

      try {
        const body = { accion: 'enviar_codigo', metodo: 'email', email: emailVal };

        const res  = await fetch('/api/recuperarcontrasena', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(body)
        });
        const data = await res.json();

        if (!res.ok) {
          mostrarToast('No se pudo enviar', data.error || 'Verifica los datos ingresados.', 'error');
          return;
        }

        otpToken = data.otpToken;
        document.getElementById('texto-mascara').textContent =
          `Código enviado a ${data.destino}`;
        irAPaso(2);
        iniciarTemporizador(180);
        iniciarReenviar(50);

        mostrarToast('Código enviado', 'Revisa tu bandeja de entrada.', 'info');

      } catch {
        mostrarToast('Error de conexión', 'Verifica tu red e intenta de nuevo.', 'error');
      } finally {
        btn.innerHTML = '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg> Enviar código de verificación';
        btn.disabled = false;
      }
    }

    // ── OTP inputs ────────────────────────────────────────────────
    const otpInputs = document.querySelectorAll('.otp-caja');
    otpInputs.forEach((input, index) => {
      input.addEventListener('input', () => {
        input.value = input.value.replace(/[^0-9]/g, '');
        if (input.value && index < 5) otpInputs[index + 1].focus();
        document.getElementById('btn-verificar').disabled =
          !Array.from(otpInputs).every(i => i.value);
      });
      input.addEventListener('keydown', e => {
        if (e.key === 'Backspace' && !input.value && index > 0)
          otpInputs[index - 1].focus();
      });
      input.addEventListener('paste', e => {
        e.preventDefault();
        const text = (e.clipboardData?.getData('text') ?? '').replace(/\D/g, '').slice(0, 6);
        [...text].forEach((ch, i) => { if (otpInputs[i]) otpInputs[i].value = ch; });
        const next = Math.min(text.length, 5);
        otpInputs[next]?.focus();
        document.getElementById('btn-verificar').disabled =
          !Array.from(otpInputs).every(i => i.value);
      });
    });

    // ── PASO 2: Verificar código ──────────────────────────────────
    document.getElementById('btn-verificar').addEventListener('click', verificarCodigo);
    document.getElementById('btn-volver-paso1').addEventListener('click', () => {
      detenerTemporizador(); irAPaso(1);
    });

    async function verificarCodigo() {
      const codigo = Array.from(otpInputs).map(i => i.value).join('');
      const btn    = document.getElementById('btn-verificar');
      btn.innerHTML = '<span class="btn-spinner"></span> Verificando…';
      btn.disabled = true;

      try {
        const body = { accion: 'verificar_codigo', otpToken, codigo };

        const res  = await fetch('/api/recuperarcontrasena', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(body)
        });
        const data = await res.json();

        if (!res.ok) {
          mostrarToast('Código incorrecto', data.error || 'Verifica el código e intenta de nuevo.', 'error');
          otpInputs.forEach(i => { i.value = ''; i.classList.add('otp-error'); });
          otpInputs[0].focus();
          setTimeout(() => otpInputs.forEach(i => i.classList.remove('otp-error')), 600);
          btn.disabled = false;
          btn.innerHTML = '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg> Verificar código';
          return;
        }

        resetToken = data.resetToken;
        detenerTemporizador();
        irAPaso(3);
        document.getElementById('input-nueva').focus();

      } catch {
        mostrarToast('Error de conexión', 'Verifica tu red e intenta de nuevo.', 'error');
        btn.disabled = false;
        btn.innerHTML = '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg> Verificar código';
      }
    }

    // ── Reenviar código ───────────────────────────────────────────
    document.getElementById('btn-reenviar').addEventListener('click', async () => {
      const btn = document.getElementById('btn-reenviar');
      btn.disabled = true;
      try {
        const body = { accion: 'enviar_codigo', metodo: 'email', email: contactoActual };
        const res  = await fetch('/api/recuperarcontrasena', {
          method: 'POST', headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(body)
        });
        const data = await res.json();
        if (res.ok) {
          otpToken = data.otpToken;
          otpInputs.forEach(i => i.value = '');
          iniciarTemporizador(180);
          iniciarReenviar(50);
          otpInputs[0].focus();
          mostrarToast('Código reenviado', 'Se envió un nuevo código.', 'info');
        } else {
          mostrarToast('Error', data.error || 'No se pudo reenviar.', 'error');
          btn.disabled = false;
        }
      } catch {
        mostrarToast('Error de conexión', 'Verifica tu red.', 'error');
        btn.disabled = false;
      }
    });

    // ── PASO 3: Nueva contraseña ──────────────────────────────────
    document.getElementById('input-nueva').addEventListener('input', verificarConfirmacion);
    document.getElementById('input-confirmar').addEventListener('input', verificarConfirmacion);

    function verificarConfirmacion() {
      const p1  = document.getElementById('input-nueva').value;
      const p2  = document.getElementById('input-confirmar').value;
      const btn = document.getElementById('btn-guardar');
      const msg = document.getElementById('msg-confirmar');

      // Indicador de fortaleza
      const strengthEl = document.getElementById('pass-strength');
      if (p1.length === 0) {
        strengthEl.innerHTML = '';
      } else {
        const nivel = p1.length < 8 ? 0 : p1.length < 12 ? 1 : /[A-Z]/.test(p1) && /[0-9]/.test(p1) && /[^A-Za-z0-9]/.test(p1) ? 3 : 2;
        const labels = ['Muy corta', 'Débil', 'Aceptable', 'Fuerte'];
        const colors = ['#ef4444', '#f59e0b', '#3b82f6', '#22c55e'];
        const widths = ['25%', '50%', '75%', '100%'];
        strengthEl.innerHTML = `
          <div class="strength-bar"><div style="width:${widths[nivel]};background:${colors[nivel]};height:100%;border-radius:4px;transition:width .3s,background .3s"></div></div>
          <span style="font-size:11px;color:${colors[nivel]};font-weight:600">${labels[nivel]}</span>
        `;
      }

      if (!p2) { msg.textContent = ''; btn.disabled = true; return; }
      if (p1 === p2 && p1.length >= 8) {
        msg.className   = 'msg msg-ok';
        msg.innerHTML   = '<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg> Las contraseñas coinciden';
        btn.disabled = false;
      } else {
        msg.className   = 'msg msg-err';
        msg.innerHTML   = p1.length < 8
          ? '<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg> Mínimo 8 caracteres'
          : '<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg> No coinciden';
        btn.disabled = true;
      }
    }

    document.getElementById('btn-guardar').addEventListener('click', guardarContrasena);

    async function guardarContrasena() {
      const nuevaClave = document.getElementById('input-nueva').value;
      const btn        = document.getElementById('btn-guardar');
      btn.innerHTML    = '<span class="btn-spinner"></span> Guardando…';
      btn.disabled     = true;

      try {
        const res  = await fetch('/api/recuperarcontrasena', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ accion: 'actualizar_contrasena', nuevaContrasena: nuevaClave, resetToken })
        });
        const data = await res.json();

        if (!res.ok) {
          mostrarToast('Error', data.error || 'No se pudo actualizar la contraseña.', 'error');
          btn.disabled = false;
          btn.innerHTML = '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/><polyline points="17 21 17 13 7 13 7 21"/><polyline points="7 3 7 8 15 8"/></svg> Guardar nueva contraseña';
          return;
        }

        irAPaso(4);

      } catch {
        mostrarToast('Error de conexión', 'Verifica tu red e intenta de nuevo.', 'error');
        btn.disabled = false;
        btn.innerHTML = 'Guardar nueva contraseña';
      }
    }

    // ── Temporizadores ────────────────────────────────────────────
    function iniciarTemporizador(segundos) {
      let s = segundos;
      const display = document.getElementById('timer');
      if (timerInterval) clearInterval(timerInterval);
      timerInterval = setInterval(() => {
        s--;
        const m = Math.floor(s / 60);
        const sec = (s % 60).toString().padStart(2, '0');
        display.textContent = `${m}:${sec}`;
        if (s <= 0) {
          clearInterval(timerInterval);
          display.textContent = '0:00';
          display.style.color = '#ef4444';
        }
      }, 1000);
    }

    function iniciarReenviar(segundos) {
      let s = segundos;
      const btn  = document.getElementById('btn-reenviar');
      const span = document.getElementById('reenviar-timer');
      btn.disabled = true;
      if (reenviarInterval) clearInterval(reenviarInterval);
      reenviarInterval = setInterval(() => {
        s--;
        span.textContent = `(${s}s)`;
        if (s <= 0) {
          clearInterval(reenviarInterval);
          span.textContent = '';
          btn.disabled = false;
        }
      }, 1000);
    }

    function detenerTemporizador() {
      if (timerInterval)  { clearInterval(timerInterval);  timerInterval  = null; }
      if (reenviarInterval) { clearInterval(reenviarInterval); reenviarInterval = null; }
    }

    // ── Mostrar/ocultar contraseña ────────────────────────────────
    const SVG_OJO_ABIERTO = `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>`;
    const SVG_OJO_CERRADO = `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24"/><line x1="1" y1="1" x2="23" y2="23"/></svg>`;

    function toggleOjo(inputId, btnId) {
      const input   = document.getElementById(inputId);
      const btn     = document.getElementById(btnId);
      const mostrar = input.type === 'password';
      input.type    = mostrar ? 'text' : 'password';
      btn.innerHTML = mostrar ? SVG_OJO_CERRADO : SVG_OJO_ABIERTO;
      btn.setAttribute('aria-label', mostrar ? 'Ocultar contraseña' : 'Mostrar contraseña');
    }

    document.getElementById('ojo-nueva').addEventListener('mousedown',     e => { e.preventDefault(); toggleOjo('input-nueva',     'ojo-nueva'); });
    document.getElementById('ojo-confirmar').addEventListener('mousedown', e => { e.preventDefault(); toggleOjo('input-confirmar', 'ojo-confirmar'); });
  </script>

</body>
</html>
