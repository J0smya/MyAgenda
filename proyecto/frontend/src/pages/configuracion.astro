---
import '../styles/global.css'
import Layout from "../layouts/Layout.astro";
import '../styles/configuracion.css';
---

<Layout title="Configuración | My Agenda">
  <div class="config-wrapper">

    <header class="config-header">
      <a href="/" class="btn-volver">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
        Volver al Inicio
      </a>
      <h1 class="config-title">Configuración General</h1>
      <p class="config-subtitle">Personaliza tu experiencia y administra tus datos de My Agenda.</p>
    </header>

    <div class="config-grid">

      <!-- EDITAR PERFIL -->
      <section class="config-card">
        <div class="card-header">
          <span class="card-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#0ea5e9" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
          </span>
          <h2>Editar Perfil</h2>
        </div>
        <div class="card-body">
          <div class="form-group">
            <label>Foto de perfil</label>
            <div class="avatar-upload-container">
              <div class="avatar-preview" id="avatar-preview-circulo">A</div>
              <button type="button" class="btn-primary" id="btn-cambiar-foto">Cambiar foto</button>
              <input type="file" id="input-foto" accept="image/*" class="hidden">
            </div>
          </div>
          <div class="form-group">
            <label>Nombre completo</label>
            <input
              type="text"
              id="input-nombre"
              class="config-input"
              placeholder="Ingresa tu nombre completo"
              value="Alex Sebastian Saldaña Palomino"
            >
            <span id="error-nombre" class="config-error-msg">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
              El nombre debe tener al menos 1 carácter.
            </span>
          </div>
        </div>
      </section>

    <!-- PREFERENCIAS -->
<section class="config-card">
  <div class="card-header">
    <span class="card-icon">
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#0ea5e9" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="4" rx="2" ry="2"/><line x1="16" x2="16" y1="2" y2="6"/><line x1="8" x2="8" y1="2" y2="6"/><line x1="3" x2="21" y1="10" y2="10"/></svg>
    </span>
    <h2>Preferencias de la Agenda</h2>
  </div>
  <div class="card-body">
    <div class="form-group">
      <label>Vista predeterminada al iniciar</label>
      <select id="select-vista" class="config-input">
        <option value="dia">Vista de Día</option>
        <option value="semana">Vista de Semana</option>
        <option value="mes">Vista de Mes</option>
      </select>
    </div>
  </div>
</section>

      <!-- NOTIFICACIONES -->
      <section class="config-card">
        <div class="card-header">
          <span class="card-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#0ea5e9" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 8a6 6 0 0 1 12 0c0 7 3 9 3 9H3s3-2 3-9"/><path d="M10.3 21a1.94 1.94 0 0 0 3.4 0"/></svg>
          </span>
          <h2>Notificaciones y Recordatorios</h2>
        </div>
        <div class="card-body">
          <div class="form-group">
            <label>Tiempo de aviso predeterminado</label>
            <select id="select-aviso" class="config-input">
              <option value="5">5 minutos antes</option>
              <option value="15">15 minutos antes</option>
              <option value="30">30 minutos antes</option>
              <option value="60">1 hora antes</option>
            </select>
          </div>
          <div class="form-toggle">
            <label class="toggle-label">
              <span>Reproducir sonido con las notificaciones</span>
              <input type="checkbox" id="check-sonido" class="toggle-checkbox" checked>
              <div class="toggle-switch"></div>
            </label>
          </div>
        </div>
      </section>

      <!-- DATOS PRIVADOS -->
      <section class="config-card danger-zone-container">
        <div class="card-header">
          <span class="card-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#64748b" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/><polyline points="17 21 17 13 7 13 7 21"/><polyline points="7 3 7 8 15 8"/></svg>
          </span>
          <h2>Gestión de Datos Privados</h2>
        </div>
        <div class="card-body">
          <div class="data-action">
            <div class="data-info">
              <h3>Exportar mis datos</h3>
              <p>Descarga un archivo con todas tus tareas y notas actuales.</p>
            </div>
            <button id="btn-exportar" class="btn-primary">Descargar Datos</button>
          </div>

          <hr class="config-divider">

          <div class="data-action">
            <div class="data-info">
              <h3 class="danger-text">Borrar tareas completadas</h3>
              <p>Esta acción limpiará tu calendario y no se puede deshacer.</p>
            </div>
            <button id="btn-borrar-todo" class="btn-danger">Eliminar Tareas</button>
          </div>
        </div>
      </section>

    </div>

    <div class="config-footer">
      <button id="btn-guardar-config" class="btn-guardar-config">Guardar cambios</button>
    </div>

  </div>
</Layout>

<script src="../pages/api/configuracion.ts"></script>