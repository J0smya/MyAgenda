---
import '../styles/global.css'
import '../styles/registro.css'
import Layout from "../layouts/Layout.astro";
---

<Layout title="Registro">
  <div class="page">

    <!-- ── Fondo dispositivos ── -->
    <div class="bg-devices" aria-hidden="true">
      <div class="tablet">
        <div class="tablet__screen">
          <p class="tablet__notes">Notes</p>
          <div class="tablet__search">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none"
                 stroke="currentColor" stroke-width="2.5">
              <circle cx="11" cy="11" r="8"></circle>
              <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
            </svg>
            Search
          </div>
          <div class="tablet__lines">
            <div class="line"></div>
            <div class="line"></div>
            <div class="line"></div>
            <div class="line line--short"></div>
          </div>
        </div>
      </div>

      <div class="panel">
        <svg class="panel__icon" width="20" height="20" viewBox="0 0 24 24"
             fill="none" stroke="white" stroke-width="2">
          <rect x="3" y="3" width="7" height="7"></rect>
          <rect x="14" y="3" width="7" height="7"></rect>
          <rect x="3" y="14" width="7" height="7"></rect>
          <rect x="14" y="14" width="7" height="7"></rect>
        </svg>
      </div>

      <div class="bg-overlay"></div>
    </div>

    <!-- ── Card ── -->
    <div class="card">

      <!-- Header -->
      <div class="card__header">
        <span class="card__header-icon">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none"
               stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <rect x="3" y="4" width="18" height="18" rx="2"></rect>
            <line x1="16" y1="2" x2="16" y2="6"></line>
            <line x1="8"  y1="2" x2="8"  y2="6"></line>
            <line x1="3"  y1="10" x2="21" y2="10"></line>
          </svg>
        </span>
        CREAR CUENTA
      </div>

      <!-- ── Toast error ── -->
      <div class="toast toast--error" id="toast-error" aria-live="polite">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none"
             stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="10"></circle>
          <line x1="12" y1="8" x2="12" y2="12"></line>
          <line x1="12" y1="16" x2="12.01" y2="16"></line>
        </svg>
        <span id="toast-msg"></span>
      </div>

      <!-- ── Toast éxito ── -->
      <div class="toast toast--success" id="toast-success" aria-live="polite">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none"
             stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="20 6 9 17 4 12"></polyline>
        </svg>
        <span>Cuenta creada. Redirigiendo…</span>
      </div>

      <form id="registro-form" class="form" novalidate>

        <!-- Nombre -->
        <div class="field" id="field-name">
          <span class="field__label">Nombre</span>
          <div class="field__wrap">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none"
                 stroke="#6b7280" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
              <circle cx="12" cy="7" r="4"></circle>
            </svg>
            <input type="text" name="name" required class="field__input" placeholder="Tu nombre completo" />
          </div>
          <span class="field__error" id="err-name"></span>
        </div>

        <!-- Correo -->
        <div class="field" id="field-email">
          <span class="field__label">Correo</span>
          <div class="field__wrap">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none"
                 stroke="#6b7280" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="4"></circle>
              <path d="M16 8v5a3 3 0 0 0 6 0v-1a10 10 0 1 0-3.92 7.94"></path>
            </svg>
            <input type="email" name="email" required class="field__input" placeholder="correo@ejemplo.com" />
          </div>
          <span class="field__error" id="err-email"></span>
        </div>

        <!-- Contraseña -->
        <div class="field" id="field-password">
          <span class="field__label">Contraseña</span>
          <div class="field__wrap">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none"
                 stroke="#6b7280" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect x="3" y="11" width="18" height="11" rx="2"></rect>
              <path d="M7 11V7a5 5 0 0 1 10 0v4"></path>
            </svg>
            <input type="password" name="password" required minlength="8"
                   class="field__input" placeholder="Mínimo 8 caracteres" />
            <button type="button" class="field__toggle" id="toggle-pass"
                    aria-label="Mostrar contraseña" tabindex="-1">
              <svg id="eye-open" width="14" height="14" viewBox="0 0 24 24" fill="none"
                   stroke="#6b7280" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path>
                <circle cx="12" cy="12" r="3"></circle>
              </svg>
              <svg id="eye-closed" width="14" height="14" viewBox="0 0 24 24" fill="none"
                   stroke="#6b7280" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
                   style="display:none">
                <path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94"></path>
                <path d="M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19"></path>
                <line x1="1" y1="1" x2="23" y2="23"></line>
              </svg>
            </button>
          </div>
          <span class="field__error" id="err-password"></span>
        </div>

        <!-- Teléfono -->
        <div class="field" id="field-telefono">
          <span class="field__label">Teléfono</span>
          <div class="field__wrap">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none"
                 stroke="#6b7280" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.61 3.4 2 2 0 0 1 3.6 1.21h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.77a16 16 0 0 0 6.29 6.29l.87-.87a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"></path>
            </svg>
            <input type="tel" name="telefono" class="field__input" placeholder="+57 300 000 0000" />
          </div>
          <span class="field__error" id="err-telefono"></span>
        </div>

        <!-- Términos -->
        <label class="terms">
          <input type="checkbox" required class="terms__check" id="terms-check" />
          Acepto los <a href="/terminos" class="terms__link">Términos y condiciones</a>
        </label>
        <span class="field__error" id="err-terms"></span>

        <!-- Botón -->
        <button type="submit" class="btn" id="submit-btn">
          <span id="btn-text">REGISTRAR</span>
          <span id="btn-spinner" class="btn__spinner" style="display:none"></span>
        </button>
        <p class="login-redirect">
        ¿Ya tienes una cuenta?
        <a href="/login" class="login-link">Inicia sesión</a>
        </p>

      </form>
    </div>
  </div>
</Layout>


<script>
  const form       = document.getElementById('registro-form') as HTMLFormElement;
  const submitBtn  = document.getElementById('submit-btn') as HTMLButtonElement;
  const btnText    = document.getElementById('btn-text') as HTMLSpanElement;
  const btnSpinner = document.getElementById('btn-spinner') as HTMLSpanElement;
  const toastError = document.getElementById('toast-error') as HTMLDivElement;
  const toastMsg   = document.getElementById('toast-msg') as HTMLSpanElement;
  const toastOk    = document.getElementById('toast-success') as HTMLDivElement;
  const togglePass = document.getElementById('toggle-pass') as HTMLButtonElement;
  const passInput  = form.querySelector('input[name="password"]') as HTMLInputElement;
  const eyeOpen    = document.getElementById('eye-open') as unknown as SVGElement;
  const eyeClosed  = document.getElementById('eye-closed') as unknown as SVGElement;

  // ── Toggle contraseña visible/oculta ──
  togglePass.addEventListener('click', () => {
    const show = passInput.type === 'password';
    passInput.type = show ? 'text' : 'password';
    (eyeOpen as HTMLElement).style.display   = show ? 'none' : '';
    (eyeClosed as HTMLElement).style.display = show ? ''     : 'none';
  });

  // ── Helpers ──
  function showFieldError(id: string, msg: string) {
    const el    = document.getElementById(id) as HTMLSpanElement;
    const field = el?.closest('.field') as HTMLDivElement | null;
    el.textContent = msg;
    el.classList.add('visible');
    field?.classList.add('field--invalid');
    field?.classList.remove('field--shake');
    void (field as HTMLElement)?.offsetWidth; // reflow para reiniciar animación
    field?.classList.add('field--shake');
  }

  function clearFieldError(id: string) {
    const el    = document.getElementById(id) as HTMLSpanElement;
    const field = el?.closest('.field') as HTMLDivElement | null;
    el.textContent = '';
    el.classList.remove('visible');
    field?.classList.remove('field--invalid', 'field--shake');
  }

  function showToastError(msg: string) {
    toastOk.classList.remove('toast--visible');
    toastMsg.textContent = msg;
    toastError.classList.add('toast--visible');
    setTimeout(() => toastError.classList.remove('toast--visible'), 4500);
  }

  function showToastSuccess() {
    toastError.classList.remove('toast--visible');
    toastOk.classList.add('toast--visible');
  }

  function setLoading(on: boolean) {
    submitBtn.disabled           = on;
    btnText.style.display        = on ? 'none'         : '';
    btnSpinner.style.display     = on ? 'inline-block' : 'none';
  }

  // ── Limpiar error al volver a escribir ──
  ['name', 'email', 'password', 'telefono'].forEach(name => {
    const input = form.querySelector(`input[name="${name}"]`) as HTMLInputElement;
    input?.addEventListener('input', () => clearFieldError(`err-${name}`));
  });

  // ── Submit ──
  form.addEventListener('submit', async (e) => {
    e.preventDefault();

    // Limpiar todo
    ['name', 'email', 'password', 'telefono', 'terms'].forEach(f =>
      clearFieldError(`err-${f}`)
    );
    toastError.classList.remove('toast--visible');

    const name     = (form.querySelector('input[name="name"]')     as HTMLInputElement).value.trim();
    const email    = (form.querySelector('input[name="email"]')    as HTMLInputElement).value.trim();
    const password = (form.querySelector('input[name="password"]') as HTMLInputElement).value;
    const telefono = (form.querySelector('input[name="telefono"]') as HTMLInputElement).value.trim();
    const terms    = (document.getElementById('terms-check')       as HTMLInputElement).checked;

    // ── Validación en cliente ──
    let hasError = false;
    let firstError = '';

    if (!name) {
      showFieldError('err-name', 'El nombre es obligatorio.');
      firstError ||= 'El nombre es obligatorio.';
      hasError = true;
    }

    if (!email || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
      showFieldError('err-email', 'Ingresa un correo válido.');
      firstError ||= 'Ingresa un correo válido.';
      hasError = true;
    }

    if (password.length < 8) {
      showFieldError('err-password', 'La contraseña debe tener mínimo 8 caracteres.');
      firstError ||= 'La contraseña debe tener mínimo 8 caracteres.';
      hasError = true;
    }

    // (opcional) validar teléfono
    // if (!telefono) {
    //   showFieldError('err-telefono', 'El teléfono es obligatorio.');
    //   firstError ||= 'El teléfono es obligatorio.';
    //   hasError = true;
    // }

    if (!terms) {
      showFieldError('err-terms', 'Debes aceptar los términos.');
      firstError ||= 'Debes aceptar los términos.';
      hasError = true;
    }

    if (hasError) {
      showToastError(firstError);
      return;
    }
    // ── Envío al servidor ──
    setLoading(true);
    try {
      const body = new FormData();
      body.append('name',     name);
      body.append('email',    email);
      body.append('password', password);
      body.append('telefono', telefono);

      const res = await fetch('/api/registro', { method: 'POST', body });

      if (res.ok || res.redirected) {
        showToastSuccess();
        setTimeout(() => { window.location.href = '/login'; }, 1500);
        return;
      }

      const msg = await res.text();

      // Error de correo duplicado → marcamos el campo también
      if (msg.toLowerCase().includes('correo')) {
        showFieldError('err-email', 'Este correo ya está registrado.');
      }

      showToastError(msg || 'Ocurrió un error. Intenta de nuevo.');

    } catch {
      showToastError('Sin conexión. Verifica tu red e intenta de nuevo.');
    } finally {
      setLoading(false);
    }
  });
</script>