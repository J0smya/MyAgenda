---
import Layout from "../layouts/Layout.astro";
const error = Astro.url.searchParams.get("error");
---

<Layout title="Registro">

<div class="relative min-h-screen flex items-center justify-center">

  <!-- Fondo -->
  <div class="absolute inset-0">
    <img 
      src="https://images.unsplash.com/photo-1557683316-973673baf926"
      class="w-full h-full object-cover"
      alt="background"
    />
    <div class="absolute inset-0 bg-white/70"></div>
  </div>

  <!-- Card -->
  <div class="relative w-[350px] bg-gray-200 rounded-2xl shadow-xl p-8">

    <!-- Header -->
    <div class="flex justify-center mb-6">
      <div class="bg-gray-400 text-white px-6 py-2 rounded-full font-bold shadow-md tracking-wide flex items-center gap-2">
        📘 CREAR CUENTA
      </div>
    </div>

    {error && (
      <div class="mb-4 text-center text-sm text-red-600 font-medium">
        {error}
      </div>
    )}

    <form method="POST" action="/api/registro" class="space-y-4">

      <!-- Usuario -->
      <div class="bg-gray-300 rounded-full px-4 py-2 flex items-center gap-3 shadow-inner">
        <span class="text-gray-600">👤</span>
        <input 
          type="text" 
          name="username"
          placeholder="Nombre"
          required
          class="bg-transparent w-full outline-none text-sm"
        />
      </div>

      <!-- Email -->
      <div class="bg-gray-300 rounded-full px-4 py-2 flex items-center gap-3 shadow-inner">
        <span class="text-gray-600">✉</span>
        <input 
          type="email" 
          name="email"
          placeholder="Correo"
          required
          class="bg-transparent w-full outline-none text-sm"
        />
      </div>

      <!-- Password -->
      <div class="bg-gray-300 rounded-full px-4 py-2 flex items-center gap-3 shadow-inner">
        <span class="text-gray-600">🔒</span>
        <input 
          type="password" 
          name="password"
          placeholder="Contraseña"
          required
          minlength="8"
          class="bg-transparent w-full outline-none text-sm"
        />
      </div>

      <!-- Teléfono -->
      <div class="bg-gray-300 rounded-full px-4 py-2 flex items-center gap-3 shadow-inner">
        <span class="text-gray-600">📞</span>
        <input 
          type="text" 
          name="telefono"
          placeholder="Teléfono"
          class="bg-transparent w-full outline-none text-sm"
        />
      </div>

      <!-- Términos -->
      <div class="flex items-center gap-2 text-xs text-gray-600 mt-2">
        <input type="checkbox" required />
        <span>Términos y condiciones</span>
      </div>

      <!-- Botón -->
      <button 
        type="submit"
        class="w-full mt-4 bg-black text-white py-2 rounded-full font-semibold hover:scale-105 transition duration-200"
      >
        REGISTRAR
      </button>

    </form>

  </div>
</div>

</Layout>