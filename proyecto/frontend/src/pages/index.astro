---
import '../styles/global.css'
import '../styles/landing.css'
import Layout from "../layouts/Layout.astro";
---

<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>My Agenda</title>
  </head>

  <body>
    <!-- ── NAV ── -->
    <nav class="nav">
      <a href="/" class="nav__brand">
        <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
          <line x1="16" y1="2" x2="16" y2="6"></line>
          <line x1="8" y1="2" x2="8" y2="6"></line>
          <line x1="3" y1="10" x2="21" y2="10"></line>
        </svg>
        My Agenda
      </a>
      <div class="nav__actions">
        <button class="btn-outline" onclick="window.location.href='/login'">Iniciar sesión</button>
        <button class="btn-outline" onclick="window.location.href='/registro'">Crear cuenta</button>
      </div>
    </nav>

    <!-- ── HERO ── -->
    <section class="hero">

      <!-- Columna izquierda -->
      <div class="hero__left">
        <h1 class="hero__title">Organiza tus dias,<br />en un solo lugar</h1>
        <p class="hero__subtitle">Organiza tu día, conquista tu meta.</p>
        <a href="#" class="btn-primary">Comenzar ahora</a>

        <div class="features">
          <div class="feature-item">
            <div class="feature-item__icon">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="9 11 12 14 22 4"></polyline>
                <path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"></path>
              </svg>
            </div>
            Tareas
          </div>
          <div class="feature-item">
            <div class="feature-item__icon">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
                <line x1="16" y1="2" x2="16" y2="6"></line>
                <line x1="8" y1="2" x2="8" y2="6"></line>
                <line x1="3" y1="10" x2="21" y2="10"></line>
              </svg>
            </div>
            Agenda
          </div>
          <div class="feature-item">
            <div class="feature-item__icon">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path>
                <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"></path>
              </svg>
            </div>
            Notas
          </div>
        </div>
      </div>

      <!-- Columna derecha – Mockup -->
      <div class="hero__right">
        <div class="mockup">
          <!-- Sidebar -->
          <div class="mockup__sidebar">
            <div class="mockup__sidebar-icon">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <line x1="8" y1="6" x2="21" y2="6"></line>
                <line x1="8" y1="12" x2="21" y2="12"></line>
                <line x1="8" y1="18" x2="21" y2="18"></line>
                <line x1="3" y1="6" x2="3.01" y2="6"></line>
                <line x1="3" y1="12" x2="3.01" y2="12"></line>
                <line x1="3" y1="18" x2="3.01" y2="18"></line>
              </svg>
            </div>
            <div class="mockup__sidebar-icon">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
                <polyline points="14 2 14 8 20 8"></polyline>
              </svg>
            </div>
            <div class="mockup__sidebar-icon">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <circle cx="12" cy="12" r="3"></circle>
                <path d="M19.07 4.93a10 10 0 0 1 0 14.14M4.93 4.93a10 10 0 0 0 0 14.14"></path>
              </svg>
            </div>
          </div>

          <!-- Tarjeta -->
          <div class="mockup__card">
            <h2 class="mockup__card-title">HOY</h2>

            <ul class="task-list">
              <li class="task-item">
                <div class="task-item__check--done">
                  <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3">
                    <polyline points="20 6 9 17 4 12"></polyline>
                  </svg>
                </div>
                <div>
                  <span class="task-item__name" style="text-decoration:line-through;color:#9ca3af;">Revisión proyecto</span>
                  <small class="task-item__time">10:00 AM</small>
                </div>
              </li>
              <li class="task-item">
                <div class="task-item__check--pending"></div>
                <div>
                  <span class="task-item__name">Comprar materiales</span>
                </div>
              </li>
              <li class="task-item">
                <div class="task-item__check--pending"></div>
                <div>
                  <span class="task-item__name">Llamar cliente</span>
                  <small class="task-item__time">03:00 PM</small>
                </div>
              </li>
            </ul>

            <div class="events">
              <h3 class="events__title">Próximos eventos</h3>
              <ul class="event-list">
                <li>
                  <p class="event-item__name">Reunión de equipo</p>
                  <small class="event-item__time">09:00 AM</small>
                </li>
                <li>
                  <p class="event-item__name">Almuerzo con Marta</p>
                  <small class="event-item__time">01:00 PM</small>
                </li>
                <li>
                  <p class="event-item__name">Pasear a Lola</p>
                  <small class="event-item__time">10:00 PM</small>
                </li>
              </ul>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ── PLATAFORMAS ── -->
    <div class="platforms">
      <p class="platforms__label">Disponible en todas tus plataformas favoritas</p>
      <div class="platforms__badges">
        <a href="#" class="badge">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="#3b9edd"><path d="M3 20.5v-17l17.5 8.5L3 20.5z"></path></svg>
          Google Play
        </a>
        <a href="#" class="badge">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="#555">
            <path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"></path>
          </svg>
          App Store
        </a>
        <a href="#" class="badge">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <rect x="2" y="3" width="20" height="14" rx="2" ry="2"></rect>
            <line x1="8" y1="21" x2="16" y2="21"></line>
            <line x1="12" y1="17" x2="12" y2="21"></line>
          </svg>
          Descarga Pc
        </a>
      </div>
    </div>

  </body>
</html>