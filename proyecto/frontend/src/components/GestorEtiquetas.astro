---
import GestorEtiquetas from "../components/GestorEtiquetas.astro";
---
---
// src/components/GestorEtiquetas.astro
// Componente independiente para Editar / Eliminar etiquetas
// Uso: <GestorEtiquetas /> donde quieras mostrarlo (sidebar, settings, etc.)
// NO modifica ningún archivo existente del proyecto.
---
 
<!-- Botón disparador del panel -->
<button
  id="btn-abrir-etiquetas"
  class="ge-trigger"
  title="Gestionar etiquetas"
>
  🏷️ <span>ETIQUETAS</span>
</button>
 
<!-- Overlay + Panel -->
<div id="ge-overlay" class="ge-overlay hidden">
  <div class="ge-panel" role="dialog" aria-label="Gestionar etiquetas">
 
    <!-- Cabecera -->
    <div class="ge-header">
      <div class="ge-header-left">
        <span class="ge-icon">🏷️</span>
        <h2 class="ge-title">ETIQUETAS</h2>
      </div>
      <button id="ge-close" class="ge-close-btn" aria-label="Cerrar">✕</button>
    </div>
 
    <!-- Lista de etiquetas -->
    <div id="ge-list" class="ge-list">
      <div class="ge-loading">Cargando etiquetas…</div>
    </div>
 
    <!-- Formulario de edición (se muestra al pulsar Editar) -->
    <div id="ge-form-wrap" class="ge-form-wrap hidden">
      <div class="ge-form-title">✏️ EDITAR ETIQUETA</div>
      <form id="ge-form" autocomplete="off">
        <input type="hidden" id="ge-id" />
 
        <label class="ge-label">NOMBRE
          <input type="text" id="ge-nombre" class="ge-input" required maxlength="30" placeholder="ej: trabajo" />
        </label>
 
        <label class="ge-label">COLOR
          <div class="ge-color-row">
            <input type="color" id="ge-color" class="ge-color-picker" value="#3b82f6" />
            <span id="ge-color-hex" class="ge-color-hex">#3b82f6</span>
          </div>
        </label>
 
        <label class="ge-label">ÍCONO
          <div class="ge-emoji-grid" id="ge-emoji-grid">
            <!-- Se rellena por JS -->
          </div>
          <input type="hidden" id="ge-icono" value="💼" />
        </label>
 
        <div class="ge-form-actions">
          <button type="submit" class="ge-btn-save">GUARDAR CAMBIOS</button>
          <button type="button" id="ge-cancel-edit" class="ge-btn-cancel">CANCELAR</button>
        </div>
      </form>
    </div>
 
    <!-- Mensaje de estado -->
    <div id="ge-toast" class="ge-toast hidden"></div>
  </div>
</div>
 
<style>
  /* ── Variables ── */
  :root {
    --ge-bg: #ffffff;
    --ge-dark: #0f172a;
    --ge-accent: #1e60ff;
    --ge-danger: #ef4444;
    --ge-radius: 2rem;
    --ge-panel-w: 420px;
  }
 
  /* ── Botón disparador ── */
  .ge-trigger {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: #1e293b;
    color: #94a3b8;
    border: none;
    padding: 10px 20px;
    border-radius: 999px;
    font-size: 10px;
    font-weight: 900;
    font-style: italic;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    cursor: pointer;
    transition: background 0.2s, color 0.2s, transform 0.15s;
  }
  .ge-trigger:hover {
    background: var(--ge-accent);
    color: white;
    transform: scale(1.04);
  }
 
  /* ── Overlay ── */
  .ge-overlay {
    position: fixed;
    inset: 0;
    background: rgba(15, 23, 42, 0.65);
    backdrop-filter: blur(8px);
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 9999;
    padding: 16px;
    animation: ge-fade-in 0.2s ease;
  }
  .ge-overlay.hidden { display: none !important; }
 
  @keyframes ge-fade-in {
    from { opacity: 0; }
    to   { opacity: 1; }
  }
 
  /* ── Panel ── */
  .ge-panel {
    background: var(--ge-bg);
    width: 100%;
    max-width: var(--ge-panel-w);
    border-radius: var(--ge-radius);
    padding: 32px;
    box-shadow: 0 40px 80px rgba(0,0,0,0.25);
    display: flex;
    flex-direction: column;
    gap: 20px;
    animation: ge-slide-up 0.25s cubic-bezier(.22,1,.36,1);
    max-height: 90vh;
    overflow-y: auto;
  }
  @keyframes ge-slide-up {
    from { transform: translateY(32px); opacity: 0; }
    to   { transform: translateY(0);    opacity: 1; }
  }
 
  /* ── Cabecera ── */
  .ge-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .ge-header-left { display: flex; align-items: center; gap: 12px; }
  .ge-icon { font-size: 24px; }
  .ge-title {
    font-size: 18px;
    font-weight: 900;
    font-style: italic;
    text-transform: uppercase;
    letter-spacing: -0.04em;
    color: var(--ge-dark);
    margin: 0;
  }
  .ge-close-btn {
    background: #f1f5f9;
    border: none;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    font-size: 14px;
    cursor: pointer;
    color: #64748b;
    font-weight: 700;
    transition: background 0.15s, color 0.15s;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .ge-close-btn:hover { background: var(--ge-danger); color: white; }
 
  /* ── Lista ── */
  .ge-list { display: flex; flex-direction: column; gap: 12px; }
  .ge-loading { text-align: center; color: #94a3b8; font-size: 11px; font-weight: 700; text-transform: uppercase; padding: 24px 0; }
 
  .ge-item {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 16px 20px;
    border-radius: 1.2rem;
    background: #f8fafc;
    border: 2px solid transparent;
    transition: border-color 0.2s, box-shadow 0.2s;
  }
  .ge-item:hover { border-color: #e2e8f0; box-shadow: 0 4px 16px rgba(0,0,0,0.06); }
 
  .ge-item-left { display: flex; align-items: center; gap: 14px; }
  .ge-swatch {
    width: 38px; height: 38px;
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    font-size: 18px;
    flex-shrink: 0;
  }
  .ge-item-name {
    font-size: 13px;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--ge-dark);
  }
 
  .ge-item-actions { display: flex; gap: 8px; }
  .ge-btn-edit, .ge-btn-del {
    border: none;
    padding: 8px 16px;
    border-radius: 999px;
    font-size: 9px;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    cursor: pointer;
    transition: transform 0.15s, opacity 0.15s;
  }
  .ge-btn-edit:hover, .ge-btn-del:hover { transform: scale(1.06); opacity: 0.85; }
  .ge-btn-edit { background: var(--ge-dark); color: white; }
  .ge-btn-del  { background: #fee2e2; color: var(--ge-danger); }
 
  /* ── Formulario ── */
  .ge-form-wrap {
    border-top: 2px solid #f1f5f9;
    padding-top: 20px;
  }
  .ge-form-wrap.hidden { display: none !important; }
  .ge-form-title {
    font-size: 11px;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: #64748b;
    margin-bottom: 16px;
  }
  #ge-form { display: flex; flex-direction: column; gap: 16px; }
 
  .ge-label {
    display: flex;
    flex-direction: column;
    gap: 8px;
    font-size: 9px;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: #94a3b8;
  }
  .ge-input {
    background: #f8fafc;
    border: 2px solid #e2e8f0;
    padding: 14px 18px;
    border-radius: 1rem;
    font-size: 13px;
    font-weight: 700;
    text-transform: uppercase;
    outline: none;
    transition: border-color 0.2s;
    color: var(--ge-dark);
  }
  .ge-input:focus { border-color: var(--ge-accent); }
 
  .ge-color-row { display: flex; align-items: center; gap: 14px; }
  .ge-color-picker {
    width: 52px; height: 52px;
    border: none;
    border-radius: 50%;
    cursor: pointer;
    padding: 0;
    background: none;
  }
  .ge-color-hex { font-size: 12px; font-weight: 900; color: #475569; }
 
  /* ── Emoji grid ── */
  .ge-emoji-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    padding: 8px 0;
  }
  .ge-emoji-btn {
    width: 40px; height: 40px;
    border-radius: 50%;
    border: 2px solid transparent;
    background: #f1f5f9;
    font-size: 18px;
    cursor: pointer;
    display: flex; align-items: center; justify-content: center;
    transition: border-color 0.15s, transform 0.15s;
  }
  .ge-emoji-btn:hover { transform: scale(1.15); }
  .ge-emoji-btn.selected { border-color: var(--ge-accent); background: #eff6ff; }
 
  /* ── Botones del form ── */
  .ge-form-actions { display: flex; gap: 10px; }
  .ge-btn-save {
    flex: 1;
    background: var(--ge-accent);
    color: white;
    border: none;
    padding: 16px;
    border-radius: 999px;
    font-size: 10px;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    cursor: pointer;
    transition: background 0.2s, transform 0.15s;
  }
  .ge-btn-save:hover { background: #1a50d4; transform: scale(1.02); }
  .ge-btn-cancel {
    background: #f1f5f9;
    color: #64748b;
    border: none;
    padding: 16px 24px;
    border-radius: 999px;
    font-size: 10px;
    font-weight: 900;
    text-transform: uppercase;
    cursor: pointer;
    transition: background 0.2s;
  }
  .ge-btn-cancel:hover { background: #e2e8f0; }
 
  /* ── Toast ── */
  .ge-toast {
    text-align: center;
    padding: 12px 20px;
    border-radius: 999px;
    font-size: 10px;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    transition: opacity 0.3s;
  }
  .ge-toast.hidden { display: none !important; }
  .ge-toast.ok    { background: #dcfce7; color: #16a34a; }
  .ge-toast.error { background: #fee2e2; color: var(--ge-danger); }
</style>
 
<script>
  const EMOJIS = ["💼","🏠","🎯","📚","💪","🎨","🛒","✈️","💡","🎵","🏃","🍎","🔥","⭐","🎉"];
 
  // ── Elementos ──
  const overlay   = document.getElementById('ge-overlay')!;
  const btnAbrir  = document.getElementById('btn-abrir-etiquetas')!;
  const btnCerrar = document.getElementById('ge-close')!;
  const list      = document.getElementById('ge-list')!;
  const formWrap  = document.getElementById('ge-form-wrap')!;
  const form      = document.getElementById('ge-form') as HTMLFormElement;
  const toast     = document.getElementById('ge-toast')!;
  const inputId     = document.getElementById('ge-id') as HTMLInputElement;
  const inputNombre = document.getElementById('ge-nombre') as HTMLInputElement;
  const inputColor  = document.getElementById('ge-color') as HTMLInputElement;
  const colorHex    = document.getElementById('ge-color-hex')!;
  const inputIcono  = document.getElementById('ge-icono') as HTMLInputElement;
  const emojiGrid   = document.getElementById('ge-emoji-grid')!;
  const btnCancelEdit = document.getElementById('ge-cancel-edit')!;
 
  // Construye el grid de emojis seleccionables
  function buildEmojiGrid(selected = "💼") {
    emojiGrid.innerHTML = EMOJIS.map(e =>
      `<button type="button" class="ge-emoji-btn${e === selected ? ' selected' : ''}" data-emoji="${e}">${e}</button>`
    ).join('');
    emojiGrid.querySelectorAll('.ge-emoji-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        emojiGrid.querySelectorAll('.ge-emoji-btn').forEach(b => b.classList.remove('selected'));
        btn.classList.add('selected');
        inputIcono.value = (btn as HTMLElement).dataset.emoji!;
      });
    });
  }
 
  // Muestra un toast temporal
  function showToast(msg: string, type: 'ok' | 'error') {
    toast.textContent = msg;
    toast.className = `ge-toast ${type}`;
    setTimeout(() => { toast.className = 'ge-toast hidden'; }, 2800);
  }
 
  // ── Carga y renderiza las etiquetas desde la API ──
  async function cargarEtiquetas() {
    list.innerHTML = '<div class="ge-loading">Cargando etiquetas…</div>';
    try {
      const res  = await fetch('/api/etiquetas');
      const data = await res.json();
      if (!data.success) throw new Error();
 
      if (data.etiquetas.length === 0) {
        list.innerHTML = '<div class="ge-loading">No hay etiquetas.</div>';
        return;
      }
 
      list.innerHTML = data.etiquetas.map((e: any) => `
        <div class="ge-item" data-id="${e.id}">
          <div class="ge-item-left">
            <div class="ge-swatch" style="background:${e.color}20; color:${e.color}">${e.icono}</div>
            <span class="ge-item-name" style="color:${e.color}">${e.nombre}</span>
          </div>
          <div class="ge-item-actions">
            <button class="ge-btn-edit" data-id="${e.id}" data-nombre="${e.nombre}" data-color="${e.color}" data-icono="${e.icono}">✏️ Editar</button>
            <button class="ge-btn-del"  data-id="${e.id}" data-nombre="${e.nombre}">🗑️ Eliminar</button>
          </div>
        </div>
      `).join('');
 
      // Botón EDITAR
      list.querySelectorAll('.ge-btn-edit').forEach(btn => {
        btn.addEventListener('click', () => {
          const d = (btn as HTMLElement).dataset;
          inputId.value     = d.id!;
          inputNombre.value = d.nombre!;
          inputColor.value  = d.color!;
          colorHex.textContent = d.color!;
          inputIcono.value  = d.icono!;
          buildEmojiGrid(d.icono);
          formWrap.classList.remove('hidden');
          formWrap.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
        });
      });
 
      // Botón ELIMINAR
      list.querySelectorAll('.ge-btn-del').forEach(btn => {
        btn.addEventListener('click', async () => {
          const d = (btn as HTMLElement).dataset;
          if (!confirm(`¿Eliminar la etiqueta "${d.nombre}"? Esta acción no se puede deshacer.`)) return;
 
          const res = await fetch('/api/etiquetas', {
            method: 'DELETE',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ id: Number(d.id) })
          });
          const data = await res.json();
          if (data.success) {
            showToast(`✅ Etiqueta "${d.nombre}" eliminada`, 'ok');
            await cargarEtiquetas();
          } else {
            showToast('❌ No se pudo eliminar', 'error');
          }
        });
      });
 
    } catch {
      list.innerHTML = '<div class="ge-loading">Error al cargar etiquetas.</div>';
    }
  }
 
  // ── SUBMIT del formulario de edición ──
  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    const payload = {
      id:     Number(inputId.value),
      nombre: inputNombre.value.trim().toLowerCase(),
      color:  inputColor.value,
      icono:  inputIcono.value,
    };
 
    try {
      const res  = await fetch('/api/etiquetas', {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload)
      });
      const data = await res.json();
      if (data.success) {
        showToast(`✅ Etiqueta "${payload.nombre}" actualizada`, 'ok');
        formWrap.classList.add('hidden');
        form.reset();
        await cargarEtiquetas();
      } else {
        showToast('❌ No se pudo guardar', 'error');
      }
    } catch {
      showToast('❌ Error de conexión', 'error');
    }
  });
 
  // Actualiza el hex visible al cambiar el color
  inputColor.addEventListener('input', () => {
    colorHex.textContent = inputColor.value;
  });
 
  // ── Abrir / cerrar panel ──
  btnAbrir.addEventListener('click', async () => {
    overlay.classList.remove('hidden');
    formWrap.classList.add('hidden');
    await cargarEtiquetas();
    buildEmojiGrid();
  });
 
  const cerrar = () => { overlay.classList.add('hidden'); formWrap.classList.add('hidden'); };
  btnCerrar.addEventListener('click', cerrar);
  overlay.addEventListener('click', (e) => { if (e.target === overlay) cerrar(); });
  btnCancelEdit.addEventListener('click', () => formWrap.classList.add('hidden'));
</script>