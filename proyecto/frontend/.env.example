SITE=https://myagenda-2.onrender.com
PUBLIC_SITE_URL=https://myagenda-2.onrender.com
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
DATABASE_URL=
JWT_SECRET=

# ── Email OTP (Gmail SMTP — completamente gratis) ────────────────────────────
# 1. Activa "Verificación en 2 pasos" en tu Gmail
# 2. Ve a Cuenta de Google > Seguridad > Contraseñas de aplicaciones
# 3. Genera una contraseña para "Correo" y ponla en SMTP_PASS
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tucorreo@gmail.com
SMTP_PASS=xxxx-xxxx-xxxx-xxxx

# ── WhatsApp OTP (Green-API — gratis 500 mensajes/día) ───────────────────────
# 1. Regístrate en https://green-api.com (plan gratuito, no requiere tarjeta)
# 2. Crea una instancia y escanea el QR con tu WhatsApp
# 3. Copia el ID de instancia y el token API aquí
GREEN_API_INSTANCE_ID=
GREEN_API_TOKEN=

# ── Resend (notificaciones de tareas por correo — 3 000 emails/mes gratis) ───
# Opcional: solo si quieres notificaciones de tareas desde un dominio propio
RESEND_API_KEY=
RESEND_FROM=My Agenda <no-reply@tudominio.com>
